{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "endDate": {
      "type": "string"
    },
    "venue": {
      "type": "string"
    },
    "area": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "free": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "venue",
    "area",
    "category"
  ]
}