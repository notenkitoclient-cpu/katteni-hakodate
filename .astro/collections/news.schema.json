{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "開店",
        "閉店",
        "工事中",
        "イベント",
        "目撃情報",
        "その他"
      ]
    },
    "date": {
      "type": "string"
    },
    "area": {
      "type": "string"
    },
    "reporter": {
      "default": "編集部",
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "type",
    "date",
    "area"
  ]
}