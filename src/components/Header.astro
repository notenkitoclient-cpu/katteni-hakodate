---
const categories = [
  { name: 'グルメ',       href: '/category/グルメ' },
  { name: '観光',         href: '/category/観光' },
  { name: '暮らし',       href: '/category/暮らし' },
  { name: 'イベント',     href: '/category/イベント' },
  { name: '人・ビジネス', href: '/category/人・ビジネス' },
  { name: '特産品',       href: '/category/特産品' },
];
---

<header id="site-header" class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-mark">
        <img src="/images/kacchin-nightview.png" alt="" class="logo-img" />
      </div>
      <div class="logo-type">
        <span class="logo-ja">カッテニハコダテ</span>
        <span class="logo-en">KATTENI HAKODATE</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="nav" aria-label="メインナビゲーション">
      {categories.map(cat => (
        <a href={cat.href} class="nav-item">{cat.name}</a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="/members" class="header-cta">仕掛け人募集</a>

  </div>
</header>

<div class="header-offset" aria-hidden="true"></div>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 64px;
  background: rgba(255, 255, 255, 0.93);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.site-header.scrolled {
  border-bottom: 1px solid rgba(13, 45, 82, 0.08);
  box-shadow: 0 2px 20px rgba(13, 45, 82, 0.07);
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Logo */
.logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 9px;
  text-decoration: none;
}
.logo-mark {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, #d4ecf7, #b4e0f0);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.logo-img {
  width: 26px;
  height: 26px;
  object-fit: contain;
}
.logo-type { line-height: 1; }
.logo-ja {
  display: block;
  font-family: 'Shippori Mincho', serif;
  font-size: 15px;
  font-weight: 800;
  color: #0d2d52;
  letter-spacing: 0.02em;
}
.logo-en {
  display: block;
  font-size: 7.5px;
  letter-spacing: 0.22em;
  color: #9ab8c8;
  margin-top: 3px;
}

/* Nav */
.nav {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  overflow-x: auto;
  scrollbar-width: none;
}
.nav::-webkit-scrollbar { display: none; }

.nav-item {
  padding: 6px 11px;
  font-size: 13px;
  font-weight: 500;
  color: #4a6070;
  white-space: nowrap;
  border-radius: 5px;
  transition: background 0.18s, color 0.18s;
}
.nav-item:hover {
  background: #e4f5f4;
  color: #0d8a87;
}

/* CTA */
.header-cta {
  flex-shrink: 0;
  padding: 8px 18px;
  background: #0d8a87;
  color: #fff;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  white-space: nowrap;
  transition: background 0.2s, transform 0.2s;
}
.header-cta:hover {
  background: #0fa09c;
  transform: translateY(-1px);
}

.header-offset { height: 64px; margin-bottom: -64px; }
</style>

<script>
  const hdr = document.getElementById('site-header');
  function sync() {
    hdr?.classList.toggle('scrolled', window.scrollY > 30);
  }
  sync();
  window.addEventListener('scroll', sync, { passive: true });
</script>
