---
const categories = [
  { name: 'グルメ',       href: '/category/グルメ' },
  { name: '観光',         href: '/category/観光' },
  { name: '暮らし',       href: '/category/暮らし' },
  { name: 'イベント',     href: '/category/イベント' },
  { name: '人・ビジネス', href: '/category/人・ビジネス' },
  { name: '特産品',       href: '/category/特産品' },
];
---

<header style="
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(13,45,82,0.07);
">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px; height: 64px; display: flex; align-items: center; gap: 24px;">

    <!-- Logo -->
    <a href="/" style="flex-shrink: 0; display: flex; align-items: center; gap: 9px; text-decoration: none;">
      <img src="/images/kacchin-nightview.png" alt="" style="width: 30px; height: 30px; object-fit: contain;" />
      <div style="line-height: 1;">
        <span style="font-family: 'Shippori Mincho', serif; font-size: 16px; font-weight: 800; color: #0d2d52; letter-spacing: 0.02em; display: block;">カッテニハコダテ</span>
        <span style="font-size: 8px; color: #9ab0ba; letter-spacing: 0.22em; display: block; margin-top: 2px;">KATTENI HAKODATE</span>
      </div>
    </a>

    <!-- Nav -->
    <nav style="flex: 1; display: flex; align-items: center; justify-content: center; gap: 2px; overflow-x: auto; scrollbar-width: none;">
      {categories.map(cat => (
        <a href={cat.href} style="
          padding: 6px 12px; font-size: 13px; font-weight: 500;
          color: #4a6070; white-space: nowrap; border-radius: 4px;
          transition: all 0.2s;
        "
        onmouseover="this.style.background='#eef6f8'; this.style.color='#0d8a87'"
        onmouseout="this.style.background='transparent'; this.style.color='#4a6070'"
        >{cat.name}</a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="/members" style="
      flex-shrink: 0; padding: 8px 18px;
      background: #0d8a87; color: white;
      border-radius: 4px; font-size: 12px; font-weight: 700;
      white-space: nowrap; letter-spacing: 0.05em; transition: background 0.2s;
    "
    onmouseover="this.style.background='#0faba8'"
    onmouseout="this.style.background='#0d8a87'"
    >仕掛け人募集</a>
  </div>
</header>

<div style="height: 64px;"></div>
