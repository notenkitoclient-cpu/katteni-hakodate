---
const navItems = [
  { name: '調査報告', href: '/articles' },
  { name: 'ニュース', href: '/news' },
  { name: 'について', href: '/about' },
];
---

<header id="site-header" class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-mark">
        <img src="/images/kacchin-nightview.png" alt="" class="logo-img" />
      </div>
      <div class="logo-type">
        <span class="logo-ja">カッテニハコダテ</span>
        <span class="logo-en">KATTENI HAKODATE</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav" aria-label="メインナビゲーション">
      {navItems.map(item => (
        <a href={item.href} class="nav-item">{item.name}</a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="/submit" class="header-cta">情報を送る ＋</a>

    <!-- Hamburger (mobile) -->
    <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>

  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <nav class="drawer-nav">
    {navItems.map(item => (
      <a href={item.href} class="drawer-item">{item.name}</a>
    ))}
    <a href="/submit" class="drawer-cta">情報を送る ＋</a>
  </nav>
</div>
<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="header-offset" aria-hidden="true"></div>

<style>
.site-header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 62px;
  background: rgba(251,247,239,0.96);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 3px solid #9E3D26;
  box-shadow: 0 2px 12px rgba(42,36,32,0.08);
}
.header-inner {
  max-width: 1200px; margin: 0 auto;
  padding: 0 32px; height: 100%;
  display: flex; align-items: center; gap: 16px;
}

/* Logo */
.logo { flex-shrink: 0; display: flex; align-items: center; gap: 10px; text-decoration: none; }
.logo-mark {
  width: 34px; height: 34px; border-radius: 4px;
  background: #9E3D26;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; flex-shrink: 0;
  border: 2px solid #2A2420;
}
.logo-img { width: 26px; height: 26px; object-fit: contain; filter: brightness(0) invert(1); }
.logo-type { line-height: 1; }
.logo-ja { display: block; font-family: 'Shippori Mincho', serif; font-size: 15px; font-weight: 800; color: #2A2420; letter-spacing: 0.02em; }
.logo-en { display: block; font-size: 7px; letter-spacing: 0.28em; color: #8A7A6A; margin-top: 3px; text-transform: uppercase; }

/* Desktop Nav */
.nav { flex: 1; display: flex; align-items: center; justify-content: center; gap: 4px; overflow-x: auto; scrollbar-width: none; }
.nav::-webkit-scrollbar { display: none; }
.nav-item {
  padding: 6px 14px; font-size: 13.5px; font-weight: 700; color: #5A4A3A;
  white-space: nowrap; border-radius: 3px; letter-spacing: 0.04em;
  transition: background 0.18s, color 0.18s;
  font-family: 'Shippori Mincho', serif;
}
.nav-item:hover { background: #F7E8E2; color: #9E3D26; }

/* CTA */
.header-cta {
  flex-shrink: 0; padding: 8px 16px;
  background: #9E3D26; color: #F5EDD8; border-radius: 3px;
  font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
  white-space: nowrap; transition: background 0.2s;
  border: 2px solid #2A2420;
  font-family: 'Shippori Mincho', serif;
}
.header-cta:hover { background: #B84A2E; }

/* Hamburger */
.hamburger {
  display: none; flex-direction: column; justify-content: center;
  gap: 5px; width: 40px; height: 40px; padding: 8px;
  background: none; border: none; cursor: pointer;
  margin-left: auto; border-radius: 4px; transition: background 0.2s;
}
.hamburger:hover { background: #F7E8E2; }
.ham-bar { display: block; width: 22px; height: 2.5px; background: #2A2420; border-radius: 1px; transition: transform 0.28s ease, opacity 0.2s; }
.hamburger.open .ham-bar:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
.hamburger.open .ham-bar:nth-child(2) { opacity: 0; }
.hamburger.open .ham-bar:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }

/* Mobile drawer */
.mobile-drawer {
  position: fixed; top: 62px; left: 0; right: 0; z-index: 99;
  background: #FBF7EF;
  border-bottom: 3px solid #9E3D26;
  transform: translateY(-8px); opacity: 0; pointer-events: none;
  transition: transform 0.28s ease, opacity 0.22s ease;
}
.mobile-drawer.open { transform: translateY(0); opacity: 1; pointer-events: auto; }
.drawer-nav { display: flex; flex-direction: column; padding: 16px 20px 24px; gap: 2px; }
.drawer-item {
  padding: 13px 16px; font-size: 15px; font-weight: 700; color: #2A2420;
  border-radius: 4px; transition: background 0.18s, color 0.18s;
  font-family: 'Shippori Mincho', serif; letter-spacing: 0.04em;
  border-bottom: 1px solid #EDE3CC;
}
.drawer-item:hover { background: #F7E8E2; color: #9E3D26; }
.drawer-cta {
  margin-top: 12px; padding: 14px 16px;
  background: #9E3D26; color: #F5EDD8;
  border-radius: 3px; border: 2px solid #2A2420;
  font-size: 14px; font-weight: 700; text-align: center;
  letter-spacing: 0.06em; transition: background 0.2s;
  font-family: 'Shippori Mincho', serif;
}
.drawer-cta:hover { background: #B84A2E; }
.drawer-overlay { position: fixed; inset: 0; z-index: 98; background: rgba(42,36,32,0.3); opacity: 0; pointer-events: none; transition: opacity 0.25s; }
.drawer-overlay.open { opacity: 1; pointer-events: auto; }

.header-offset { height: 62px; margin-bottom: -62px; }

@media (max-width: 900px) {
  .header-inner { padding: 0 16px; }
  .nav { display: none; }
  .header-cta { display: none; }
  .hamburger { display: flex; }
  .logo-en { display: none; }
}
</style>

<script>
  const btn = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');

  function openMenu() {
    btn?.classList.add('open'); drawer?.classList.add('open'); overlay?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true'); drawer?.setAttribute('aria-hidden', 'false');
  }
  function closeMenu() {
    btn?.classList.remove('open'); drawer?.classList.remove('open'); overlay?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false'); drawer?.setAttribute('aria-hidden', 'true');
  }
  btn?.addEventListener('click', () => btn.classList.contains('open') ? closeMenu() : openMenu());
  overlay?.addEventListener('click', closeMenu);
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>
