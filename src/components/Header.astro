---
const categories = [
  { name: 'グルメ',       href: '/category/グルメ' },
  { name: '観光',         href: '/category/観光' },
  { name: '暮らし',       href: '/category/暮らし' },
  { name: 'イベント',     href: '/category/イベント' },
  { name: '人・ビジネス', href: '/category/人・ビジネス' },
  { name: '特産品',       href: '/category/特産品' },
];
---

<header id="site-header" class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-mark">
        <img src="/images/kacchin-nightview.png" alt="" class="logo-img" />
      </div>
      <div class="logo-type">
        <span class="logo-ja">カッテニハコダテ</span>
        <span class="logo-en">KATTENI HAKODATE</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="nav" aria-label="メインナビゲーション">
      {categories.map(cat => (
        <a href={cat.href} class="nav-item">{cat.name}</a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="/members" class="header-cta">仕掛け人募集</a>

    <!-- Hamburger button (mobile only) -->
    <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>

  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <nav class="drawer-nav">
    {categories.map(cat => (
      <a href={cat.href} class="drawer-item">{cat.name}</a>
    ))}
    <a href="/members" class="drawer-cta">仕掛け人に参加する</a>
  </nav>
</div>
<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="header-offset" aria-hidden="true"></div>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 64px;
  background: rgba(255, 255, 255, 0.93);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.site-header.scrolled {
  border-bottom: 1px solid rgba(13, 45, 82, 0.08);
  box-shadow: 0 2px 20px rgba(13, 45, 82, 0.07);
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Logo */
.logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 9px;
  text-decoration: none;
}
.logo-mark {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, #d4ecf7, #b4e0f0);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.logo-img {
  width: 26px;
  height: 26px;
  object-fit: contain;
}
.logo-type { line-height: 1; }
.logo-ja {
  display: block;
  font-family: 'Shippori Mincho', serif;
  font-size: 15px;
  font-weight: 800;
  color: #0d2d52;
  letter-spacing: 0.02em;
}
.logo-en {
  display: block;
  font-size: 7.5px;
  letter-spacing: 0.22em;
  color: #9ab8c8;
  margin-top: 3px;
}

/* Desktop Nav */
.nav {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  overflow-x: auto;
  scrollbar-width: none;
}
.nav::-webkit-scrollbar { display: none; }
.nav-item {
  padding: 6px 11px;
  font-size: 13px;
  font-weight: 500;
  color: #4a6070;
  white-space: nowrap;
  border-radius: 5px;
  transition: background 0.18s, color 0.18s;
}
.nav-item:hover {
  background: #e4f5f4;
  color: #0d8a87;
}

/* Desktop CTA */
.header-cta {
  flex-shrink: 0;
  padding: 8px 18px;
  background: #0d8a87;
  color: #fff;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  white-space: nowrap;
  transition: background 0.2s, transform 0.2s;
}
.header-cta:hover {
  background: #0fa09c;
  transform: translateY(-1px);
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  padding: 8px;
  background: none;
  border: none;
  cursor: pointer;
  margin-left: auto;
  border-radius: 8px;
  transition: background 0.2s;
}
.hamburger:hover { background: #f0f8f8; }
.ham-bar {
  display: block;
  width: 22px;
  height: 2px;
  background: #0d2d52;
  border-radius: 2px;
  transition: transform 0.28s ease, opacity 0.2s;
}
.hamburger.open .ham-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open .ham-bar:nth-child(2) { opacity: 0; }
.hamburger.open .ham-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile drawer */
.mobile-drawer {
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  z-index: 99;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(13,45,82,0.08);
  transform: translateY(-8px);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.22s ease;
}
.mobile-drawer.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}
.drawer-nav {
  display: flex;
  flex-direction: column;
  padding: 16px 20px 24px;
  gap: 2px;
}
.drawer-item {
  padding: 13px 16px;
  font-size: 15px;
  font-weight: 600;
  color: #0d2d52;
  border-radius: 8px;
  transition: background 0.18s, color 0.18s;
}
.drawer-item:hover {
  background: #e4f5f4;
  color: #0d8a87;
}
.drawer-cta {
  margin-top: 10px;
  padding: 14px 16px;
  background: #0d8a87;
  color: white;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  text-align: center;
  letter-spacing: 0.04em;
  transition: background 0.2s;
}
.drawer-cta:hover { background: #0fa09c; }

/* Overlay behind drawer */
.drawer-overlay {
  position: fixed;
  inset: 0;
  z-index: 98;
  background: rgba(0,0,0,0.2);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}
.drawer-overlay.open {
  opacity: 1;
  pointer-events: auto;
}

.header-offset { height: 64px; margin-bottom: -64px; }

/* ── Responsive ── */
@media (max-width: 768px) {
  .header-inner { padding: 0 16px; }
  .nav { display: none; }
  .header-cta { display: none; }
  .hamburger { display: flex; }
  .logo-en { display: none; }
}
</style>

<script>
  const hdr = document.getElementById('site-header');
  const btn = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');

  // Scroll shadow
  function syncScroll() {
    hdr?.classList.toggle('scrolled', window.scrollY > 30);
  }
  syncScroll();
  window.addEventListener('scroll', syncScroll, { passive: true });

  // Hamburger toggle
  function openMenu() {
    btn?.classList.add('open');
    drawer?.classList.add('open');
    overlay?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true');
    drawer?.setAttribute('aria-hidden', 'false');
  }
  function closeMenu() {
    btn?.classList.remove('open');
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
  }
  btn?.addEventListener('click', () => {
    btn.classList.contains('open') ? closeMenu() : openMenu();
  });
  overlay?.addEventListener('click', closeMenu);

  // Close on link tap
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>
