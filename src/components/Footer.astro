---
---
<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <div class="brand-logo">
          <div class="brand-mark">
            <img src="/images/kacchin-nightview.png" alt="カッチン" class="brand-img" />
          </div>
          <div>
            <p class="brand-ja">カッテニハコダテ</p>
            <p class="brand-en">KATTENI HAKODATE</p>
          </div>
        </div>
        <p class="brand-tagline">勝手に、楽しく。</p>
        <p class="brand-desc">
          頼まれてもないのに、函館・道南の情報を勝手に集めて勝手に発信するローカルメディア。
          市民の日常に寄り添う超ローカルな情報を届けます。
        </p>
        <a href="https://x.com/katteni_hakodate" target="_blank" rel="noopener" class="social-btn">
          𝕏 @katteni_hakodate
        </a>
      </div>

      <!-- 3軸リンク -->
      <div class="footer-col">
        <p class="col-head">活動</p>
        <ul class="col-list">
          {[
            { text: '📋 情報収集',   href: '/news' },
            { text: '💰 応援',       href: '/crowdfunding' },
            { text: '🔍 調べた',     href: '/articles' },
            { text: '情報を投稿する', href: '/submit' },
          ].map(item => (
            <li><a href={item.href} class="col-link">{item.text}</a></li>
          ))}
        </ul>
      </div>

      <!-- Site -->
      <div class="footer-col">
        <p class="col-head">サイト</p>
        <ul class="col-list">
          {[
            { text: '仕掛け人',           href: '/members' },
            { text: 'カッテニハコダテとは', href: '/about' },
          ].map(item => (
            <li><a href={item.href} class="col-link">{item.text}</a></li>
          ))}
        </ul>

        <p class="col-head" style="margin-top: 28px;">カテゴリ</p>
        <ul class="col-list">
          {['グルメ','暮らし','イベント','人・ビジネス','特産品'].map(cat => (
            <li><a href={`/category/${cat}`} class="col-link">{cat}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© 2026 カッテニハコダテ — 頼まれてないけどやってます。</p>
      <p class="footer-copy">⚓ 港町函館より</p>
    </div>

  </div>
</footer>

<style>
.site-footer {
  background: #2A2420;
  color: #F5EDD8;
  padding: 64px 40px 32px;
  border-top: 4px solid #9E3D26;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
}

/* Grid */
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 56px;
  margin-bottom: 48px;
}

/* Brand */
.brand-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}
.brand-mark {
  width: 36px; height: 36px;
  background: #9E3D26;
  border-radius: 4px;
  border: 2px solid #5A4A3A;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.brand-img {
  width: 26px; height: 26px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}
.brand-ja {
  font-family: 'Shippori Mincho', serif;
  font-size: 16px; font-weight: 800;
  color: #F5EDD8; letter-spacing: 0.04em;
}
.brand-en {
  font-size: 8px; color: #8A7A6A;
  letter-spacing: 0.28em; margin-top: 2px; text-transform: uppercase;
}
.brand-tagline {
  font-family: 'Shippori Mincho', serif;
  font-size: 18px; font-weight: 800;
  color: #D4A02A; margin-bottom: 12px;
  letter-spacing: 0.06em;
}
.brand-desc {
  font-size: 13px;
  color: #8A7A6A;
  line-height: 1.9;
  max-width: 300px;
  margin-bottom: 20px;
}
.social-btn {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; color: #8A7A6A;
  padding: 7px 16px;
  border: 1px solid #5A4A3A;
  border-radius: 3px;
  transition: border-color 0.2s, color 0.2s;
  font-weight: 600;
}
.social-btn:hover { border-color: #9E3D26; color: #F5EDD8; }

/* Columns */
.col-head {
  font-size: 10px; letter-spacing: 0.25em;
  color: #D4A02A; font-weight: 700;
  margin-bottom: 16px; text-transform: uppercase;
  font-family: 'Shippori Mincho', serif;
}
.col-list {
  list-style: none;
  display: flex; flex-direction: column; gap: 10px;
}
.col-link {
  font-size: 13.5px; color: #8A7A6A;
  transition: color 0.2s;
  font-weight: 500;
}
.col-link:hover { color: #F5EDD8; }

/* Bottom */
.footer-bottom {
  padding-top: 24px;
  border-top: 1px solid #5A4A3A;
  display: flex; justify-content: space-between;
  align-items: center; flex-wrap: wrap; gap: 8px;
}
.footer-copy {
  font-size: 11.5px; color: #5A4A3A;
  font-family: 'Shippori Mincho', serif;
}

/* Responsive */
@media (max-width: 768px) {
  .site-footer { padding: 48px 20px 28px; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer-brand { grid-column: 1 / 3; }
  .brand-desc { max-width: 100%; }
}
@media (max-width: 480px) {
  .footer-grid { grid-template-columns: 1fr; gap: 28px; }
  .footer-brand { grid-column: auto; }
  .footer-bottom { flex-direction: column; align-items: flex-start; gap: 4px; }
}
</style>
