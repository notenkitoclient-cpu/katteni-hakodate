---
---
<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <div class="brand-logo">
          <img src="/images/kacchin-nightview.png" alt="カッチン" class="brand-img" />
          <div>
            <p class="brand-ja">カッテニハコダテ</p>
            <p class="brand-en">KATTENI HAKODATE</p>
          </div>
        </div>
        <p class="brand-desc">
          港町・函館の魅力を、地元目線でかってに発信するコミュニティメディア。
        </p>
        <a href="https://x.com/katteni_hakodate" target="_blank" rel="noopener" class="social-btn">
          𝕏 &nbsp;@katteni_hakodate
        </a>
      </div>

      <!-- Categories -->
      <div class="footer-col">
        <p class="col-head">Category</p>
        <ul class="col-list">
          {['グルメ','観光','暮らし','イベント','人・ビジネス','特産品'].map(cat => (
            <li><a href={`/category/${cat}`} class="col-link">{cat}</a></li>
          ))}
        </ul>
      </div>

      <!-- Site -->
      <div class="footer-col">
        <p class="col-head">Site</p>
        <ul class="col-list">
          {[
            { text: 'カッテニハコダテとは', href: '/about' },
            { text: 'ハコダテ仕掛け人',     href: '/members' },
            { text: '情報を投稿する',        href: '/submit' },
            { text: 'すべての記事',          href: '/articles' },
          ].map(item => (
            <li><a href={item.href} class="col-link">{item.text}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© 2026 カッテニハコダテ All rights reserved.</p>
      <p class="footer-copy">⚓ 港町函館より発信中</p>
    </div>

  </div>
</footer>

<style>
.site-footer {
  background: #0d2d52;
  color: white;
  padding: 72px 40px 32px;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
}

/* Grid */
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 56px;
  margin-bottom: 56px;
}

/* Brand */
.footer-brand {}
.brand-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}
.brand-img {
  width: 38px;
  height: 38px;
  object-fit: contain;
}
.brand-ja {
  font-family: 'Shippori Mincho', serif;
  font-size: 17px;
  font-weight: 800;
  color: white;
  letter-spacing: 0.04em;
}
.brand-en {
  font-size: 9px;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.28em;
  margin-top: 2px;
}
.brand-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
  max-width: 300px;
  margin-bottom: 24px;
}
.social-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: rgba(255,255,255,0.55);
  padding: 7px 16px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 4px;
  transition: border-color 0.2s, color 0.2s;
}
.social-btn:hover {
  border-color: rgba(255,255,255,0.5);
  color: white;
}

/* Columns */
.footer-col {}
.col-head {
  font-size: 10px;
  letter-spacing: 0.25em;
  color: #52d9d6;
  font-weight: 700;
  margin-bottom: 18px;
  text-transform: uppercase;
}
.col-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 11px;
}
.col-link {
  font-size: 14px;
  color: rgba(255,255,255,0.55);
  transition: color 0.2s;
}
.col-link:hover { color: white; }

/* Bottom */
.footer-bottom {
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.footer-copy {
  font-size: 12px;
  color: rgba(255,255,255,0.25);
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .site-footer { padding: 48px 20px 28px; }
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .footer-brand {
    grid-column: 1 / 3;
  }
  .brand-desc { max-width: 100%; }
}

@media (max-width: 480px) {
  .footer-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .footer-brand { grid-column: auto; }
  .footer-bottom { flex-direction: column; align-items: flex-start; gap: 4px; }
}
</style>
