---
---
<footer style="background: #0d0d0d; color: white; padding: 72px 24px 32px; margin-top: 120px;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 64px; margin-bottom: 64px;">

      <!-- Brand -->
      <div>
        <p style="font-family: 'Shippori Mincho', serif; font-size: 20px; font-weight: 800; color: white; margin-bottom: 6px; letter-spacing: 0.05em;">カッテニハコダテ</p>
        <p style="font-size: 10px; color: #6c757d; letter-spacing: 0.3em; margin-bottom: 24px;">KATTENI HAKODATE</p>
        <p style="font-size: 13px; color: #6c757d; line-height: 1.9; max-width: 320px; margin-bottom: 28px;">
          港町・函館の魅力を、地元目線でかってに発信するコミュニティメディア。グルメ・観光・移住・イベント情報をお届けします。
        </p>
        <div style="display: flex; gap: 12px;">
          {[
            { label: 'X (Twitter)', href: 'https://x.com/katteni_hakodate' },
          ].map(s => (
            <a href={s.href} target="_blank" style="font-size: 12px; color: #6c757d; padding: 6px 14px; border: 1px solid #2a2a2a; border-radius: 4px; transition: all 0.2s;"
              onmouseover="this.style.borderColor='#6c757d'; this.style.color='white'"
              onmouseout="this.style.borderColor='#2a2a2a'; this.style.color='#6c757d'">{s.label}</a>
          ))}
        </div>
      </div>

      <!-- Categories -->
      <div>
        <p style="font-size: 11px; letter-spacing: 0.2em; color: #6c757d; margin-bottom: 20px; text-transform: uppercase;">Category</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px;">
          {['グルメ', '観光', '暮らし', 'イベント', '人・ビジネス', '特産品'].map(cat => (
            <li><a href={`/category/${cat}`} style="font-size: 14px; color: #aab4bc; transition: color 0.2s;"
              onmouseover="this.style.color='white'"
              onmouseout="this.style.color='#aab4bc'">{cat}</a></li>
          ))}
        </ul>
      </div>

      <!-- Site -->
      <div>
        <p style="font-size: 11px; letter-spacing: 0.2em; color: #6c757d; margin-bottom: 20px; text-transform: uppercase;">Site</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px;">
          {[
            { text: 'このサイトについて', href: '/about' },
            { text: 'ハコダテ仕掛け人', href: '/members' },
            { text: '情報を投稿する', href: '/submit' },
            { text: 'すべての記事', href: '/articles' },
          ].map(item => (
            <li><a href={item.href} style="font-size: 14px; color: #aab4bc; transition: color 0.2s;"
              onmouseover="this.style.color='white'"
              onmouseout="this.style.color='#aab4bc'">{item.text}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div style="padding-top: 32px; border-top: 1px solid #1a1a1a; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
      <p style="font-size: 12px; color: #3d4a52;">© 2026 カッテニハコダテ All rights reserved.</p>
      <p style="font-size: 12px; color: #3d4a52;">⚓ 港町函館より発信中</p>
    </div>
  </div>
</footer>
