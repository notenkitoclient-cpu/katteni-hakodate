---
---
<section style="
  position: relative;
  background: linear-gradient(160deg, #061a2e 0%, #0a2d4a 45%, #0d5a7a 75%, #0d8a87 100%);
  min-height: 100vh;
  display: flex; flex-direction: column;
  overflow: hidden;
">
  <!-- Stars / Noise texture overlay -->
  <div style="
    position: absolute; inset: 0;
    background-image: radial-gradient(circle at 20% 30%, rgba(13,138,135,0.15) 0%, transparent 50%),
                      radial-gradient(circle at 80% 70%, rgba(13,45,82,0.4) 0%, transparent 50%);
    pointer-events: none;
  "></div>

  <!-- Floating circles (depth) -->
  <div style="position: absolute; top: 10%; right: 8%; width: 320px; height: 320px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.06); pointer-events: none;"></div>
  <div style="position: absolute; top: 18%; right: 14%; width: 200px; height: 200px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.04); pointer-events: none;"></div>

  <!-- Main content -->
  <div style="
    flex: 1; display: flex; align-items: center;
    max-width: 1200px; margin: 0 auto; padding: 80px 40px 60px;
    width: 100%;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 40px; align-items: center;
  ">
    <!-- Left: Text -->
    <div style="position: relative; z-index: 2;">
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 28px;">
        <div style="width: 32px; height: 1px; background: #0d8a87;"></div>
        <p style="font-size: 11px; letter-spacing: 0.35em; color: #0d8a87; font-weight: 700; text-transform: uppercase;">Hakodate Community Media</p>
      </div>

      <h1 style="
        font-family: 'Shippori Mincho', serif;
        font-size: clamp(38px, 5.5vw, 68px);
        font-weight: 800; line-height: 1.25;
        color: #ffffff; margin-bottom: 28px;
        letter-spacing: 0.02em;
      ">
        知らなかった、<br>
        <span style="color: #52d9d6;">ハコダテ</span>がある。
      </h1>

      <p style="
        font-size: 15px; color: rgba(255,255,255,0.65);
        line-height: 1.9; margin-bottom: 44px;
        max-width: 440px;
      ">
        港町・函館に住む人、訪れる人、移住を考える人へ。<br>
        地元目線で、かってに函館の魅力を発信するコミュニティメディアです。
      </p>

      <div style="display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 56px;">
        <a href="/articles" style="
          padding: 14px 32px;
          background: #0d8a87; color: white;
          font-size: 14px; font-weight: 700;
          border-radius: 3px; letter-spacing: 0.06em;
          transition: all 0.25s;
        "
        onmouseover="this.style.background='#0faba8'"
        onmouseout="this.style.background='#0d8a87'"
        >記事を読む</a>

        <a href="/about" style="
          padding: 14px 32px;
          border: 1.5px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);
          font-size: 14px; font-weight: 700;
          border-radius: 3px; letter-spacing: 0.06em;
          transition: all 0.25s;
        "
        onmouseover="this.style.borderColor='rgba(255,255,255,0.8)'; this.style.color='white'"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.color='rgba(255,255,255,0.85)'"
        >サイトについて</a>
      </div>

      <!-- Stats -->
      <div style="display: flex; gap: 40px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.1);">
        {[
          { num: '14+', label: '記事' },
          { num: '6', label: 'カテゴリ' },
          { num: '4', label: '仕掛け人' },
        ].map(item => (
          <div>
            <p style="font-family: 'Shippori Mincho', serif; font-size: 30px; font-weight: 800; color: #52d9d6; line-height: 1;">{item.num}</p>
            <p style="font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 5px; letter-spacing: 0.15em;">{item.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: カッチン -->
    <div style="position: relative; display: flex; align-items: center; justify-content: center; z-index: 2;">
      <!-- Glow behind カッチン -->
      <div style="
        position: absolute; width: 360px; height: 360px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(13,138,135,0.25) 0%, transparent 70%);
        pointer-events: none;
      "></div>

      <img
        src="/images/kacchin-nightview.png"
        alt="カッチン — カッテニハコダテのマスコット"
        style="
          width: 100%; max-width: 400px;
          filter: drop-shadow(0 20px 60px rgba(13,138,135,0.35));
          position: relative;
          animation: float 6s ease-in-out infinite;
        "
      />

      <!-- Floating label -->
      <div style="
        position: absolute; bottom: 0; right: 0;
        background: #c05a3a; color: white;
        padding: 12px 18px; border-radius: 4px;
        font-size: 12px; font-weight: 700;
        box-shadow: 0 8px 24px rgba(192,90,58,0.45);
        text-align: center; line-height: 1.5;
      ">
        <div style="font-size: 10px; letter-spacing: 0.2em; margin-bottom: 2px;">HAKODATE</div>
        <div>函館発ローカル情報</div>
      </div>
    </div>
  </div>

  <!-- Wave separator -->
  <div style="position: relative; flex-shrink: 0; line-height: 0;">
    <svg viewBox="0 0 1440 80" style="width: 100%; display: block;" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-16px); }
  }
</style>
