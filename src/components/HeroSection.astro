---
---
<section class="hero">
  <!-- Brick texture overlay -->
  <div class="hero-texture" aria-hidden="true"></div>

  <div class="hero-container">

    <!-- Left: Main message -->
    <div class="hero-main">

      <div class="hero-stamp-row">
        <span class="hero-stamp">勝手に</span>
        <span class="hero-eye">道南エリア 超ローカルメディア</span>
      </div>

      <h1 class="hero-headline">
        <span class="hl-small">頼まれてないけど</span>
        <span class="hl-large">函館を勝手に<br>楽しくする。</span>
      </h1>

      <p class="hero-sub">
        函館・北斗・七飯の<strong>リアルな日常情報</strong>を勝手に集めて、<br>
        頑張ってる人・店・プロジェクトを勝手に応援します。
      </p>

      <div class="hero-axes">
        <a href="/news" class="axis-badge axis-info">
          <span class="axis-icon">📋</span>
          <span class="axis-name">情報収集</span>
          <span class="axis-desc">開店・閉店・街の変化</span>
        </a>
        <a href="/crowdfunding" class="axis-badge axis-ouen">
          <span class="axis-icon">💰</span>
          <span class="axis-name">応援</span>
          <span class="axis-desc">クラファン・注目プロジェクト</span>
        </a>
        <a href="/articles" class="axis-badge axis-shira">
          <span class="axis-icon">🔍</span>
          <span class="axis-name">調べた</span>
          <span class="axis-desc">ローカルあるある・検証</span>
        </a>
      </div>

      <div class="hero-ctas">
        <a href="/submit" class="cta-primary">情報を投稿する ＋</a>
        <a href="/crowdfunding" class="cta-secondary">応援中を見る →</a>
      </div>

      <!-- Weather badge -->
      <div class="weather-badge" id="weather-badge" style="display:none">
        <span class="w-icon" id="w-icon">🌤</span>
        <div class="w-info">
          <span class="w-temp" id="w-temp">--°C</span>
          <span class="w-label">今日の函館</span>
        </div>
      </div>

    </div>

    <!-- Right: Mascot -->
    <div class="hero-right">
      <div class="poster-frame">
        <div class="poster-tape t1" aria-hidden="true"></div>
        <div class="poster-tape t2" aria-hidden="true"></div>
        <div class="poster-inner">
          <p class="poster-label">KATTENI HAKODATE</p>
          <img src="/images/kacchin-slope.png" alt="カッチン" class="mascot-img" />
          <p class="poster-caption">勝手に楽しくする仕掛け人</p>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom wave -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 56" preserveAspectRatio="none">
      <path d="M0,28 C360,56 720,0 1080,28 C1260,42 1380,14 1440,28 L1440,56 L0,56 Z" fill="#F5EDD8"/>
    </svg>
  </div>
</section>

<!-- Weather script -->
<script>
(async () => {
  try {
    const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=41.7686&longitude=140.7288&current=temperature_2m,weather_code&timezone=Asia/Tokyo');
    const d = await res.json();
    const temp = Math.round(d.current.temperature_2m);
    const code = d.current.weather_code;
    const icons = {0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',53:'🌦',55:'🌧',61:'🌧',63:'🌧',65:'🌧',71:'🌨',73:'🌨',75:'❄️',77:'❄️',80:'🌦',81:'🌧',82:'⛈',95:'⛈',96:'⛈',99:'⛈'};
    document.getElementById('w-icon').textContent = icons[code] ?? '🌤';
    document.getElementById('w-temp').textContent = `${temp}°C`;
    document.getElementById('weather-badge').style.display = 'flex';
  } catch(e) {}
})();
</script>

<style>
/* ── Hero ── */
.hero {
  position: relative; overflow: hidden;
  background: #9E3D26;
  padding: 96px 0 64px;
  min-height: 540px;
}

/* Brick pattern texture */
.hero-texture {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent, transparent 28px,
      rgba(0,0,0,0.07) 28px, rgba(0,0,0,0.07) 30px
    ),
    repeating-linear-gradient(
      90deg,
      transparent, transparent 56px,
      rgba(0,0,0,0.05) 56px, rgba(0,0,0,0.05) 58px
    );
  background-size: 58px 30px;
}

.hero-container {
  position: relative; z-index: 1;
  max-width: 1200px; margin: 0 auto;
  padding: 0 40px;
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 48px;
  align-items: center;
}

/* Stamp */
.hero-stamp-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.hero-stamp {
  background: #D4A02A; color: #2A2420;
  font-size: 11px; font-weight: 900; letter-spacing: 0.3em;
  padding: 5px 16px; transform: rotate(-1.5deg);
  font-family: 'Shippori Mincho', serif;
  border: 2px solid #2A2420;
  display: inline-block;
}
.hero-eye {
  font-size: 10.5px; letter-spacing: 0.2em;
  color: rgba(245,237,216,0.65); font-weight: 600;
}

/* Headline */
.hero-headline { margin-bottom: 20px; }
.hl-small {
  display: block;
  font-family: 'Shippori Mincho', serif;
  font-size: 16px; font-weight: 600;
  color: rgba(245,237,216,0.72);
  letter-spacing: 0.1em; margin-bottom: 8px;
}
.hl-large {
  display: block;
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 900;
  color: #F5EDD8;
  letter-spacing: 0.04em;
  line-height: 1.3;
}

.hero-sub {
  font-size: 14px; color: rgba(245,237,216,0.75);
  line-height: 2; margin-bottom: 28px;
}
.hero-sub strong { color: #F5EDD8; font-weight: 700; }

/* 3軸バッジ */
.hero-axes { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
.axis-badge {
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 2px; padding: 10px 14px;
  background: rgba(245,237,216,0.12);
  border: 1.5px solid rgba(245,237,216,0.25);
  border-radius: 4px; text-decoration: none;
  transition: background 0.2s, border-color 0.2s;
  min-width: 110px;
}
.axis-badge:hover { background: rgba(245,237,216,0.22); border-color: rgba(245,237,216,0.5); }
.axis-icon { font-size: 18px; }
.axis-name {
  font-family: 'Shippori Mincho', serif;
  font-size: 13px; font-weight: 800;
  color: #F5EDD8; letter-spacing: 0.04em;
}
.axis-desc { font-size: 10px; color: rgba(245,237,216,0.55); letter-spacing: 0.02em; }

/* CTAs */
.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
.cta-primary {
  padding: 13px 24px;
  background: #D4A02A; color: #2A2420;
  font-family: 'Shippori Mincho', serif;
  font-size: 13.5px; font-weight: 800;
  border-radius: 3px; border: 2px solid #2A2420;
  letter-spacing: 0.06em;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 3px 3px 0 #2A2420;
}
.cta-primary:hover { background: #E0AD30; transform: translate(-1px, -1px); box-shadow: 4px 4px 0 #2A2420; }
.cta-secondary {
  padding: 13px 20px;
  border: 2px solid rgba(245,237,216,0.4);
  color: rgba(245,237,216,0.85);
  font-family: 'Shippori Mincho', serif;
  font-size: 13px; font-weight: 700;
  border-radius: 3px; letter-spacing: 0.06em;
  transition: border-color 0.2s, color 0.2s;
}
.cta-secondary:hover { border-color: #F5EDD8; color: #F5EDD8; }

/* Weather */
.weather-badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(42,36,32,0.4);
  border: 1px solid rgba(245,237,216,0.2);
  border-radius: 4px; padding: 8px 16px;
}
.w-icon { font-size: 20px; }
.w-temp { display: block; font-size: 18px; font-weight: 800; color: #F5EDD8; line-height: 1; }
.w-label { display: block; font-size: 9px; color: rgba(245,237,216,0.5); letter-spacing: 0.15em; margin-top: 2px; }

/* Poster (right) */
.hero-right { display: flex; justify-content: center; align-items: center; }
.poster-frame {
  position: relative;
  background: #F5EDD8;
  border: 3px solid #2A2420;
  padding: 20px;
  transform: rotate(2deg);
  box-shadow: 6px 6px 0 rgba(42,36,32,0.5);
  width: 220px;
}
.poster-tape {
  position: absolute;
  width: 48px; height: 16px;
  background: rgba(212,160,42,0.7);
  border: 1px solid rgba(42,36,32,0.2);
}
.t1 { top: -8px; left: 24px; transform: rotate(-2deg); }
.t2 { top: -8px; right: 24px; transform: rotate(2deg); }
.poster-inner { text-align: center; }
.poster-label {
  font-size: 8px; letter-spacing: 0.3em;
  color: #8A7A6A; margin-bottom: 12px;
  text-transform: uppercase; font-weight: 700;
}
.mascot-img { width: 140px; height: 140px; object-fit: contain; }
.poster-caption {
  font-family: 'Shippori Mincho', serif;
  font-size: 11px; font-weight: 700;
  color: #9E3D26; margin-top: 8px;
  letter-spacing: 0.04em;
}

/* Wave */
.hero-wave { line-height: 0; margin-bottom: -1px; }
.hero-wave svg { display: block; width: 100%; height: 56px; }

/* Responsive */
@media (max-width: 768px) {
  .hero { padding: 88px 0 52px; min-height: auto; }
  .hero-container {
    grid-template-columns: 1fr;
    padding: 0 20px;
    gap: 32px;
  }
  .hero-right { display: none; }
  .hl-large { font-size: 32px; }
  .hero-axes { gap: 8px; }
  .axis-badge { min-width: calc(50% - 4px); flex: 1; }
}
@media (max-width: 480px) {
  .axis-badge { min-width: 100%; }
  .hero-ctas { flex-direction: column; }
  .cta-primary, .cta-secondary { text-align: center; }
}
</style>
