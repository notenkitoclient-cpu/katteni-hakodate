---
---
<section class="hero">
  <div class="hero-sky" aria-hidden="true"></div>
  <div class="hero-sun" aria-hidden="true"></div>
  <div class="hero-clouds" aria-hidden="true">
    <div class="cloud c1"></div>
    <div class="cloud c2"></div>
  </div>

  <div class="hero-grid">

    <!-- Left -->
    <div class="hero-left">

      <p class="eyebrow">
        <span class="ey-icon">⚓</span>
        道南エリア 勝手に応援メディア
      </p>

      <h1 class="headline">
        <span class="hl-sm">誰に頼まれたわけでもないけど、</span>
        <span class="hl-lg">函館を勝手に<br>楽しくする。</span>
      </h1>

      <p class="hero-body">
        函館・北斗・七飯、道南エリアの<br>
        クラファン・イベント・お店・人を<br>
        勝手にリサーチして勝手に応援します。
      </p>

      <div class="hero-ctas">
        <a href="/crowdfunding" class="btn-fill">クラファン応援団へ</a>
        <a href="/articles" class="btn-line">記事を読む</a>
      </div>

      <div class="hero-teams">
        <div class="team-badge" style="background:#fff3e0; color:#e8734a;">🗞 記事団</div>
        <div class="team-badge" style="background:#fff3e0; color:#e8734a;">💰 クラファン応援団</div>
        <div class="team-badge" style="background:#e4f5f4; color:#0d8a87;">🎉 イベント情報団</div>
      </div>

      <!-- Weather badge -->
      <div class="weather-badge" id="weather-badge" style="display:none">
        <span class="w-icon" id="w-icon">🌤</span>
        <div class="w-info">
          <span class="w-temp" id="w-temp">--°C</span>
          <span class="w-label">函館の今の天気</span>
        </div>
        <span class="w-sep"></span>
        <span class="w-city">函館市</span>
      </div>

    </div>

    <!-- Right: Mascot scene -->
    <div class="hero-right">
      <div class="scene-glow" aria-hidden="true"></div>
      <div class="scene-ring r1" aria-hidden="true"></div>
      <div class="scene-ring r2" aria-hidden="true"></div>

      <div class="mascot-wrap">
        <img src="/images/kacchin-slope.png" alt="カッチン" class="mascot" />
      </div>

      <div class="float-badge fb1" aria-hidden="true"><span>🌊</span>函館湾</div>
      <div class="float-badge fb2" aria-hidden="true"><span>💰</span>北斗市</div>
    </div>

  </div>

  <!-- Weather script -->
  <script>
  (async () => {
    try {
      const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=41.7686&longitude=140.7288&current=temperature_2m,weather_code&timezone=Asia/Tokyo');
      const d = await res.json();
      const temp = Math.round(d.current.temperature_2m);
      const code = d.current.weather_code;
      const icons = {0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',53:'🌦',55:'🌧',61:'🌧',63:'🌧',65:'🌧',71:'🌨',73:'🌨',75:'❄️',77:'❄️',80:'🌦',81:'🌧',82:'⛈',95:'⛈',96:'⛈',99:'⛈'};
      document.getElementById('w-icon').textContent = icons[code] ?? '🌤';
      document.getElementById('w-temp').textContent = `${temp}°C`;
      document.getElementById('weather-badge').style.display = 'flex';
    } catch(e) {}
  })();
  </script>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-pill"><div class="scroll-nub"></div></div>
    <span>SCROLL</span>
  </div>

  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 64" preserveAspectRatio="none">
      <path d="M0,32 C360,64 720,0 1080,32 C1260,48 1380,24 1440,32 L1440,64 L0,64 Z" fill="#faf7f0"/>
    </svg>
  </div>
</section>

<style>
.hero {
  position: relative;
  width: 100%;
  min-height: 88vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.hero-sky {
  position: absolute; inset: 0;
  background: linear-gradient(168deg,#bdddf0 0%,#cce7f4 8%,#d8eef9 16%,#e4f4fb 28%,#eef8fd 40%,#f5fbff 54%,#fafeff 66%,#ffffff 76%,#fdfaf7 88%,#faf7f0 100%);
}
.hero-sun {
  position: absolute; top: -120px; right: 6%;
  width: 600px; height: 600px; border-radius: 50%;
  background: radial-gradient(circle,rgba(255,248,215,0.55) 0%,rgba(255,243,200,0.3) 30%,rgba(255,240,195,0.1) 55%,transparent 70%);
  pointer-events: none;
}
.hero-clouds { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.cloud { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.55); filter: blur(40px); }
.c1 { width: 400px; height: 160px; top: 6%; left: 12%; }
.c2 { width: 300px; height: 120px; top: 12%; right: 22%; }

.hero-grid {
  position: relative; z-index: 2; flex: 1;
  display: grid; grid-template-columns: 5fr 7fr;
  align-items: center;
  max-width: 1200px; width: 100%;
  margin: 0 auto; padding: 88px 40px 48px; gap: 0;
}

.hero-left { display: flex; flex-direction: column; padding-right: 40px; }

.eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: 0.3em; color: #0d8a87;
  font-weight: 700; text-transform: uppercase; margin-bottom: 20px;
  opacity: 0; animation: fadeUp 0.55s 0.05s ease forwards;
}
.ey-icon { font-size: 13px; letter-spacing: 0; }

.headline {
  display: flex; flex-direction: column;
  margin-bottom: 20px;
  opacity: 0; animation: fadeUp 0.55s 0.18s ease forwards;
}
.hl-sm {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(13px, 1.6vw, 20px); font-weight: 600;
  color: #7aa0b8; letter-spacing: 0.06em; line-height: 1.6; margin-bottom: 4px;
}
.hl-lg {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(30px, 4.5vw, 58px); font-weight: 800;
  color: #0d2d52; letter-spacing: 0.04em; line-height: 1.2;
}

.hero-body {
  font-size: clamp(13px, 1.1vw, 14.5px); color: #5a7080;
  line-height: 2; margin-bottom: 28px;
  opacity: 0; animation: fadeUp 0.55s 0.3s ease forwards;
}

.hero-ctas {
  display: flex; gap: 12px; flex-wrap: wrap;
  margin-bottom: 24px;
  opacity: 0; animation: fadeUp 0.55s 0.42s ease forwards;
}
.btn-fill {
  padding: 13px 28px; background: #e8734a; color: #fff;
  font-size: 13px; font-weight: 700; border-radius: 6px;
  letter-spacing: 0.06em; transition: all 0.22s;
  box-shadow: 0 4px 18px rgba(232,115,74,0.32);
}
.btn-fill:hover { background: #f0845a; transform: translateY(-2px); box-shadow: 0 8px 26px rgba(232,115,74,0.4); }
.btn-line {
  padding: 13px 28px; border: 1.5px solid #b8d2de; color: #3a5868;
  font-size: 13px; font-weight: 700; border-radius: 6px;
  letter-spacing: 0.06em; transition: all 0.22s;
}
.btn-line:hover { border-color: #0d8a87; color: #0d8a87; background: rgba(13,138,135,0.05); }

.hero-teams {
  display: flex; gap: 8px; flex-wrap: wrap;
  margin-bottom: 20px;
  opacity: 0; animation: fadeUp 0.55s 0.5s ease forwards;
}
.team-badge {
  font-size: 11px; font-weight: 700; padding: 5px 12px;
  border-radius: 20px; letter-spacing: 0.04em;
}

/* Weather */
.weather-badge {
  display: flex; align-items: center; gap: 10px;
  margin-top: 4px;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(13,138,135,0.18); border-radius: 30px;
  padding: 8px 16px; width: fit-content;
  box-shadow: 0 2px 12px rgba(0,60,90,0.08);
}
.w-icon { font-size: 22px; line-height: 1; }
.w-info { display: flex; flex-direction: column; gap: 1px; }
.w-temp { font-size: 16px; font-weight: 800; color: #0d2d52; line-height: 1; }
.w-label { font-size: 9px; color: #9ab8c8; letter-spacing: 0.1em; }
.w-sep { width: 1px; height: 24px; background: #d0e8f0; margin: 0 4px; }
.w-city { font-size: 11px; font-weight: 600; color: #4a7080; }

/* Right */
.hero-right {
  position: relative; display: flex;
  align-items: center; justify-content: center;
  min-height: 520px;
}
.scene-glow {
  position: absolute; width: 460px; height: 460px; border-radius: 50%;
  background: radial-gradient(circle,rgba(13,138,135,0.1) 0%,rgba(200,235,245,0.2) 45%,transparent 72%);
}
.scene-ring { position: absolute; border-radius: 50%; }
.r1 { width: 500px; height: 500px; border: 1px solid rgba(13,138,135,0.12); animation: spin1 22s linear infinite; }
.r2 { width: 600px; height: 600px; border: 1px solid rgba(13,138,135,0.06); animation: spin1 35s linear infinite reverse; }
@keyframes spin1 { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.mascot-wrap {
  position: relative; z-index: 2;
  opacity: 0; animation: mascotReveal 0.9s 0.55s cubic-bezier(0.16,1,0.3,1) forwards;
}
.mascot {
  width: clamp(280px, 34vw, 460px);
  filter: drop-shadow(0 24px 56px rgba(0,60,90,0.15));
  animation: float 6s ease-in-out infinite;
}
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
@keyframes mascotReveal { from { opacity:0; transform:translateY(24px) scale(0.97); } to { opacity:1; transform:translateY(0) scale(1); } }

.float-badge {
  position: absolute; display: flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(13,138,135,0.15); border-radius: 24px;
  padding: 7px 14px; font-size: 11px; font-weight: 600; color: #0d2d52;
  box-shadow: 0 4px 16px rgba(0,60,90,0.1); z-index: 3; opacity: 0;
}
.float-badge span { font-size: 14px; }
.fb1 { top: 18%; left: 2%; animation: badgeFloat 0.5s 1.1s ease forwards, badgePulse1 4s 1.6s ease-in-out infinite; }
.fb2 { bottom: 22%; right: 0%; animation: badgeFloat 0.5s 1.3s ease forwards, badgePulse2 4.5s 1.8s ease-in-out infinite; }
@keyframes badgeFloat { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
@keyframes badgePulse1 { 0%,100% { transform:translateY(0px); } 50% { transform:translateY(-5px); } }
@keyframes badgePulse2 { 0%,100% { transform:translateY(0px); } 50% { transform:translateY(-6px); } }

/* Scroll */
.hero-scroll {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  gap: 7px; padding-bottom: 40px;
}
.hero-scroll span { font-size: 8.5px; letter-spacing: 0.3em; color: #a8c4d4; }
.scroll-pill {
  width: 20px; height: 32px; border-radius: 10px;
  border: 1.5px solid rgba(13,138,135,0.3);
  display: flex; align-items: flex-start; justify-content: center; padding-top: 5px;
}
.scroll-nub {
  width: 4px; height: 8px; border-radius: 2px; background: #0d8a87;
  animation: scrollNub 2.2s ease-in-out infinite;
}
@keyframes scrollNub { 0% { transform:translateY(0); opacity:1; } 60% { transform:translateY(10px); opacity:0; } 61% { transform:translateY(0); opacity:0; } 100% { transform:translateY(0); opacity:1; } }

.hero-wave { position: absolute; bottom: -1px; left: 0; right: 0; z-index: 3; line-height: 0; }
.hero-wave svg { width: 100%; display: block; }

@keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }

/* Responsive */
@media (max-width: 768px) {
  .hero { min-height: auto; }
  .hero-grid { grid-template-columns: 1fr; padding: 80px 20px 24px; text-align: center; }
  .hero-left { padding-right: 0; align-items: center; }
  .hero-right { min-height: 260px; }
  .r1 { width: 260px; height: 260px; }
  .r2 { width: 320px; height: 320px; }
  .mascot { width: clamp(180px, 55vw, 260px); }
  .fb1, .fb2 { display: none; }
  .hero-ctas, .hero-teams { justify-content: center; }
  .weather-badge { align-self: center; }
}
@media (max-width: 480px) {
  .hl-lg { font-size: 28px; }
  .hero-right { min-height: 200px; }
  .mascot { width: 160px; }
}
</style>
