---
---
<!-- ======================================================
  HERO — 全画面 (studyinshizuoka.jp 参照)
  背景: 空〜海のグラデーション (写真の代替)
  中央: 大きいキャッチコピー + CTA
====================================================== -->
<section style="
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 560px;
  overflow: hidden;
  display: flex; flex-direction: column;
">
  <!-- 空〜海グラデーション背景 -->
  <div style="
    position: absolute; inset: 0;
    background: linear-gradient(
      180deg,
      #b8d8e8 0%,
      #7ab8d4 25%,
      #3a8aaa 50%,
      #1a5a7a 75%,
      #0d3a58 100%
    );
  "></div>

  <!-- 白い光のオーバーレイ（上部） -->
  <div style="
    position: absolute; top: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(to bottom, rgba(255,255,255,0.25), transparent);
    pointer-events: none;
  "></div>

  <!-- 波紋デコレーション -->
  <div style="
    position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%);
    width: 800px; height: 800px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    pointer-events: none;
  "></div>
  <div style="
    position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
    width: 500px; height: 500px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    pointer-events: none;
  "></div>

  <!-- カッチン（右下に配置） -->
  <img
    src="/images/kacchin-nightview.png"
    alt="カッチン"
    style="
      position: absolute;
      right: 6%; bottom: 80px;
      width: clamp(200px, 22vw, 320px);
      filter: drop-shadow(0 20px 48px rgba(0,0,0,0.25));
      animation: float 5s ease-in-out infinite;
      z-index: 2;
    "
  />

  <!-- メインコンテンツ（中央） -->
  <div style="
    position: relative; z-index: 3;
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 0 24px;
  ">
    <p style="
      font-size: 11px; letter-spacing: 0.45em;
      color: rgba(255,255,255,0.75); font-weight: 700;
      text-transform: uppercase; margin-bottom: 24px;
    ">⚓ &nbsp; Hakodate Community Media</p>

    <h1 style="
      font-family: 'Shippori Mincho', serif;
      font-size: clamp(36px, 6vw, 72px);
      font-weight: 800; color: #ffffff;
      line-height: 1.2; letter-spacing: 0.03em;
      margin-bottom: 24px;
      text-shadow: 0 2px 20px rgba(0,0,0,0.2);
    ">
      知らなかった、<br>ハコダテがある。
    </h1>

    <p style="
      font-size: clamp(14px, 1.6vw, 17px);
      color: rgba(255,255,255,0.82);
      line-height: 1.85; margin-bottom: 40px;
      max-width: 520px;
    ">
      港町・函館に住む人、訪れる人、移住を考える人へ。<br>
      地元目線でかってに函館の魅力を発信するコミュニティメディア。
    </p>

    <div style="display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;">
      <a href="/articles" style="
        padding: 14px 36px;
        background: white; color: #0d3a58;
        font-size: 14px; font-weight: 700; border-radius: 4px;
        letter-spacing: 0.06em; transition: all 0.2s;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      "
      onmouseover="this.style.background='#e8f4f8'; this.style.boxShadow='0 6px 28px rgba(0,0,0,0.2)'"
      onmouseout="this.style.background='white'; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.15)'"
      >記事を読む</a>

      <a href="/about" style="
        padding: 14px 36px;
        border: 2px solid rgba(255,255,255,0.6); color: white;
        font-size: 14px; font-weight: 700; border-radius: 4px;
        letter-spacing: 0.06em; transition: all 0.2s;
      "
      onmouseover="this.style.background='rgba(255,255,255,0.12)'; this.style.borderColor='white'"
      onmouseout="this.style.background='transparent'; this.style.borderColor='rgba(255,255,255,0.6)'"
      >サイトについて</a>
    </div>
  </div>

  <!-- 下部のスクロール促進 -->
  <div style="position: relative; z-index: 3; text-align: center; padding-bottom: 28px;">
    <p style="font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.2em;">SCROLL ↓</p>
  </div>

  <!-- Wave to white -->
  <div style="position: absolute; bottom: -1px; left: 0; right: 0; z-index: 4; line-height: 0;">
    <svg viewBox="0 0 1440 64" style="width:100%; display:block;" preserveAspectRatio="none">
      <path d="M0,32 C240,64 480,0 720,32 C960,64 1200,0 1440,32 L1440,64 L0,64 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<style>
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-16px); }
  }
</style>
