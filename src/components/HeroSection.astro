---
---
<section class="hero">

  <!-- Sky gradient background -->
  <div class="hero-sky" aria-hidden="true"></div>

  <!-- Warm sun glow (upper right) -->
  <div class="hero-sun" aria-hidden="true"></div>

  <!-- Subtle cloud shapes -->
  <div class="hero-clouds" aria-hidden="true">
    <div class="cloud c1"></div>
    <div class="cloud c2"></div>
  </div>

  <!-- ── Grid layout ── -->
  <div class="hero-grid">

    <!-- Left: Editorial text -->
    <div class="hero-left">

      <p class="eyebrow">
        <span class="ey-icon">⚓</span>
        Hakodate Community Media
      </p>

      <h1 class="headline">
        <span class="hl-sm">知らなかった、</span>
        <span class="hl-lg">ハコダテがある。</span>
      </h1>

      <p class="hero-body">
        港町・函館に住む人、訪れる人、<br>
        移住を考える人へ。<br>
        地元目線でかってに函館の魅力を<br>
        発信するコミュニティメディア。
      </p>

      <div class="hero-ctas">
        <a href="/articles" class="btn-fill">記事を読む</a>
        <a href="/about" class="btn-line">サイトについて</a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <b>6</b><span>カテゴリ</span>
        </div>
        <div class="stat-dot"></div>
        <div class="stat">
          <b>地元</b><span>発信</span>
        </div>
        <div class="stat-dot"></div>
        <div class="stat">
          <b>毎週</b><span>更新</span>
        </div>
      </div>
    </div>

    <!-- Right: Mascot scene -->
    <div class="hero-right">
      <div class="scene-glow" aria-hidden="true"></div>
      <div class="scene-ring r1" aria-hidden="true"></div>
      <div class="scene-ring r2" aria-hidden="true"></div>

      <div class="mascot-wrap">
        <img
          src="/images/kacchin-slope.png"
          alt="函館の坂道にいるカッチン"
          class="mascot"
        />
      </div>

      <!-- Floating badge -->
      <div class="float-badge fb1" aria-hidden="true">
        <span>🌊</span>函館湾
      </div>
      <div class="float-badge fb2" aria-hidden="true">
        <span>⛪</span>元町
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-pill">
      <div class="scroll-nub"></div>
    </div>
    <span>SCROLL</span>
  </div>

  <!-- Wave to page -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 64" preserveAspectRatio="none">
      <path d="M0,32 C360,64 720,0 1080,32 C1260,48 1380,24 1440,32 L1440,64 L0,64 Z" fill="#faf7f0"/>
    </svg>
  </div>

</section>

<style>
/* ──── Base ──── */
.hero {
  position: relative;
  width: 100%;
  min-height: 88vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ──── Background ──── */
.hero-sky {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    168deg,
    #bdddf0 0%,
    #cce7f4 8%,
    #d8eef9 16%,
    #e4f4fb 28%,
    #eef8fd 40%,
    #f5fbff 54%,
    #fafeff 66%,
    #ffffff 76%,
    #fdfaf7 88%,
    #faf7f0 100%
  );
}

.hero-sun {
  position: absolute;
  top: -120px;
  right: 6%;
  width: 600px;
  height: 600px;
  background: radial-gradient(
    circle,
    rgba(255, 248, 215, 0.55) 0%,
    rgba(255, 243, 200, 0.3)  30%,
    rgba(255, 240, 195, 0.1)  55%,
    transparent 70%
  );
  pointer-events: none;
}

.hero-clouds { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.cloud {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.55);
  filter: blur(40px);
}
.c1 { width: 400px; height: 160px; top: 6%; left: 12%; }
.c2 { width: 300px; height: 120px; top: 12%; right: 22%; }

/* ──── Grid ──── */
.hero-grid {
  position: relative;
  z-index: 2;
  flex: 1;
  display: grid;
  grid-template-columns: 5fr 7fr;
  align-items: center;
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: 88px 40px 48px;
  gap: 0;
}

/* ──── Left text ──── */
.hero-left {
  display: flex;
  flex-direction: column;
  padding-right: 40px;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 10px;
  letter-spacing: 0.36em;
  color: #0d8a87;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 22px;
  opacity: 0;
  animation: fadeUp 0.55s 0.05s ease forwards;
}
.ey-icon { font-size: 13px; letter-spacing: 0; }

.headline {
  display: flex;
  flex-direction: column;
  margin-bottom: 22px;
  opacity: 0;
  animation: fadeUp 0.55s 0.18s ease forwards;
}
.hl-sm {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(18px, 2.5vw, 32px);
  font-weight: 700;
  color: #7aa0b8;
  letter-spacing: 0.08em;
  line-height: 1.5;
  margin-bottom: 2px;
}
.hl-lg {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(32px, 4.8vw, 62px);
  font-weight: 800;
  color: #0d2d52;
  letter-spacing: 0.04em;
  line-height: 1.2;
}

.hero-body {
  font-size: clamp(13px, 1.2vw, 15px);
  color: #5a7080;
  line-height: 2;
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeUp 0.55s 0.3s ease forwards;
}

.hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 36px;
  opacity: 0;
  animation: fadeUp 0.55s 0.42s ease forwards;
}

.btn-fill {
  padding: 13px 32px;
  background: #0d8a87;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  border-radius: 6px;
  letter-spacing: 0.07em;
  transition: all 0.22s;
  box-shadow: 0 4px 18px rgba(13, 138, 135, 0.3);
}
.btn-fill:hover {
  background: #0fa09c;
  transform: translateY(-2px);
  box-shadow: 0 8px 26px rgba(13, 138, 135, 0.36);
}

.btn-line {
  padding: 13px 32px;
  border: 1.5px solid #b8d2de;
  color: #3a5868;
  font-size: 13px;
  font-weight: 700;
  border-radius: 6px;
  letter-spacing: 0.07em;
  transition: all 0.22s;
}
.btn-line:hover {
  border-color: #0d8a87;
  color: #0d8a87;
  background: rgba(13, 138, 135, 0.05);
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 16px;
  opacity: 0;
  animation: fadeUp 0.55s 0.54s ease forwards;
}
.stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.stat b {
  font-family: 'Shippori Mincho', serif;
  font-size: 19px;
  font-weight: 800;
  color: #0d2d52;
  line-height: 1;
}
.stat span {
  font-size: 9px;
  color: #9ab8c8;
  letter-spacing: 0.12em;
}
.stat-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #c8dce8;
}

/* ──── Right visual ──── */
.hero-right {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 520px;
}

.scene-glow {
  position: absolute;
  width: 460px;
  height: 460px;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(13, 138, 135, 0.1) 0%,
    rgba(200, 235, 245, 0.2) 45%,
    transparent 72%
  );
}

.scene-ring {
  position: absolute;
  border-radius: 50%;
}
.r1 {
  width: 500px;
  height: 500px;
  border: 1px solid rgba(13, 138, 135, 0.12);
  animation: spin1 22s linear infinite;
}
.r2 {
  width: 600px;
  height: 600px;
  border: 1px solid rgba(13, 138, 135, 0.06);
  animation: spin1 35s linear infinite reverse;
}
@keyframes spin1 {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.mascot-wrap {
  position: relative;
  z-index: 2;
  opacity: 0;
  animation: mascotReveal 0.9s 0.55s cubic-bezier(0.16,1,0.3,1) forwards;
}
.mascot {
  width: clamp(280px, 34vw, 460px);
  filter: drop-shadow(0 24px 56px rgba(0, 60, 90, 0.15));
  animation: float 6s ease-in-out infinite;
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-16px); }
}
@keyframes mascotReveal {
  from { opacity: 0; transform: translateY(24px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Floating location badges */
.float-badge {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 5px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(13, 138, 135, 0.15);
  border-radius: 24px;
  padding: 7px 14px;
  font-size: 11px;
  font-weight: 600;
  color: #0d2d52;
  box-shadow: 0 4px 16px rgba(0, 60, 90, 0.1);
  z-index: 3;
  opacity: 0;
}
.float-badge span { font-size: 14px; }
.fb1 {
  top: 18%;
  left: 2%;
  animation: badgeFloat 0.5s 1.1s ease forwards, badgePulse1 4s 1.6s ease-in-out infinite;
}
.fb2 {
  bottom: 22%;
  right: 0%;
  animation: badgeFloat 0.5s 1.3s ease forwards, badgePulse2 4.5s 1.8s ease-in-out infinite;
}
@keyframes badgeFloat {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes badgePulse1 {
  0%,100% { transform: translateY(0px); }
  50%     { transform: translateY(-5px); }
}
@keyframes badgePulse2 {
  0%,100% { transform: translateY(0px); }
  50%     { transform: translateY(-6px); }
}

/* ──── Scroll indicator ──── */
.hero-scroll {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  padding-bottom: 40px;
}
.hero-scroll span {
  font-size: 8.5px;
  letter-spacing: 0.3em;
  color: #a8c4d4;
}
.scroll-pill {
  width: 20px;
  height: 32px;
  border-radius: 10px;
  border: 1.5px solid rgba(13, 138, 135, 0.3);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 5px;
}
.scroll-nub {
  width: 4px;
  height: 8px;
  border-radius: 2px;
  background: #0d8a87;
  animation: scrollNub 2.2s ease-in-out infinite;
}
@keyframes scrollNub {
  0%   { transform: translateY(0);   opacity: 1; }
  60%  { transform: translateY(10px); opacity: 0; }
  61%  { transform: translateY(0);   opacity: 0; }
  100% { transform: translateY(0);   opacity: 1; }
}

/* ──── Wave ──── */
.hero-wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  z-index: 3;
  line-height: 0;
}
.hero-wave svg { width: 100%; display: block; }

/* ──── Animation ──── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
