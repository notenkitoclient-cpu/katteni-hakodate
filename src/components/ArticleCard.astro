---
export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  author: string;
  slug: string;
  featured?: boolean;
  large?: boolean;
}
const { title, description, category, date, author, slug, featured = false, large = false } = Astro.props;

const categoryColors: Record<string, string> = {
  'グルメ': '#0d8a87',
  '観光': '#0d2d52',
  '暮らし': '#1a7fc0',
  'イベント': '#c05a3a',
  '人・ビジネス': '#5a3a7a',
  '特産品': '#1a6a5a',
};
const categoryEmoji: Record<string, string> = {
  'グルメ': '🍣',
  '観光': '⚓',
  '暮らし': '🏘️',
  'イベント': '🎆',
  '人・ビジネス': '👥',
  '特産品': '🦑',
};
const catColor = categoryColors[category] || '#0d8a87';
const catEmoji = categoryEmoji[category] || '📄';
---

<article
  style="background: white; border-radius: 12px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 2px 8px rgba(13,45,82,0.08);"
  onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 12px 28px rgba(13,45,82,0.15)'"
  onmouseout="this.style.transform=''; this.style.boxShadow='0 2px 8px rgba(13,45,82,0.08)'"
>
  <a href={`/articles/${slug}`} style="text-decoration: none; color: inherit; display: block;">
    <div style={`background: linear-gradient(135deg, ${catColor}18, ${catColor}35); aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; position: relative; border-bottom: 1px solid ${catColor}20;`}>
      <span style="font-size: 52px; opacity: 0.55;">{catEmoji}</span>
      {featured && (
        <div style="position: absolute; top: 10px; left: 10px; background: #c05a3a; color: white; font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 10px; letter-spacing: 1px;">PICK UP</div>
      )}
      <div style={`position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: ${catColor};`}></div>
    </div>
    <div style="padding: 16px;">
      <div style="margin-bottom: 8px;">
        <span style={`display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 10px; color: white; background: ${catColor};`}>{category}</span>
      </div>
      <h3 style={`font-size: ${large ? '17px' : '15px'}; font-weight: 700; line-height: 1.45; margin-bottom: 8px; color: #0d1b2a; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;`}>{title}</h3>
      <p style="font-size: 13px; color: #5a7a8a; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12px;">{description}</p>
      <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 10px; border-top: 1px solid #d8e4ed;">
        <span style="font-size: 12px; color: #4a7a9a; font-weight: 500;">{author}</span>
        <span style="font-size: 11px; color: #8aaabb;">{date}</span>
      </div>
    </div>
  </a>
</article>
