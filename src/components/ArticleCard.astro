---
export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  author: string;
  slug: string;
  featured?: boolean;
}
const { title, description, category, date, author, slug, featured = false } = Astro.props;

const categoryColor: Record<string, string> = {
  'グルメ':      '#0d8a87',
  '観光':        '#1a7fc0',
  '暮らし':      '#3a8fd4',
  'イベント':    '#c05a3a',
  '人・ビジネス':'#7a50b0',
  '特産品':      '#1a9a6a',
};
const categoryBg: Record<string, string> = {
  'グルメ':      '#e6f7f7',
  '観光':        '#e8f2fa',
  '暮らし':      '#eaf4fc',
  'イベント':    '#fdf2ee',
  '人・ビジネス':'#f4f0fa',
  '特産品':      '#ebf8f2',
};
const categoryImage: Record<string, string> = {
  'グルメ':      '/images/kacchin-gourmet.png',
  '観光':        '/images/kacchin-slope.png',
  '暮らし':      '/images/kacchin-tram.png',
  'イベント':    '/images/kacchin-goryokaku.png',
  '人・ビジネス':'/images/kacchin-nightview.png',
  '特産品':      '/images/kacchin-asaichi.png',
};
const catColor = categoryColor[category] || '#0d8a87';
const catBg    = categoryBg[category]    || '#e6f7f7';
const catImage = categoryImage[category] || '/images/kacchin-nightview.png';
---

<article class="card" style="
  background: #fff; border-radius: 10px; overflow: hidden;
  border: 1.5px solid #e8eef4;
  transition: box-shadow 0.25s, transform 0.25s;
  display: flex; flex-direction: column;
">
  <a href={`/articles/${slug}`} style="display: flex; flex-direction: column; flex: 1; text-decoration: none; color: inherit;">

    <!-- Thumbnail: light-colored background + カッチン as transparent PNG -->
    <div style={`aspect-ratio: 16/9; background: ${catBg}; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;`}
      class="card-thumb">
      <img
        src={catImage}
        alt={category}
        class="card-img"
        style="height: 82%; width: 100%; object-fit: contain; transition: transform 0.5s ease; filter: drop-shadow(0 8px 16px rgba(0,0,0,0.1));"
      />
      <!-- Badges -->
      <div style={`position: absolute; top: 12px; left: 12px; background: ${catColor}; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 3px; letter-spacing: 0.1em;`}>{category}</div>
      {featured && (
        <div style="position: absolute; top: 12px; right: 12px; background: #c05a3a; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 3px; letter-spacing: 0.1em;">PICK UP</div>
      )}
    </div>

    <!-- Body -->
    <div style="padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1;">
      <h3 style="
        font-family: 'Shippori Mincho', serif;
        font-size: 16px; font-weight: 700; line-height: 1.65;
        color: #0d2d52; margin-bottom: 10px;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
      ">{title}</h3>
      <p style="
        font-size: 13px; color: #6c7e8a; line-height: 1.7;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
        margin-bottom: 16px; flex: 1;
      ">{description}</p>
      <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid #eef2f6;">
        <span style="font-size: 12px; color: #4a6070; font-weight: 600;">{author}</span>
        <span style="font-size: 11px; color: #9ab0ba;">{date}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .card:hover {
    box-shadow: 0 12px 36px rgba(13, 45, 82, 0.10);
    transform: translateY(-4px);
  }
  .card:hover .card-img {
    transform: scale(1.06);
  }
</style>
