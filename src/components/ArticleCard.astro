---
export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  author: string;
  slug: string;
  featured?: boolean;
}
const { title, description, category, date, author, slug, featured = false } = Astro.props;

const categoryColors: Record<string, string> = {
  'グルメ': '#0d8a87',
  '観光': '#0d2d52',
  '暮らし': '#1a7fc0',
  'イベント': '#c05a3a',
  '人・ビジネス': '#5a3a7a',
  '特産品': '#1a6a5a',
};
const categoryBg: Record<string, string> = {
  'グルメ': 'linear-gradient(135deg, #0d4a4a, #0d8a87)',
  '観光': 'linear-gradient(135deg, #0d1a38, #0d2d52)',
  '暮らし': 'linear-gradient(135deg, #0a3a6a, #1a7fc0)',
  'イベント': 'linear-gradient(135deg, #7a2a18, #c05a3a)',
  '人・ビジネス': 'linear-gradient(135deg, #2a1a4a, #5a3a7a)',
  '特産品': 'linear-gradient(135deg, #0a3a2a, #1a6a5a)',
};
const categoryImage: Record<string, string> = {
  'グルメ': '/images/kacchin-gourmet.png',
  '観光': '/images/kacchin-slope.png',
  '暮らし': '/images/kacchin-tram.png',
  'イベント': '/images/kacchin-goryokaku.png',
  '人・ビジネス': '/images/kacchin-nightview.png',
  '特産品': '/images/kacchin-asaichi.png',
};
const catColor = categoryColors[category] || '#0d8a87';
const catBg = categoryBg[category] || 'linear-gradient(135deg, #0d2d52, #0d8a87)';
const catImage = categoryImage[category] || '/images/kacchin-nightview.png';
---

<article style="background: #fff; border-radius: 8px; overflow: hidden; border: 1px solid #e2e6ea; transition: box-shadow 0.3s ease, transform 0.3s ease;"
  onmouseover="this.style.boxShadow='0 12px 40px rgba(0,0,0,0.12)'; this.style.transform='translateY(-4px)'"
  onmouseout="this.style.boxShadow='none'; this.style.transform='translateY(0)'">
  <a href={`/articles/${slug}`} style="display: block; text-decoration: none; color: inherit;">

    <!-- Image area with zoom effect -->
    <div style="overflow: hidden; aspect-ratio: 3/2; position: relative;">
      <div style={`background: ${catBg}; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transition: transform 0.6s ease;`}
        onmouseover="this.style.transform='scale(1.06)'"
        onmouseout="this.style.transform='scale(1)'">
        <img
          src={catImage}
          alt={category}
          style="width: 70%; height: 100%; object-fit: contain; object-position: center; filter: drop-shadow(0 8px 20px rgba(0,0,0,0.25));"
        />
      </div>
      {featured && (
        <div style="position: absolute; top: 14px; left: 14px; background: #c05a3a; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 2px; letter-spacing: 0.12em;">PICK UP</div>
      )}
      <div style={`position: absolute; top: 14px; right: 14px; background: ${catColor}; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 2px; letter-spacing: 0.1em;`}>{category}</div>
    </div>

    <!-- Content -->
    <div style="padding: 20px 22px 22px;">
      <h3 style="font-family: 'Shippori Mincho', serif; font-size: 16px; font-weight: 700; line-height: 1.6; color: #0d0d0d; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{title}</h3>
      <p style="font-size: 13px; color: #6c757d; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 16px;">{description}</p>
      <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid #f0f2f4;">
        <span style="font-size: 12px; color: #3d4a52; font-weight: 500;">{author}</span>
        <span style="font-size: 11px; color: #aab4bc;">{date}</span>
      </div>
    </div>
  </a>
</article>
