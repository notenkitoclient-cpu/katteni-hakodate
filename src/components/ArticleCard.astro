---
export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  author: string;
  slug: string;
  featured?: boolean;
}
const { title, description, category, date, author, slug, featured = false } = Astro.props;

const categoryColors: Record<string, string> = {
  'グルメ':     '#0d8a87',
  '観光':       '#1a7fc0',
  '暮らし':     '#4a9ebe',
  'イベント':   '#c05a3a',
  '人・ビジネス':'#8a5abe',
  '特産品':     '#1a9a6a',
};
const categoryBg: Record<string, string> = {
  'グルメ':     'linear-gradient(135deg, #061e1e 0%, #0d5a5a 100%)',
  '観光':       'linear-gradient(135deg, #061226 0%, #0a2d52 100%)',
  '暮らし':     'linear-gradient(135deg, #061a2e 0%, #0d3d6a 100%)',
  'イベント':   'linear-gradient(135deg, #200a06 0%, #7a2a18 100%)',
  '人・ビジネス':'linear-gradient(135deg, #12062a 0%, #3a1a6a 100%)',
  '特産品':     'linear-gradient(135deg, #061a0e 0%, #0a4a2a 100%)',
};
const categoryImage: Record<string, string> = {
  'グルメ':     '/images/kacchin-gourmet.png',
  '観光':       '/images/kacchin-slope.png',
  '暮らし':     '/images/kacchin-tram.png',
  'イベント':   '/images/kacchin-goryokaku.png',
  '人・ビジネス':'/images/kacchin-nightview.png',
  '特産品':     '/images/kacchin-asaichi.png',
};
const catColor = categoryColors[category] || '#0d8a87';
const catBg    = categoryBg[category]    || 'linear-gradient(135deg, #061a2e, #0d5a7a)';
const catImage = categoryImage[category] || '/images/kacchin-nightview.png';
---

<article class="article-card" style="
  background: #fff; border-radius: 8px; overflow: hidden;
  border: 1px solid #e8edf2;
  transition: box-shadow 0.3s ease, transform 0.3s ease;
  display: flex; flex-direction: column;
">
  <a href={`/articles/${slug}`} style="display: flex; flex-direction: column; flex: 1; text-decoration: none; color: inherit;">

    <!-- Thumbnail -->
    <div style="overflow: hidden; aspect-ratio: 16/9; position: relative; flex-shrink: 0;">
      <div style={`${catBg}; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transition: transform 0.6s ease;`}
        class="card-thumb">
        <img
          src={catImage}
          alt={category}
          style="height: 80%; width: 100%; object-fit: contain; filter: drop-shadow(0 8px 20px rgba(0,0,0,0.4)); transition: transform 0.6s ease;"
          class="card-img"
        />
      </div>
      <!-- Category badge -->
      <div style={`position: absolute; top: 14px; left: 14px; background: ${catColor}; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 2px; letter-spacing: 0.12em;`}>{category}</div>
      {featured && (
        <div style="position: absolute; top: 14px; right: 14px; background: #c05a3a; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 2px; letter-spacing: 0.12em;">PICK UP</div>
      )}
    </div>

    <!-- Body -->
    <div style="padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1;">
      <h3 style="
        font-family: 'Shippori Mincho', serif;
        font-size: 16px; font-weight: 700; line-height: 1.65;
        color: #061a2e; margin-bottom: 10px;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
      ">{title}</h3>
      <p style="
        font-size: 13px; color: #6c757d; line-height: 1.7;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
        margin-bottom: 16px; flex: 1;
      ">{description}</p>
      <div style="
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 14px; border-top: 1px solid #f0f3f6;
      ">
        <span style="font-size: 12px; color: #3d4a52; font-weight: 600;">{author}</span>
        <span style="font-size: 11px; color: #aab4bc;">{date}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card:hover {
    box-shadow: 0 16px 48px rgba(6, 26, 46, 0.12);
    transform: translateY(-5px);
  }
  .article-card:hover .card-thumb {
    transform: scale(1.04);
  }
  .article-card:hover .card-img {
    transform: scale(1.08);
  }
</style>
