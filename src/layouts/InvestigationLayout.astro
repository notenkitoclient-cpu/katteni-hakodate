---
/**
 * 調査報告（実験記事）専用レイアウト
 * Scrollytelling対応。サイドバーにチャプターナビゲーションを表示。
 *
 * Frontmatterで使えるprops:
 *   title, description, category, date, author
 *   experimentNo  — 実験番号 (例: "001")
 *   finding       — 主要な発見・数値 (例: "127g")
 *   findingLabel  — 発見のラベル (例: "平均チキン重量")
 *   tags          — タグ配列
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  author: string;
  experimentNo?: string;
  finding?: string;
  findingLabel?: string;
  tags?: string[];
}

const {
  title, description, category, date, author,
  experimentNo, finding, findingLabel, tags,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />

  <!-- 調査ヒーロー -->
  <section class="inv-hero">
    <div class="inv-hero-grid" aria-hidden="true"></div>
    <div class="inv-hero-inner">
      <div class="inv-hero-meta">
        {experimentNo && <span class="inv-exp-badge">EXP — {experimentNo}</span>}
        <span class="inv-cat-badge">{category}</span>
      </div>

      <h1 class="inv-hero-title">{title}</h1>
      <p class="inv-hero-desc">{description}</p>

      {finding && (
        <div class="inv-hero-finding">
          <span class="inv-finding-num">{finding}</span>
          {findingLabel && <span class="inv-finding-label">{findingLabel}</span>}
        </div>
      )}

      <div class="inv-hero-byline">
        <span>{author}</span>
        <span class="inv-hero-sep">|</span>
        <span>{date}</span>
      </div>
    </div>
  </section>

  <!-- スクロールコンテンツ -->
  <div class="inv-body">

    <!-- サイドバー（スティッキー） -->
    <aside class="inv-sidebar" id="inv-sidebar">
      <div class="inv-sidebar-inner">
        <p class="inv-sidebar-label">この調査について</p>
        <nav class="inv-toc" id="inv-toc" aria-label="目次"></nav>
        <div class="inv-sidebar-meta">
          <div class="inv-meta-row">
            <span class="inv-meta-key">カテゴリ</span>
            <span class="inv-meta-val">{category}</span>
          </div>
          <div class="inv-meta-row">
            <span class="inv-meta-key">調査日</span>
            <span class="inv-meta-val">{date}</span>
          </div>
          <div class="inv-meta-row">
            <span class="inv-meta-key">調査者</span>
            <span class="inv-meta-val">{author}</span>
          </div>
          {experimentNo && (
            <div class="inv-meta-row">
              <span class="inv-meta-key">実験番号</span>
              <span class="inv-meta-val">#{experimentNo}</span>
            </div>
          )}
        </div>
        <a href="/articles" class="inv-back-link">← 調査報告一覧</a>
      </div>
    </aside>

    <!-- メインコンテンツ -->
    <main class="inv-main" id="inv-main">
      <div class="inv-content article-content">
        <slot />
      </div>

      {tags && tags.length > 0 && (
        <div class="inv-tags">
          {tags.map((tag: string) => (
            <span class="inv-tag">#{tag}</span>
          ))}
        </div>
      )}

      <div class="inv-nav-bottom">
        <a href="/articles" class="inv-nav-btn">← 調査報告一覧に戻る</a>
      </div>
    </main>

  </div>

  <Footer />
</BaseLayout>


<!-- ═══ SCROLLYTELLING ═══════════════════════════════════════ -->
<script>
  // 目次の自動生成
  function buildToc() {
    const main = document.getElementById('inv-main');
    const toc  = document.getElementById('inv-toc');
    if (!main || !toc) return;

    const headings = main.querySelectorAll('h2, h3');
    if (headings.length === 0) return;

    headings.forEach((h, i) => {
      if (!h.id) h.id = `section-${i}`;
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent || '';
      a.className = `toc-item toc-${h.tagName.toLowerCase()}`;
      a.dataset.target = h.id;
      toc.appendChild(a);
    });
  }

  // スクロール連動：アクティブセクションをハイライト
  function initScrollSpy() {
    const tocItems = document.querySelectorAll<HTMLAnchorElement>('.toc-item');
    if (tocItems.length === 0) return;

    const targets = Array.from(tocItems).map(a =>
      document.getElementById(a.dataset.target || '')
    ).filter(Boolean) as HTMLElement[];

    function onScroll() {
      let activeIdx = 0;
      const offset = 120;
      targets.forEach((el, i) => {
        if (el.getBoundingClientRect().top <= offset) activeIdx = i;
      });
      tocItems.forEach((a, i) => {
        a.classList.toggle('toc-active', i === activeIdx);
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // スクロール連動：data-scroll-reveal 要素のフェードイン
  function initReveal() {
    const els = document.querySelectorAll('[data-scroll-reveal]');
    if (!els.length) return;

    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });

    els.forEach(el => observer.observe(el));
  }

  // スティッキーサイドバーの高さ調整
  function adjustSidebar() {
    const sidebar = document.getElementById('inv-sidebar');
    if (!sidebar) return;
    sidebar.style.maxHeight = `${window.innerHeight - 80}px`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    buildToc();
    initScrollSpy();
    initReveal();
    adjustSidebar();
  });
  window.addEventListener('resize', adjustSidebar, { passive: true });
</script>


<style is:global>
/* ── data-scroll-reveal ── */
[data-scroll-reveal] {
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}
[data-scroll-reveal].revealed {
  opacity: 1; transform: translateY(0);
}

/* ── カスタムチャート・データ表示ブロック ── */
.inv-stat {
  display: flex; align-items: baseline; gap: 10px;
  margin: 32px 0;
}
.inv-stat-num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 900; color: #0d2d52; line-height: 1;
}
.inv-stat-unit {
  font-size: 14px; color: #6c757d; letter-spacing: 0.05em;
}

.inv-data-table {
  width: 100%; border-collapse: collapse;
  margin: 32px 0; font-size: 14px;
  border: 1px solid #d0d6de;
}
.inv-data-table th {
  background: #080e1a; color: #fff;
  padding: 12px 16px; text-align: left;
  font-size: 11px; letter-spacing: 0.15em; font-weight: 700;
}
.inv-data-table td {
  padding: 12px 16px; border-bottom: 1px solid #e4e8ed;
}
.inv-data-table tr:last-child td { border-bottom: none; }
.inv-data-table tr:nth-child(even) td { background: #f7f8fa; }

.inv-finding-callout {
  background: #080e1a;
  padding: 40px 36px; margin: 40px 0;
  display: flex; flex-direction: column; gap: 8px;
}
.inv-finding-callout .num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(48px, 7vw, 80px);
  font-weight: 900; color: #0d8a87; line-height: 1;
}
.inv-finding-callout .label {
  font-size: 13px; color: rgba(255,255,255,0.4); letter-spacing: 0.05em;
}
.inv-finding-callout .note {
  font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.8;
  margin-top: 8px;
}

.inv-bar-chart {
  margin: 32px 0; display: flex; flex-direction: column; gap: 8px;
}
.inv-bar-row {
  display: grid; grid-template-columns: 120px 1fr 50px;
  align-items: center; gap: 12px;
}
.inv-bar-label { font-size: 12px; color: #3d4a52; text-align: right; }
.inv-bar-track { background: #e4e8ed; height: 20px; position: relative; }
.inv-bar-fill {
  height: 100%; background: #0d2d52;
  width: var(--pct, 0%);
  transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
}
.inv-bar-fill--accent { background: #0d8a87; }
.inv-bar-val { font-size: 12px; font-weight: 700; color: #0d2d52; }

/* TOC styling */
.toc-item {
  display: block; padding: 6px 0;
  font-size: 12px; color: #8a9099;
  border-left: 2px solid transparent;
  padding-left: 10px; margin-left: -12px;
  text-decoration: none;
  transition: color 0.2s, border-color 0.2s;
  line-height: 1.5;
}
.toc-item:hover { color: #0d2d52; }
.toc-item.toc-active {
  color: #0d8a87; border-color: #0d8a87; font-weight: 700;
}
.toc-h3 { padding-left: 22px; font-size: 11px; }

/* Bar chart animation trigger */
.inv-bar-fill { width: 0; }
.revealed .inv-bar-fill { width: var(--pct, 0%); }
</style>

<style>
/* ── Hero ── */
.inv-hero {
  position: relative;
  background: #080e1a;
  padding: 130px 0 72px;
  overflow: hidden;
}
.inv-hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(13,45,82,0.18) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13,45,82,0.18) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}
.inv-hero-inner {
  position: relative;
  max-width: 1200px; margin: 0 auto; padding: 0 48px;
}
.inv-hero-meta {
  display: flex; align-items: center; gap: 10px; margin-bottom: 24px;
}
.inv-exp-badge {
  font-size: 9px; letter-spacing: 0.3em; font-weight: 700;
  color: #0d8a87; border: 1px solid rgba(13,138,135,0.4);
  padding: 4px 10px;
}
.inv-cat-badge {
  font-size: 9px; letter-spacing: 0.15em; font-weight: 700;
  color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.12);
  padding: 4px 10px;
}
.inv-hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(28px, 4.5vw, 52px); font-weight: 800;
  color: #ffffff; line-height: 1.35; letter-spacing: 0.02em;
  margin-bottom: 16px; max-width: 840px;
}
.inv-hero-desc {
  font-size: 15px; color: rgba(255,255,255,0.45);
  line-height: 1.9; max-width: 640px; margin-bottom: 32px;
}
.inv-hero-finding {
  display: flex; align-items: baseline; gap: 12px;
  margin-bottom: 32px;
}
.inv-finding-num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(48px, 6vw, 80px); font-weight: 900;
  color: #0d8a87; line-height: 1;
}
.inv-finding-label {
  font-size: 13px; color: rgba(255,255,255,0.35); letter-spacing: 0.05em;
}
.inv-hero-byline {
  font-size: 12px; color: rgba(255,255,255,0.3);
  display: flex; align-items: center; gap: 10px;
  letter-spacing: 0.05em;
}
.inv-hero-sep { opacity: 0.3; }

/* ── Body layout ── */
.inv-body {
  display: grid;
  grid-template-columns: 240px 1fr;
  max-width: 1200px; margin: 0 auto;
  padding: 0 48px;
  gap: 64px;
  align-items: start;
}

/* ── Sidebar ── */
.inv-sidebar {
  position: sticky; top: 80px;
  overflow-y: auto;
  padding: 40px 0;
}
.inv-sidebar-inner {
  display: flex; flex-direction: column; gap: 24px;
}
.inv-sidebar-label {
  font-size: 9px; letter-spacing: 0.35em; font-weight: 700;
  color: #0d8a87; text-transform: uppercase;
}
.inv-toc { display: flex; flex-direction: column; }
.inv-sidebar-meta {
  border-top: 1px solid #e4e8ed; padding-top: 20px;
  display: flex; flex-direction: column; gap: 10px;
}
.inv-meta-row { display: flex; justify-content: space-between; gap: 8px; }
.inv-meta-key { font-size: 10px; color: #a0a8b0; letter-spacing: 0.05em; }
.inv-meta-val { font-size: 11px; color: #3d4a52; font-weight: 600; text-align: right; }
.inv-back-link {
  font-size: 11px; color: #0d8a87; font-weight: 700;
  border-bottom: 1px solid currentColor; padding-bottom: 2px;
  align-self: flex-start; transition: opacity 0.2s;
}
.inv-back-link:hover { opacity: 0.65; }

/* ── Main content ── */
.inv-main { padding: 48px 0 80px; min-width: 0; }
.inv-content { margin-bottom: 48px; }

.inv-tags {
  display: flex; flex-wrap: wrap; gap: 8px;
  padding-top: 32px; border-top: 1px solid #e4e8ed;
  margin-bottom: 40px;
}
.inv-tag {
  font-size: 11px; padding: 4px 12px;
  border: 1px solid #d0d6de; color: #6c757d;
}

.inv-nav-bottom { text-align: left; }
.inv-nav-btn {
  display: inline-flex; align-items: center;
  padding: 12px 24px;
  border: 1px solid #d0d6de; color: #3d4a52;
  font-size: 13px; font-weight: 700;
  font-family: 'Shippori Mincho', serif;
  transition: all 0.2s;
}
.inv-nav-btn:hover { border-color: #0d8a87; color: #0d8a87; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .inv-body {
    grid-template-columns: 1fr;
    padding: 0 24px; gap: 0;
  }
  .inv-hero-inner { padding: 0 24px; }
  .inv-sidebar { position: static; padding: 24px 0 0; border-bottom: 1px solid #e4e8ed; }
  .inv-main { padding: 32px 0 60px; }
}
@media (max-width: 600px) {
  .inv-hero { padding: 100px 0 48px; }
  .inv-hero-title { font-size: clamp(24px, 6vw, 36px); }
}
</style>
