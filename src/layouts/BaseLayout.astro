---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = '函館の魅力を、地元目線でかってに発信するコミュニティメディア' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | カッテニハコダテ</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:title" content={`${title} | カッテニハコダテ`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://kattenihakodate.com/icon-512.png" />
  <meta property="og:url" content="https://kattenihakodate.com" />
  <meta property="og:site_name" content="カッテニハコダテ" />
  <meta property="og:type" content="website" />
  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RFE6QTKL22"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RFE6QTKL22');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Noto+Sans+JP:wght@400;500;700&family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>
