---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({ params: { slug: a.id }, props: { article: a } }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const categoryColors: Record<string, string> = {
  'グルメ': '#0d8a87', '観光': '#0d2d52', '暮らし': '#1a7fc0',
  'イベント': '#c05a3a', '人・ビジネス': '#5a3a7a', '特産品': '#1a6a5a',
};
const categoryBg: Record<string, string> = {
  'グルメ': 'linear-gradient(135deg, #0d4a4a, #0d8a87)',
  '観光': 'linear-gradient(135deg, #0d1a38, #0d2d52)',
  '暮らし': 'linear-gradient(135deg, #0a3a6a, #1a7fc0)',
  'イベント': 'linear-gradient(135deg, #7a2a18, #c05a3a)',
  '人・ビジネス': 'linear-gradient(135deg, #2a1a4a, #5a3a7a)',
  '特産品': 'linear-gradient(135deg, #0a3a2a, #1a6a5a)',
};
const catColor = categoryColors[article.data.category] || '#0d8a87';
const catBg = categoryBg[article.data.category] || 'linear-gradient(135deg,#0d2d52,#0d8a87)';
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <Header />

  <!-- Hero image -->
  <div style={`background: ${catBg}; height: 360px; display:flex; align-items:center; justify-content:center; position:relative;`}>
    <span style="font-size: 80px; opacity: 0.25;">
      {article.data.category === 'グルメ' ? '🍣' : article.data.category === '観光' ? '⚓' : article.data.category === '暮らし' ? '🏘️' : article.data.category === 'イベント' ? '🎆' : article.data.category === '人・ビジネス' ? '👥' : '🦑'}
    </span>
    <div style="position:absolute; bottom:0; left:0; right:0; height:80px; background: linear-gradient(transparent, white);"></div>
  </div>

  <main style="max-width: 760px; margin: 0 auto; padding: 0 24px 100px;">

    <!-- Breadcrumb -->
    <nav style="font-size: 12px; color: #aab4bc; margin-bottom: 32px; display: flex; gap: 8px; align-items: center;">
      <a href="/" style="color: #aab4bc; transition: color 0.2s;" onmouseover="this.style.color='#0d2d52'" onmouseout="this.style.color='#aab4bc'">ホーム</a>
      <span>›</span>
      <a href={`/category/${article.data.category}`} style="color: #aab4bc; transition: color 0.2s;" onmouseover="this.style.color='#0d2d52'" onmouseout="this.style.color='#aab4bc'">{article.data.category}</a>
      <span>›</span>
      <span style="color: #3d4a52;">{article.data.title.substring(0, 20)}...</span>
    </nav>

    <!-- Meta -->
    <div style="margin-bottom: 12px; display: flex; gap: 8px; align-items: center;">
      <span style={`font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 2px; color: white; background: ${catColor}; letter-spacing: 0.1em;`}>{article.data.category}</span>
      {article.data.featured && <span style="font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 2px; color: white; background: #c05a3a; letter-spacing: 0.1em;">PICK UP</span>}
    </div>

    <!-- Title -->
    <h1 style="font-family: 'Shippori Mincho', serif; font-size: clamp(24px, 4vw, 34px); font-weight: 800; line-height: 1.45; color: #0d0d0d; margin-bottom: 20px; letter-spacing: 0.02em;">{article.data.title}</h1>

    <!-- Description -->
    <p style="font-size: 16px; color: #6c757d; line-height: 1.8; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid #e2e6ea;">{article.data.description}</p>

    <!-- Author / Date -->
    <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 48px; font-size: 13px; color: #6c757d;">
      <span>✍️ {article.data.author}</span>
      <span>📅 {article.data.date}</span>
    </div>

    <!-- Content -->
    <div class="article-content">
      <Content />
    </div>

    <!-- Tags -->
    {article.data.tags && article.data.tags.length > 0 && (
      <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid #e2e6ea; display: flex; flex-wrap: wrap; gap: 8px;">
        {article.data.tags.map((tag: string) => (
          <span style="font-size: 12px; padding: 5px 14px; border-radius: 2px; background: #f0f2f4; color: #3d4a52; border: 1px solid #e2e6ea;">#{tag}</span>
        ))}
      </div>
    )}

    <!-- Back -->
    <div style="margin-top: 56px; text-align: center;">
      <a href="/" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; border: 1.5px solid #0d2d52; color: #0d2d52; border-radius: 4px; font-size: 14px; font-weight: 700; transition: all 0.2s;"
        onmouseover="this.style.background='#0d2d52'; this.style.color='white'"
        onmouseout="this.style.background='transparent'; this.style.color='#0d2d52'">
        ← トップページに戻る
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
