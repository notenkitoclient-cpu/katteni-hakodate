---
import Navigation from '../../components/Navigation.tsx';
import ArticleGrid from '../../components/ArticleGrid.tsx';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const SOURCE_MAP: Record<string, string> = {
  '暮らし':       '函館市オープンデータ',
  '人・ビジネス': '函館市統計書',
  '特産品':       '北海道水産現勢',
};

function estimateMinutes(body: string) {
  return Math.max(1, Math.round(body.replace(/\s/g, '').length / 400));
}

const articles = sorted.map(a => ({
  slug: a.id,
  title: a.data.title,
  description: a.data.description,
  category: a.data.category,
  date: a.data.date,
  readingMinutes: estimateMinutes(a.body ?? ''),
  source: SOURCE_MAP[a.data.category],
  isInvestigation: false,
  href: `/articles/${a.id}`,
}));

const investigationCard = {
  slug: 'hakodate-youth-flow',
  title: '函館から若者が消えていく。20代人口25年間の記録',
  description: '2000年から2025年にかけて函館市の20代人口は約24%減少した。データで函館の若者流出を読み解く調査報告。',
  category: '調査報告',
  date: '2026-04-10',
  readingMinutes: 5,
  source: '函館市人口統計',
  isInvestigation: true,
  href: '/articles/hakodate-youth-flow',
};

const allItems = [investigationCard, ...articles];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>調べた | カッテニハコダテ</title>
  <meta name="description" content="函館・道南の気になることを勝手に調べた記事一覧。データジャーナリズム・ローカル検証・まとめ。" />
  <meta property="og:title" content="調べた | カッテニハコダテ" />
  <meta property="og:image" content="https://kattenihakodate.com/icon-512.png" />
  <meta property="og:url" content="https://kattenihakodate.com/articles" />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RFE6QTKL22"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RFE6QTKL22');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Noto+Sans+JP:wght@400;500;700&family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-spicato-white text-spicato-black">

  <Navigation client:load />

  <div class="pt-40 pb-20 px-6 md:px-10 max-w-6xl mx-auto">
    <p class="font-sans text-[10px] tracking-[0.3em] text-spicato-black/30 uppercase mb-6">
      Articles / 調べた
    </p>
    <h1 class="font-serif text-[clamp(2.5rem,7vw,6rem)] leading-none tracking-widest mb-8" style="font-feature-settings:'palt'">
      勝手に、<br />調べた。
    </h1>
    <p class="font-sans text-sm leading-loose max-w-xl" style="color: rgba(17,17,17,0.5)">
      函館市民なら誰でも気になるアレを、頼まれてないのに調べました。<br />
      データ、現地取材、インタビュー——全部ここにあります。
    </p>
    <div class="mt-12 pt-8 flex items-baseline gap-3" style="border-top: 1px solid rgba(17,17,17,0.1)">
      <span class="font-serif text-4xl font-light">{allItems.length}</span>
      <span class="font-sans text-xs tracking-widest" style="color: rgba(17,17,17,0.4)">本の記事</span>
    </div>
  </div>

  <ArticleGrid articles={allItems} client:load />

  <Footer />

</body>
</html>
