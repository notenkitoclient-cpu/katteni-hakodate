---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = sorted.filter(a => a.data.featured).slice(0, 3);
const recent   = sorted.slice(0, 6);

const categories = [
  { name: 'グルメ',       img: '/images/kacchin-gourmet.png',   desc: '地元民が通う店・海鮮グルメ',   color: '#0d8a87', accent: '#e6f7f7' },
  { name: '観光',         img: '/images/kacchin-slope.png',     desc: '穴場・定番・絶景スポット',     color: '#1a7fc0', accent: '#e8f2fa' },
  { name: '暮らし',       img: '/images/kacchin-tram.png',      desc: '移住・子育て・生活情報',       color: '#3a8fd4', accent: '#eaf4fc' },
  { name: 'イベント',     img: '/images/kacchin-goryokaku.png', desc: '季節のお祭り・港のイベント',   color: '#c05a3a', accent: '#fdf2ee' },
  { name: '人・ビジネス', img: '/images/kacchin-nightview.png', desc: '函館で活躍する人の物語',       color: '#7a50b0', accent: '#f4f0fa' },
  { name: '特産品',       img: '/images/kacchin-asaichi.png',   desc: 'イカ・海産物・函館の名物',     color: '#1a9a6a', accent: '#ebf8f2' },
];
---

<BaseLayout title="ホーム">
  <Header />
  <HeroSection />

  <main style="background: #ffffff;">

    <!-- ===== PICK UP ===== -->
    {featured.length > 0 && (
      <section style="padding: 80px 0;">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
          <div style="display: flex; align-items: flex-end; gap: 16px; margin-bottom: 44px;">
            <div>
              <p style="font-size: 11px; letter-spacing: 0.3em; color: #0d8a87; font-weight: 700; text-transform: uppercase; margin-bottom: 6px;">Pick Up</p>
              <h2 style="font-family: 'Shippori Mincho', serif; font-size: 26px; font-weight: 800; color: #0d2d52;">注目の記事</h2>
            </div>
            <div style="flex: 1; height: 1px; background: linear-gradient(to right, #c8dde6, transparent); margin-bottom: 6px;"></div>
          </div>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 24px;">
            {featured.map(a => (
              <ArticleCard title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.date} author={a.data.author} slug={a.id} featured={true} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== CATEGORY ===== -->
    <section style="padding: 80px 0; background: #f5fafc;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
        <div style="display: flex; align-items: flex-end; gap: 16px; margin-bottom: 44px;">
          <div>
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #0d8a87; font-weight: 700; text-transform: uppercase; margin-bottom: 6px;">Category</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 26px; font-weight: 800; color: #0d2d52;">カテゴリから探す</h2>
          </div>
          <div style="flex: 1; height: 1px; background: linear-gradient(to right, #c8dde6, transparent); margin-bottom: 6px;"></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
          {categories.map(cat => (
            <a href={`/category/${cat.name}`}
              style={`
                display: flex; align-items: center; gap: 16px;
                padding: 20px 22px;
                background: ${cat.accent};
                border-radius: 10px;
                border: 1.5px solid transparent;
                text-decoration: none;
                transition: all 0.25s ease;
              `}
              onmouseover={`this.style.borderColor='${cat.color}'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 28px rgba(0,0,0,0.08)'`}
              onmouseout="this.style.borderColor='transparent'; this.style.transform=''; this.style.boxShadow=''"
            >
              <img src={cat.img} alt={cat.name}
                style="width: 60px; height: 60px; object-fit: contain; flex-shrink: 0;"
              />
              <div>
                <p style={`font-size: 15px; font-weight: 700; color: ${cat.color}; margin-bottom: 3px; font-family: 'Shippori Mincho', serif;`}>{cat.name}</p>
                <p style="font-size: 12px; color: #7a9aaa; line-height: 1.5;">{cat.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== LATEST ===== -->
    <section style="padding: 80px 0;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
        <div style="display: flex; align-items: flex-end; gap: 16px; margin-bottom: 44px;">
          <div>
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #0d8a87; font-weight: 700; text-transform: uppercase; margin-bottom: 6px;">Latest</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 26px; font-weight: 800; color: #0d2d52;">最新記事</h2>
          </div>
          <div style="flex: 1; height: 1px; background: linear-gradient(to right, #c8dde6, transparent); margin-bottom: 6px;"></div>
          <a href="/articles" style="font-size: 13px; color: #0d8a87; font-weight: 600; border-bottom: 1px solid #0d8a87; padding-bottom: 2px; white-space: nowrap; margin-bottom: 6px; transition: opacity 0.2s;"
            onmouseover="this.style.opacity='0.7'"
            onmouseout="this.style.opacity='1'"
          >すべて見る →</a>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 24px;">
          {recent.map(a => (
            <ArticleCard title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.date} author={a.data.author} slug={a.id} featured={a.data.featured} />
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section style="padding: 0 0 100px; background: #f5fafc;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
        <div style="
          background: #0d2d52;
          border-radius: 12px; padding: 64px 56px;
          display: grid; grid-template-columns: 1fr auto;
          gap: 48px; align-items: center;
          position: relative; overflow: hidden;
        ">
          <!-- Decorative カッチン -->
          <img src="/images/kacchin-asaichi.png" alt="" aria-hidden="true" style="
            position: absolute; right: 220px; bottom: -10px;
            width: 160px; opacity: 0.12; pointer-events: none;
          " />

          <div>
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #52d9d6; font-weight: 700; margin-bottom: 14px; text-transform: uppercase;">Join Us</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 26px; font-weight: 800; color: white; margin-bottom: 14px; line-height: 1.45;">あなたの函館を、教えてください。</h2>
            <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.9; max-width: 480px;">好きなお店、おすすめの景色、移住して気づいたこと。「ハコダテ仕掛け人」として一緒に発信しませんか？</p>
          </div>
          <div style="display: flex; flex-direction: column; gap: 12px; flex-shrink: 0;">
            <a href="/submit" style="
              padding: 13px 28px; background: #c05a3a; color: white;
              border-radius: 4px; font-size: 14px; font-weight: 700;
              text-align: center; white-space: nowrap; letter-spacing: 0.05em; transition: opacity 0.2s;
            "
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'"
            >情報を投稿する</a>
            <a href="/members" style="
              padding: 13px 28px;
              border: 1.5px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8);
              border-radius: 4px; font-size: 14px; font-weight: 700;
              text-align: center; white-space: nowrap; letter-spacing: 0.05em; transition: all 0.2s;
            "
            onmouseover="this.style.borderColor='rgba(255,255,255,0.7)'; this.style.color='white'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.color='rgba(255,255,255,0.8)'"
            >仕掛け人について</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
