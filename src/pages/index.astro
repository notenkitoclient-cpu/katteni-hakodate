---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recent  = sorted.slice(0, 6);
const feature = recent[0];
const rest    = recent.slice(1);

/* ── 6 categories with icon config ── */
const categories = [
  { name: 'グルメ',       en: 'Gourmet',   emoji: '🍜', img: '/images/kacchin-gourmet.png',   href: '/category/グルメ',       accent: '#0d8a87', light: '#d4f2f0' },
  { name: '観光',         en: 'Sightseeing',emoji: '🗺', img: '/images/kacchin-slope.png',    href: '/category/観光',         accent: '#1a7fc0', light: '#d4e6f8' },
  { name: '暮らし',       en: 'Living',    emoji: '🏡', img: '/images/kacchin-tram.png',     href: '/category/暮らし',       accent: '#2a88c0', light: '#d8ecf8' },
  { name: 'イベント',     en: 'Events',    emoji: '🎉', img: '/images/kacchin-goryokaku.png',href: '/category/イベント',     accent: '#c05a3a', light: '#fbe8e0' },
  { name: '特産品',       en: 'Products',  emoji: '🦑', img: '/images/kacchin-asaichi.png',  href: '/category/特産品',       accent: '#1a9a6a', light: '#d4f0e4' },
  { name: '人・ビジネス', en: 'People',    emoji: '🤝', img: '/images/kacchin-nightview.png',href: '/category/人・ビジネス', accent: '#7a50b8', light: '#ede4f8' },
];

/* ── Life tiles (editorial card style) ── */
const lifeTiles = [
  {
    name:  'グルメ',
    en:    'Gourmet',
    desc:  '海鮮・ラーメン・朝市。地元が通う本物の味。',
    img:   '/images/kacchin-gourmet.png',
    href:  '/category/グルメ',
    accent:'#0d8a87',
    from:  '#0a5a58',
    to:    '#0ea09c',
    light: '#d4f2f0',
    span:  'hero',
  },
  {
    name:  '観光',
    en:    'Sightseeing',
    desc:  '夜景・元町・金森倉庫。函館の絶景を歩く。',
    img:   '/images/kacchin-slope.png',
    href:  '/category/観光',
    accent:'#1a7fc0',
    from:  '#0d2a4a',
    to:    '#1a72c0',
    light: '#daeaf8',
    span:  '',
  },
  {
    name:  '暮らし',
    en:    'Living',
    desc:  '移住・子育て・仕事。函館で暮らすリアル。',
    img:   '/images/kacchin-tram.png',
    href:  '/category/暮らし',
    accent:'#2a88c0',
    from:  '#0d2840',
    to:    '#2a78b8',
    light: '#daeef8',
    span:  '',
  },
  {
    name:  'イベント',
    en:    'Events',
    desc:  'バル街・港まつり。季節の祭りを全力で。',
    img:   '/images/kacchin-goryokaku.png',
    href:  '/category/イベント',
    accent:'#c05a3a',
    from:  '#3a1005',
    to:    '#c05a3a',
    light: '#fce8e0',
    span:  '',
  },
  {
    name:  '特産品',
    en:    'Products',
    desc:  'イカ・昆布・海産物。函館の食の宝庫。',
    img:   '/images/kacchin-asaichi.png',
    href:  '/category/特産品',
    accent:'#1a9a6a',
    from:  '#023a20',
    to:    '#1a9a6a',
    light: '#d4f0e4',
    span:  '',
  },
  {
    name:  '人・ビジネス',
    en:    'People & Business',
    desc:  '函館で働く・作る・挑む。人の物語。',
    img:   '/images/kacchin-nightview.png',
    href:  '/category/人・ビジネス',
    accent:'#7a50b8',
    from:  '#1a0838',
    to:    '#7a50b8',
    light: '#ede4f8',
    span:  'wide',
  },
];

/* ── Ticker content ── */
const ticks = [
  '🦑 イカソーメンは函館の誇るグルメ',
  '🌙 日本三大夜景・函館山の絶景',
  '🚃 路面電車が現役で走る港町',
  '🌸 五稜郭の桜と春の函館',
  '🐟 朝市で食べる新鮮な海の幸',
  '🏛 元町の異国情緒あふれる坂道',
  '❄ 冬の津軽海峡と函館の空',
  '🍜 塩ラーメン発祥の地・函館',
];
---

<BaseLayout title="ホーム">
  <Header />
  <HeroSection />

  <main class="main-page">

    <!-- ═══════════════════════════════════════════
      TICKER STRIP
    ═══════════════════════════════════════════ -->
    <div class="ticker-wrap">
      <span class="ticker-tag">HAKODATE</span>
      <div class="ticker-track">
        <div class="ticker-run">
          {[...ticks, ...ticks].map(t => (
            <span class="t-item">{t}<span class="t-sep">◆</span></span>
          ))}
        </div>
      </div>
    </div>


    <!-- ═══════════════════════════════════════════
      CATEGORY ICONS  (saiko-niseko style)
    ═══════════════════════════════════════════ -->
    <section class="cat-section">
      <div class="wrap">
        <div class="cat-row">
          {categories.map(cat => (
            <a href={cat.href} class="cat-icon-item">
              <div class="cat-circle" style={`background: ${cat.light};`}>
                <img src={cat.img} alt={cat.name} class="cat-img" loading="lazy" />
              </div>
              <span class="cat-label">{cat.name}</span>
              <span class="cat-en">{cat.en}</span>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
      LIFE TILES — エディトリアルカードグリッド
    ═══════════════════════════════════════════ -->
    <section class="tiles-section">
      <div class="wrap">

        <header class="sec-head">
          <div>
            <p class="sec-eye">In Hakodate</p>
            <h2 class="sec-title">6つのハコダテライフ</h2>
          </div>
          <p class="sec-note">グルメ、観光、暮らし、イベント、<br>特産品、人。あなたの函館を見つけて。</p>
        </header>

        <div class="tile-grid">
          {lifeTiles.map(tile => (
            <a
              href={tile.href}
              class={`tile ${tile.span ? 'tile--' + tile.span : ''}`}
            >
              <!-- Colored image area -->
              <div
                class="tile-top"
                style={`background: linear-gradient(145deg, ${tile.from} 0%, ${tile.to} 100%);`}
              >
                <div class="tile-top-overlay"></div>
                <img src={tile.img} alt={tile.name} class="tile-kacchin" loading="lazy" />
                <div class="tile-badge" style={`background: ${tile.accent};`}>{tile.name}</div>
              </div>

              <!-- White text area -->
              <div class="tile-body">
                <p class="tile-en">{tile.en}</p>
                <h3 class="tile-name" style={`color: ${tile.accent};`}>{tile.name}</h3>
                <p class="tile-desc">{tile.desc}</p>
                <span class="tile-arrow" style={`color: ${tile.accent};`}>→ 読む</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
      LATEST ARTICLES
    ═══════════════════════════════════════════ -->
    <section class="articles-section">
      <div class="wrap">

        <header class="sec-head sec-head--row">
          <div>
            <p class="sec-eye">News &amp; Topics</p>
            <h2 class="sec-title">最新記事</h2>
          </div>
          <a href="/articles" class="sec-more">すべて見る →</a>
        </header>

        <!-- Featured (first article, wide) -->
        {feature && (
          <a href={`/articles/${feature.id}`} class="feature-card">
            <div class="feature-thumb" style={
              feature.data.category === 'グルメ'      ? 'background: linear-gradient(135deg,#073a38,#0ea09c)' :
              feature.data.category === '観光'        ? 'background: linear-gradient(135deg,#0d2a4a,#1a72c0)' :
              feature.data.category === '暮らし'      ? 'background: linear-gradient(135deg,#0d2840,#2a78b8)' :
              feature.data.category === 'イベント'    ? 'background: linear-gradient(135deg,#3a1005,#c05a3a)' :
              feature.data.category === '特産品'      ? 'background: linear-gradient(135deg,#023a20,#1a9a6a)' :
                                                        'background: linear-gradient(135deg,#1a0838,#7a50b8)'
            }>
              <img
                src={
                  feature.data.category === 'グルメ'      ? '/images/kacchin-gourmet.png' :
                  feature.data.category === '観光'        ? '/images/kacchin-slope.png' :
                  feature.data.category === '暮らし'      ? '/images/kacchin-tram.png' :
                  feature.data.category === 'イベント'    ? '/images/kacchin-goryokaku.png' :
                  feature.data.category === '特産品'      ? '/images/kacchin-asaichi.png' :
                  '/images/kacchin-nightview.png'
                }
                alt={feature.data.category}
                class="feature-img"
                loading="lazy"
              />
              {feature.data.featured && <span class="feature-pick">PICK UP</span>}
            </div>

            <div class="feature-body">
              <div class="feature-meta">
                <span class="fcat">{feature.data.category}</span>
                <span class="fdate">{feature.data.date}</span>
                <span class="fauth">{feature.data.author}</span>
              </div>
              <h3 class="feature-title">{feature.data.title}</h3>
              <p  class="feature-desc">{feature.data.description}</p>
              <span class="feature-link">記事を読む →</span>
            </div>
          </a>
        )}

        <!-- Rest grid -->
        <div class="article-grid">
          {rest.map(a => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              date={a.data.date}
              author={a.data.author}
              slug={a.id}
              featured={a.data.featured}
            />
          ))}
        </div>

      </div>
    </section>


    <!-- ═══════════════════════════════════════════
      JOIN US
    ═══════════════════════════════════════════ -->
    <section class="join-section">
      <div class="wrap">
        <div class="join-card">

          <!-- Dot grid texture -->
          <div class="join-dots" aria-hidden="true"></div>

          <!-- Decorative wave shape -->
          <div class="join-wave-deco" aria-hidden="true"></div>

          <!-- Background mascot -->
          <img src="/images/kacchin-nightview.png" alt="" aria-hidden="true" class="join-mascot-bg" />

          <div class="join-content">
            <p class="join-eye">Join Us</p>
            <h2 class="join-title">
              あなたの函館を、<br>教えてください。
            </h2>
            <p class="join-body">
              好きなお店、おすすめの景色、移住して気づいたこと。<br>
              「ハコダテ仕掛け人」として一緒に発信しませんか？
            </p>
          </div>

          <div class="join-btns">
            <a href="/submit"  class="jbtn jbtn--primary">情報を投稿する</a>
            <a href="/members" class="jbtn jbtn--ghost">仕掛け人について</a>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>


<style>
/* ──────────────────────────────────────────
   Page base
────────────────────────────────────────── */
.main-page {
  background: #faf7f0;
}
.wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}


/* ──────────────────────────────────────────
   TICKER
────────────────────────────────────────── */
.ticker-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-top: 2px solid #0d8a87;
  border-bottom: 1px solid #e8eef2;
  height: 46px;
  overflow: hidden;
}
.ticker-tag {
  flex-shrink: 0;
  background: #0d8a87;
  color: #fff;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.26em;
  padding: 0 18px;
  height: 100%;
  display: flex;
  align-items: center;
}
.ticker-track {
  flex: 1;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
}
.ticker-run {
  display: flex;
  animation: tickRoll 30s linear infinite;
  white-space: nowrap;
}
@keyframes tickRoll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.t-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 28px;
  font-size: 12px;
  color: #3a5060;
  font-weight: 500;
}
.t-sep {
  font-size: 5px;
  color: #0d8a87;
  margin-left: 10px;
}


/* ──────────────────────────────────────────
   CATEGORY ICONS
────────────────────────────────────────── */
.cat-section {
  padding: 56px 0 48px;
  background: #ffffff;
  border-bottom: 1px solid #edf2f6;
}
.cat-row {
  display: flex;
  justify-content: center;
  gap: 0;
}
.cat-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 24px;
  border-radius: 12px;
  text-decoration: none;
  transition: background 0.22s, transform 0.22s;
  flex: 1;
  max-width: 160px;
}
.cat-icon-item:hover {
  background: #f0f8f8;
  transform: translateY(-3px);
}
.cat-circle {
  width: 72px;
  height: 72px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: box-shadow 0.22s;
}
.cat-icon-item:hover .cat-circle {
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.cat-img {
  width: 62px;
  height: 62px;
  object-fit: contain;
  transition: transform 0.35s;
}
.cat-icon-item:hover .cat-img { transform: scale(1.1); }
.cat-label {
  font-size: 13px;
  font-weight: 700;
  color: #0d2d52;
  letter-spacing: 0.03em;
}
.cat-en {
  font-size: 9.5px;
  color: #9ab8c8;
  letter-spacing: 0.1em;
}


/* ──────────────────────────────────────────
   SECTION HEADER shared
────────────────────────────────────────── */
.sec-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 40px;
  margin-bottom: 48px;
  flex-wrap: wrap;
}
.sec-head--row {
  align-items: flex-end;
}
.sec-eye {
  font-size: 10px;
  letter-spacing: 0.36em;
  color: #0d8a87;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.sec-eye::before {
  content: '';
  display: inline-block;
  width: 20px;
  height: 2px;
  background: #0d8a87;
  border-radius: 1px;
}
.sec-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 30px;
  font-weight: 800;
  color: #0d2d52;
  letter-spacing: 0.03em;
}
.sec-note {
  font-size: 13px;
  color: #7a9aaa;
  line-height: 1.8;
  text-align: right;
}
.sec-more {
  font-size: 13px;
  color: #0d8a87;
  font-weight: 600;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  white-space: nowrap;
  flex-shrink: 0;
  margin-bottom: 6px;
  transition: opacity 0.2s;
}
.sec-more:hover { opacity: 0.7; }


/* ──────────────────────────────────────────
   LIFE TILES
────────────────────────────────────────── */
.tiles-section {
  padding: 88px 0 96px;
  background: #faf7f0;
}

.tile-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: auto auto auto;
  gap: 16px;
}

/* Base tile */
.tile {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  border: 1px solid #e8eef4;
  transition: transform 0.28s ease, box-shadow 0.28s ease;
}
.tile:hover {
  transform: translateY(-5px);
  box-shadow: 0 16px 48px rgba(13, 45, 82, 0.12);
}

/* Hero tile (グルメ): spans 2 rows */
.tile--hero {
  grid-column: 1;
  grid-row: 1 / 3;
}
/* Wide tile (人・ビジネス): spans all 3 cols */
.tile--wide {
  grid-column: 1 / 4;
  flex-direction: row;
}

/* Colored top image area */
.tile-top {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  /* Default height — will be overridden below */
  min-height: 160px;
  flex-shrink: 0;
}
.tile .tile-top { min-height: 160px; }
.tile--hero .tile-top { min-height: 260px; }
.tile--wide .tile-top {
  width: 280px;
  min-height: unset;
  flex-shrink: 0;
}

.tile-top-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.08);
}

.tile-kacchin {
  height: 75%;
  width: 100%;
  object-fit: contain;
  filter: drop-shadow(0 8px 20px rgba(0,0,0,0.25));
  transition: transform 0.45s ease;
  position: relative;
  z-index: 1;
}
.tile:hover .tile-kacchin { transform: scale(1.07); }

.tile-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 2;
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 0.1em;
}

/* White text area */
.tile-body {
  padding: 18px 22px 22px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.tile--wide .tile-body {
  justify-content: center;
  padding: 24px 32px;
}

.tile-en {
  font-size: 9.5px;
  letter-spacing: 0.18em;
  color: #9ab8c8;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.tile-name {
  font-family: 'Shippori Mincho', serif;
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
  line-height: 1.2;
}
.tile--hero .tile-name { font-size: 22px; }

.tile-desc {
  font-size: 12.5px;
  color: #5a7080;
  line-height: 1.7;
  margin-bottom: 14px;
  flex: 1;
}
.tile-arrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  transition: letter-spacing 0.2s;
}
.tile:hover .tile-arrow { letter-spacing: 0.14em; }


/* ──────────────────────────────────────────
   LATEST ARTICLES
────────────────────────────────────────── */
.articles-section {
  padding: 88px 0 96px;
  background: #ffffff;
  border-top: 1px solid #edf2f6;
}

/* Featured wide card */
.feature-card {
  display: grid;
  grid-template-columns: 5fr 7fr;
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid #e8eef4;
  margin-bottom: 32px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.28s, box-shadow 0.28s;
}
.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 50px rgba(13,45,82,0.11);
}

.feature-thumb {
  position: relative;
  min-height: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.feature-img {
  height: 80%;
  width: 100%;
  object-fit: contain;
  filter: drop-shadow(0 12px 30px rgba(0,0,0,0.25));
  transition: transform 0.5s;
}
.feature-card:hover .feature-img { transform: scale(1.06); }

.feature-pick {
  position: absolute;
  top: 14px;
  right: 14px;
  background: #c05a3a;
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 0.1em;
}

.feature-body {
  padding: 36px 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.feature-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.fcat {
  background: #e4f5f4;
  color: #0d8a87;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 4px;
  letter-spacing: 0.08em;
}
.fdate, .fauth {
  font-size: 11px;
  color: #9ab8c8;
}
.feature-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 22px;
  font-weight: 800;
  color: #0d2d52;
  line-height: 1.6;
  margin-bottom: 14px;
}
.feature-desc {
  font-size: 14px;
  color: #5a7080;
  line-height: 1.85;
  margin-bottom: 24px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.feature-link {
  font-size: 13px;
  color: #0d8a87;
  font-weight: 700;
  letter-spacing: 0.05em;
  transition: letter-spacing 0.2s;
}
.feature-card:hover .feature-link { letter-spacing: 0.1em; }

/* Article grid */
.article-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}


