---
import Navigation from '../components/Navigation.tsx';
import StoriesGrid from '../components/ui/StoriesGrid.tsx';
import { getCollection } from 'astro:content';
import '../styles/global.css';
import type { Story } from '../components/ui/StoryCard.tsx';

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const TYPE_COLOR: Record<string, string> = {
  '開店': '#2d7a3a',
  '閉店': '#b91c1c',
  '工事中': '#c2410c',
  'イベント': '#1d4ed8',
  'その他': '#6b7280',
};

const stories: Story[] = [
  {
    id: '001',
    href: '/essays/squid-catch',
    title: '函館のイカが、消えていく。',
    subtitle: '漁獲量ピーク比93%減の現実',
    month: 'Apr 2026',
    tags: ['漁業', 'イカ', '海洋温暖化'],
    bg: '#00C8FF',   // vivid cyan — 海のイメージ
    filterTags: ['漁業'],
  },
  {
    id: '002',
    href: '/essays/school-enrollment',
    title: '函館の小学校が、消えていく。',
    subtitle: '25年で生徒数64%減',
    month: 'Apr 2026',
    tags: ['教育', '少子化', '廃校'],
    bg: '#FF2D78',   // vivid magenta — 喪失感・緊迫
    filterTags: ['教育'],
  },
  {
    id: '003',
    href: '/articles/hakodate-youth-flow',
    title: '函館から若者が消えていく。',
    subtitle: '20代人口25年間の記録',
    month: 'Apr 2026',
    tags: ['人口', '若者', 'データ'],
    bg: '#C8FF00',   // vivid chartreuse — エネルギー・未来
    filterTags: ['人口'],
  },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>カッテニハコダテ — 函館について、勝手に調べてしまった。</title>
  <meta name="description" content="気になったから、本気で調べてしまった。データと地図で読み解く函館のビジュアルエッセイ。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet" />
</head>
<body style="background:#ffffff; color:#0d0d0d;">

  <Navigation client:load initialLight />

  <!-- ════ HERO ════ -->
  <section class="hero">
    <div class="hero-body">
      <p class="hero-kicker">Katteni Hakodate</p>
      <h1 class="hero-title">
        函館について、<br />
        勝手に<em>調べて</em><br />しまった。
      </h1>
    </div>
    <p class="hero-sub">
      気になったから、本気で調べた。<br class="sp-only" />
      スクロールするたびに発見が動く、函館のビジュアルエッセイ。
    </p>
  </section>

  <!-- ════ STORIES ════ -->
  <main class="main-wrap">
    <StoriesGrid client:load stories={stories} />
  </main>

  <!-- ════ 今日の函館（おまけ）════ -->
  <footer class="news-footer">
    <div class="news-footer-inner">
      <div class="news-footer-head">
        <h2 class="news-footer-title">今日の函館</h2>
        <a href="/news" class="news-footer-more">すべて見る →</a>
      </div>
      <ul class="news-footer-list">
        {recentNews.map(n => (
          <li class="news-row">
            <span class="news-row-date">{n.data.date.replace(/-/g,'.')}</span>
            <span class="news-row-type" style={`color:${TYPE_COLOR[n.data.type] ?? '#6b7280'}`}>
              {n.data.type}
            </span>
            <a href={`/news/${n.id}`} class="news-row-title">{n.data.title}</a>
          </li>
        ))}
      </ul>
    </div>
  </footer>

</body>
</html>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 clamp(2rem,6vw,8rem) 6rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .hero-body { margin-bottom: 2rem; }
  .hero-kicker {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: .42em;
    opacity: .18;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .hero-title {
    font-family: 'Shippori Mincho', serif;
    /* 極端に大きく — 中途半端なサイズを避ける */
    font-size: clamp(3.2rem, 9vw, 10rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: .02em;
    font-feature-settings: 'palt';
    margin: 0;
  }
  .hero-title em { font-style: normal; opacity: .22; }
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: clamp(.75rem, 1vw, .85rem);
    opacity: .3;
    line-height: 2;
    max-width: 28em;
    letter-spacing: .04em;
  }

  /* ── MAIN ── */
  .main-wrap {
    max-width: 1600px;
    margin: 0 auto;
    padding: 6rem clamp(2rem,6vw,8rem) 10rem;
  }

  /* ── NEWS FOOTER ── */
  .news-footer {
    border-top: 1px solid rgba(0,0,0,0.08);
    background: #f8f8f8;
  }
  .news-footer-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 3rem clamp(2rem,6vw,8rem) 5rem;
  }
  .news-footer-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(0,0,0,.08);
    padding-bottom: 1rem;
  }
  .news-footer-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .06em;
    opacity: .5;
  }
  .news-footer-more {
    font-family: 'Inter', sans-serif;
    font-size: .75rem;
    opacity: .3;
    letter-spacing: .08em;
    transition: opacity .2s;
  }
  .news-footer-more:hover { opacity: .7; }
  .news-footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .news-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: .7rem 0;
    border-bottom: 1px solid rgba(0,0,0,.05);
    flex-wrap: wrap;
  }
  .news-row-date {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    opacity: .25;
    white-space: nowrap;
    letter-spacing: .05em;
  }
  .news-row-type {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: .08em;
    white-space: nowrap;
    font-weight: 600;
  }
  .news-row-title {
    font-family: 'Shippori Mincho', serif;
    font-size: .85rem;
    opacity: .5;
    letter-spacing: .04em;
    line-height: 1.5;
    transition: opacity .2s;
  }
  .news-row-title:hover { opacity: .9; }

  .sp-only { display: none; }
  @media (max-width: 640px) {
    .sp-only { display: inline; }
  }
</style>
