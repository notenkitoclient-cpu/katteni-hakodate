---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = sorted.filter(a => a.data.featured).slice(0, 3);
const recent = sorted.slice(0, 6);

const categories = [
  { name: 'グルメ',      img: '/images/kacchin-gourmet.png',   desc: '地元民が通う店・海鮮グルメ',   color: '#0d8a87', dark: '#064a4a' },
  { name: '観光',        img: '/images/kacchin-slope.png',     desc: '穴場・定番・絶景スポット',     color: '#1a7fc0', dark: '#0a2d52' },
  { name: '暮らし',      img: '/images/kacchin-tram.png',      desc: '移住・子育て・生活情報',       color: '#4a9ebe', dark: '#0a3a5a' },
  { name: 'イベント',    img: '/images/kacchin-goryokaku.png', desc: '季節のお祭り・港のイベント',   color: '#c05a3a', dark: '#5a1a0a' },
  { name: '人・ビジネス',img: '/images/kacchin-nightview.png', desc: '函館で活躍する人の物語',       color: '#8a5abe', dark: '#2a0a5a' },
  { name: '特産品',      img: '/images/kacchin-asaichi.png',   desc: 'イカ・海産物・函館の名物',     color: '#1a9a6a', dark: '#064a2a' },
];
---

<BaseLayout title="ホーム">
  <Header />
  <HeroSection />

  <main>

    <!-- ========== PICK UP ========== -->
    {featured.length > 0 && (
      <section style="padding: 80px 0; background: #ffffff;">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
          <div style="display: flex; align-items: flex-end; gap: 20px; margin-bottom: 48px;">
            <div>
              <p style="font-size: 11px; letter-spacing: 0.3em; color: #0d8a87; font-weight: 700; text-transform: uppercase; margin-bottom: 8px;">Pick Up</p>
              <h2 style="font-family: 'Shippori Mincho', serif; font-size: 28px; font-weight: 800; color: #061a2e; letter-spacing: 0.02em;">注目の記事</h2>
            </div>
            <div style="flex: 1; height: 1px; background: linear-gradient(to right, #e2e6ea, transparent); margin-bottom: 8px;"></div>
          </div>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 28px;">
            {featured.map(a => (
              <ArticleCard title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.date} author={a.data.author} slug={a.id} featured={true} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ========== CATEGORY (dark ocean) ========== -->
    <section style="
      background: linear-gradient(160deg, #061a2e 0%, #0a2744 60%, #0d3d5a 100%);
      padding: 80px 0 100px; position: relative; overflow: hidden;
    ">
      <!-- Top wave -->
      <div style="position: absolute; top: -1px; left: 0; right: 0; line-height: 0;">
        <svg viewBox="0 0 1440 60" style="width:100%; display:block;" preserveAspectRatio="none">
          <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,25 1440,30 L1440,0 L0,0 Z" fill="#ffffff"/>
        </svg>
      </div>

      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px; position: relative; z-index: 1;">
        <div style="display: flex; align-items: flex-end; gap: 20px; margin-bottom: 48px;">
          <div>
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #52d9d6; font-weight: 700; text-transform: uppercase; margin-bottom: 8px;">Category</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 28px; font-weight: 800; color: #ffffff; letter-spacing: 0.02em;">カテゴリから探す</h2>
          </div>
          <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(255,255,255,0.15), transparent); margin-bottom: 8px;"></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
          {categories.map(cat => (
            <a href={`/category/${cat.name}`}
              style={`
                display: block; border-radius: 8px; overflow: hidden;
                background: ${cat.dark};
                border: 1px solid rgba(255,255,255,0.08);
                text-decoration: none; transition: all 0.3s ease;
                position: relative;
              `}
              onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 48px rgba(0,0,0,0.4)'; this.style.borderColor='rgba(255,255,255,0.2)'"
              onmouseout="this.style.transform=''; this.style.boxShadow=''; this.style.borderColor='rgba(255,255,255,0.08)'"
            >
              <!-- Image -->
              <div style="display: flex; justify-content: center; padding: 24px 24px 0; height: 110px; align-items: flex-end;">
                <img src={cat.img} alt={cat.name}
                  style="height: 100%; object-fit: contain; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));"
                />
              </div>
              <!-- Text -->
              <div style="padding: 16px 20px 20px;">
                <p style={`font-size: 16px; font-weight: 700; color: ${cat.color}; margin-bottom: 4px; font-family: 'Shippori Mincho', serif; letter-spacing: 0.05em;`}>{cat.name}</p>
                <p style="font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.5;">{cat.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Bottom wave -->
      <div style="position: absolute; bottom: -1px; left: 0; right: 0; line-height: 0;">
        <svg viewBox="0 0 1440 60" style="width:100%; display:block;" preserveAspectRatio="none">
          <path d="M0,20 C360,50 720,0 1080,30 C1260,45 1380,15 1440,20 L1440,60 L0,60 Z" fill="#f4f8fc"/>
        </svg>
      </div>
    </section>

    <!-- ========== LATEST ARTICLES ========== -->
    <section style="background: #f4f8fc; padding: 80px 0 100px;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
        <div style="display: flex; align-items: flex-end; gap: 20px; margin-bottom: 48px;">
          <div>
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #0d8a87; font-weight: 700; text-transform: uppercase; margin-bottom: 8px;">Latest</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 28px; font-weight: 800; color: #061a2e; letter-spacing: 0.02em;">最新記事</h2>
          </div>
          <div style="flex: 1; height: 1px; background: linear-gradient(to right, #c8d8e4, transparent); margin-bottom: 8px;"></div>
          <a href="/articles" style="
            font-size: 13px; color: #0d8a87; font-weight: 600;
            border-bottom: 1px solid #0d8a87; padding-bottom: 2px;
            white-space: nowrap; margin-bottom: 8px; transition: opacity 0.2s;
          "
          onmouseover="this.style.opacity='0.7'"
          onmouseout="this.style.opacity='1'"
          >すべて見る →</a>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 28px;">
          {recent.map(a => (
            <ArticleCard title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.date} author={a.data.author} slug={a.id} featured={a.data.featured} />
          ))}
        </div>
      </div>
    </section>

    <!-- ========== CTA BANNER ========== -->
    <section style="background: #f4f8fc; padding: 0 0 100px;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 40px;">
        <div style="
          background: linear-gradient(135deg, #061a2e 0%, #0a2d4a 50%, #0d5a7a 100%);
          border-radius: 12px; padding: 64px;
          display: grid; grid-template-columns: 1fr auto;
          gap: 48px; align-items: center;
          position: relative; overflow: hidden;
        ">
          <!-- Background カッチン (faint) -->
          <img src="/images/kacchin-nightview.png" alt="" aria-hidden="true" style="
            position: absolute; right: 240px; bottom: -20px;
            width: 180px; opacity: 0.08;
            pointer-events: none;
            filter: grayscale(1);
          " />

          <div style="position: relative; z-index: 1;">
            <p style="font-size: 11px; letter-spacing: 0.3em; color: #52d9d6; font-weight: 700; margin-bottom: 16px; text-transform: uppercase;">Join Us</p>
            <h2 style="font-family: 'Shippori Mincho', serif; font-size: 28px; font-weight: 800; color: white; margin-bottom: 14px; line-height: 1.4;">あなたの函館を、教えてください。</h2>
            <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.9; max-width: 500px;">好きなお店、おすすめの景色、移住して気づいたこと。「ハコダテ仕掛け人」として一緒に発信しませんか？</p>
          </div>
          <div style="display: flex; flex-direction: column; gap: 12px; flex-shrink: 0; position: relative; z-index: 1;">
            <a href="/submit" style="
              padding: 14px 28px; background: #c05a3a; color: white;
              border-radius: 4px; font-size: 14px; font-weight: 700;
              text-align: center; white-space: nowrap; transition: opacity 0.2s; letter-spacing: 0.05em;
            "
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'"
            >情報を投稿する</a>
            <a href="/members" style="
              padding: 14px 28px;
              border: 1.5px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.8);
              border-radius: 4px; font-size: 14px; font-weight: 700;
              text-align: center; white-space: nowrap; transition: all 0.2s; letter-spacing: 0.05em;
            "
            onmouseover="this.style.borderColor='rgba(255,255,255,0.7)'; this.style.color='white'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.25)'; this.style.color='rgba(255,255,255,0.8)'"
            >仕掛け人について</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
