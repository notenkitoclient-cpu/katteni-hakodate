---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recent = sorted.slice(0, 3);

const allCF = await getCollection('crowdfunding');
const featuredCF = allCF
  .filter(cf => cf.data.featured)
  .sort((a,b) => new Date(b.data.endDate).getTime() - new Date(a.data.endDate).getTime())
  .slice(0, 3);

const ticks = [
  '📋 函館のリアルな情報を毎日収集中','💰 道南のプロジェクトを勝手に応援',
  '🔍 地元あるあるを勝手に調べた','🍜 函館グルメの新発見をお届け',
  '🏗 工事中のあの場所、何ができるの？','🎉 今週末の道南イベントをチェック',
  '⚓ 頼まれてないけどやってます','🗞 新しいお店・なくなるお店',
];

function daysLeft(dateStr: string) {
  const end = new Date(dateStr);
  const now = new Date();
  return Math.max(0, Math.ceil((end.getTime() - now.getTime()) / 86400000));
}
function pct(current: number, goal: number) {
  if (!goal) return null;
  return Math.min(100, Math.round((current / goal) * 100));
}
function fmtYen(n: number) {
  return n.toLocaleString('ja-JP') + '円';
}
---

<BaseLayout title="ホーム" description="函館・道南の超ローカル情報メディア。開店・閉店・地域プロジェクト・地元あるあるを勝手に発信。">
  <Header />
  <HeroSection />

  <main class="main-page">

    <!-- TICKER -->
    <div class="ticker-wrap">
      <span class="ticker-tag">KATTE NI</span>
      <div class="ticker-track">
        <div class="ticker-run">
          {[...ticks,...ticks].map(t => (
            <span class="t-item">{t}<span class="t-sep">◆</span></span>
          ))}
        </div>
      </div>
    </div>


    <!-- 3軸コーナー -->
    <section class="axes-section">
      <div class="wrap">
        <header class="sec-head">
          <div>
            <p class="sec-eye">カッテニハコダテの3つの活動</p>
            <h2 class="sec-title">勝手に、全力でやってます。</h2>
          </div>
          <p class="sec-note">頼まれてないけど、なぜかやめられない。</p>
        </header>

        <div class="axes-grid">

          <!-- 情報収集 -->
          <a href="/news" class="axis-card axis-info">
            <div class="card-stamp">勝手に</div>
            <div class="card-num">01</div>
            <div class="card-icon">📋</div>
            <h3 class="card-name">情報収集</h3>
            <p class="card-desc">
              開店・閉店・工事中の謎スポット。函館の「今」を勝手にキャッチしてお届けします。
            </p>
            <span class="card-link">情報を見る →</span>
          </a>

          <!-- 応援 -->
          <a href="/crowdfunding" class="axis-card axis-ouen">
            <div class="card-stamp">勝手に</div>
            <div class="card-num">02</div>
            <div class="card-icon">💰</div>
            <h3 class="card-name">応援</h3>
            <p class="card-desc">
              頑張ってるのに目につかないクラファン・プロジェクト・お店を勝手に発掘して応援します。
            </p>
            <span class="card-link">応援中を見る →</span>
          </a>

          <!-- 調べた -->
          <a href="/articles" class="axis-card axis-shira">
            <div class="card-stamp">勝手に</div>
            <div class="card-num">03</div>
            <div class="card-icon">🔍</div>
            <h3 class="card-name">調べた</h3>
            <p class="card-desc">
              函館市民なら誰でも気になるアレ、ちゃんと調べました。ローカルあるある・検証・まとめ。
            </p>
            <span class="card-link">調べた記事を読む →</span>
          </a>

        </div>
      </div>
    </section>


    <!-- 勝手に応援中 -->
    {featuredCF.length > 0 && (
      <section class="ouen-section">
        <div class="wrap">
          <header class="sec-head sec-head--row">
            <div>
              <p class="sec-eye">💰 勝手に応援中</p>
              <h2 class="sec-title">今、応援したいのはコレ</h2>
            </div>
            <a href="/crowdfunding" class="sec-more">もっと見る →</a>
          </header>

          <div class="cf-grid">
            {featuredCF.map(cf => {
              const p = pct(cf.data.currentAmount, cf.data.goalAmount);
              const days = daysLeft(cf.data.endDate);
              const ended = days === 0;
              const isPurchase = !cf.data.goalAmount;
              return (
                <a href={cf.data.url} target="_blank" rel="noopener" class={`cf-card ${ended ? 'cf-card--ended' : ''}`}>
                  <div class="cf-tags">
                    <span class="cf-area">{cf.data.area}</span>
                    <span class="cf-cat">{cf.data.category}</span>
                    {!ended && days <= 7 && <span class="cf-urgent">🔥 残り{days}日</span>}
                  </div>
                  <h3 class="cf-title">{cf.data.title}</h3>
                  <p class="cf-summary">{cf.data.summary}</p>
                  {p !== null ? (
                    <>
                      <div class="cf-bar-row">
                        <div class="cf-bar"><div class="cf-fill" style={`--pct: ${p}%`}></div></div>
                        <span class="cf-pct">{p}%</span>
                      </div>
                      <div class="cf-nums">
                        <b>{fmtYen(cf.data.currentAmount)}</b>
                        <span>/ 目標 {fmtYen(cf.data.goalAmount)}</span>
                      </div>
                    </>
                  ) : (
                    <div class="cf-purchase-row">
                      <span class="cf-purchase-badge">🎫 応援購入型</span>
                      <b>{fmtYen(cf.data.currentAmount)} 集まってます</b>
                    </div>
                  )}
                  <div class="cf-foot">
                    <span>👥 {cf.data.supporterCount}人が支援</span>
                    <span class="cf-cta">詳細を見る ↗</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}


    <!-- 勝手に調べた -->
    <section class="articles-section">
      <div class="wrap">
        <header class="sec-head sec-head--row">
          <div>
            <p class="sec-eye">🔍 勝手に調べた</p>
            <h2 class="sec-title">気になったから調べた</h2>
          </div>
          <a href="/articles" class="sec-more">すべて見る →</a>
        </header>

        <div class="article-grid">
          {recent.map(a => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              date={a.data.date}
              author={a.data.author}
              slug={a.id}
              featured={a.data.featured}
            />
          ))}
        </div>
      </div>
    </section>


    <!-- 情報投稿 CTA -->
    <section class="submit-section">
      <div class="wrap">
        <div class="submit-board">
          <div class="board-tape bt1" aria-hidden="true"></div>
          <div class="board-tape bt2" aria-hidden="true"></div>
          <div class="submit-content">
            <p class="submit-eye">あなたの情報が函館を動かす</p>
            <h2 class="submit-title">「そういえばあのお店が…」<br>その情報、教えてください。</h2>
            <p class="submit-body">
              新しくできそうなお店、閉まってたお店、気になる工事現場、頑張ってる人やプロジェクト。<br>
              なんでも投稿してください。勝手に記事にします。
            </p>
          </div>
          <div class="submit-actions">
            <a href="/submit" class="sbtn sbtn--primary">情報を投稿する ＋</a>
            <a href="/members" class="sbtn sbtn--ghost">仕掛け人を見る</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>


<style>
.main-page { background: #F5EDD8; }
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

/* Ticker */
.ticker-wrap {
  display: flex; align-items: center;
  background: #2A2420; height: 44px; overflow: hidden;
}
.ticker-tag {
  flex-shrink: 0; background: #9E3D26; color: #F5EDD8;
  font-size: 9px; font-weight: 900; letter-spacing: 0.3em;
  padding: 0 18px; height: 100%; display: flex; align-items: center;
  font-family: 'Shippori Mincho', serif; border-right: 2px solid #D4A02A;
}
.ticker-track {
  flex: 1; overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
}
.ticker-run { display: flex; animation: tickRoll 32s linear infinite; white-space: nowrap; }
@keyframes tickRoll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.t-item { display: inline-flex; align-items: center; gap: 8px; padding: 0 24px; font-size: 12px; color: #8A7A6A; font-weight: 500; }
.t-sep { font-size: 5px; color: #9E3D26; margin-left: 10px; }

/* Section headers */
.sec-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 40px; margin-bottom: 36px; flex-wrap: wrap; }
.sec-head--row { align-items: flex-end; }
.sec-eye {
  font-size: 11px; letter-spacing: 0.2em; color: #9E3D26;
  font-weight: 800; font-family: 'Shippori Mincho', serif;
  margin-bottom: 6px;
}
.sec-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 26px; font-weight: 900; color: #2A2420;
  letter-spacing: 0.04em;
}
.sec-note { font-size: 13px; color: #8A7A6A; line-height: 1.8; text-align: right; font-style: italic; }
.sec-more {
  font-size: 13px; color: #9E3D26; font-weight: 700;
  border-bottom: 1.5px solid currentColor; padding-bottom: 2px;
  white-space: nowrap; flex-shrink: 0; margin-bottom: 6px;
  transition: opacity 0.2s; font-family: 'Shippori Mincho', serif;
}
.sec-more:hover { opacity: 0.7; }

/* 3軸 */
.axes-section {
  padding: 72px 0 80px;
  background: #FBF7EF;
  border-bottom: 3px solid #EDE3CC;
}
.axes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.axis-card {
  position: relative; border-radius: 0;
  padding: 32px 24px 28px;
  text-decoration: none; display: flex; flex-direction: column; gap: 10px;
  border: 2px solid #2A2420;
  box-shadow: 4px 4px 0 #2A2420;
  transition: transform 0.22s ease, box-shadow 0.22s ease;
  overflow: hidden;
}
.axis-card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #2A2420; }
.axis-info  { background: #F7E8E2; }
.axis-ouen  { background: #FBF3DB; }
.axis-shira { background: #E8F0E8; }

.card-stamp {
  position: absolute; top: 12px; right: -4px;
  background: #9E3D26; color: #F5EDD8;
  font-size: 9px; font-weight: 900; letter-spacing: 0.2em;
  padding: 3px 14px; transform: rotate(2deg);
  font-family: 'Shippori Mincho', serif;
}
.card-num {
  font-family: 'Shippori Mincho', serif;
  font-size: 36px; font-weight: 900; color: rgba(42,36,32,0.12);
  line-height: 1; margin-bottom: -4px;
}
.card-icon { font-size: 32px; line-height: 1; }
.card-name {
  font-family: 'Shippori Mincho', serif;
  font-size: 22px; font-weight: 900; color: #2A2420;
  letter-spacing: 0.04em;
}
.card-desc { font-size: 13px; color: #5A4A3A; line-height: 1.85; flex: 1; }
.card-link {
  display: inline-block; margin-top: 8px;
  font-size: 12px; font-weight: 800;
  color: #9E3D26; letter-spacing: 0.08em;
  font-family: 'Shippori Mincho', serif;
  transition: letter-spacing 0.2s;
}
.axis-card:hover .card-link { letter-spacing: 0.14em; }

/* 応援 */
.ouen-section { padding: 72px 0 80px; background: #F5EDD8; }
.cf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.cf-card {
  background: #FBF7EF;
  border: 2px solid #2A2420;
  box-shadow: 3px 3px 0 #2A2420;
  padding: 20px; text-decoration: none; color: inherit;
  display: flex; flex-direction: column; gap: 10px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.cf-card:hover { transform: translate(-1px, -1px); box-shadow: 4px 4px 0 #2A2420; }
.cf-card--ended { opacity: 0.6; }
.cf-tags { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.cf-area {
  font-size: 10px; font-weight: 800; padding: 2px 8px;
  background: #F7E8E2; color: #9E3D26; border: 1px solid #9E3D26;
  font-family: 'Shippori Mincho', serif;
}
.cf-cat { font-size: 10px; font-weight: 600; padding: 2px 8px; background: #EDE3CC; color: #5A4A3A; border: 1px solid #8A7A6A; }
.cf-urgent { font-size: 10px; font-weight: 700; padding: 2px 8px; background: #2A2420; color: #D4A02A; margin-left: auto; }
.cf-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 15px; font-weight: 800; color: #2A2420; line-height: 1.65;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.cf-summary { font-size: 12.5px; color: #5A4A3A; line-height: 1.75; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.cf-bar-row { display: flex; align-items: center; gap: 8px; }
.cf-bar { flex: 1; height: 8px; background: #EDE3CC; border: 1px solid #8A7A6A; }
.cf-fill { height: 100%; background: #9E3D26; width: 0; animation: fillBar 1s 0.3s ease-out forwards; }
@keyframes fillBar { to { width: var(--pct); } }
.cf-pct { font-size: 13px; font-weight: 900; color: #9E3D26; min-width: 36px; text-align: right; font-family: 'Shippori Mincho', serif; }
.cf-nums { font-size: 12px; color: #5A4A3A; }
.cf-nums b { font-size: 15px; font-weight: 800; color: #2A2420; margin-right: 4px; }
.cf-purchase-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.cf-purchase-badge { font-size: 11px; font-weight: 700; padding: 3px 10px; background: #FBF3DB; color: #D4A02A; border: 1px solid #D4A02A; }
.cf-purchase-row b { font-size: 14px; font-weight: 800; color: #2A2420; }
.cf-foot { display: flex; align-items: center; justify-content: space-between; padding-top: 8px; border-top: 1px solid #EDE3CC; font-size: 12px; color: #8A7A6A; }
.cf-cta { font-weight: 800; color: #9E3D26; font-family: 'Shippori Mincho', serif; }

/* Articles */
.articles-section {
  padding: 72px 0 80px;
  background: #FBF7EF;
  border-top: 3px solid #EDE3CC;
  border-bottom: 3px solid #EDE3CC;
}
.article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }

/* Submit CTA */
.submit-section { padding: 72px 0 88px; background: #F5EDD8; }
.submit-board {
  position: relative;
  background: #2A2420;
  border: 3px solid #2A2420;
  padding: 56px 64px;
  display: grid; grid-template-columns: 1fr auto;
  gap: 48px; align-items: center;
  box-shadow: 6px 6px 0 #9E3D26;
}
.board-tape {
  position: absolute;
  width: 60px; height: 18px;
  background: rgba(212,160,42,0.75);
  border: 1px solid rgba(212,160,42,0.4);
}
.bt1 { top: -9px; left: 32px; transform: rotate(-1.5deg); }
.bt2 { top: -9px; right: 80px; transform: rotate(1.5deg); }
.submit-eye { font-size: 10px; letter-spacing: 0.3em; color: #D4A02A; font-weight: 700; margin-bottom: 12px; text-transform: uppercase; font-family: 'Shippori Mincho', serif; }
.submit-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 24px; font-weight: 900; color: #F5EDD8;
  line-height: 1.6; margin-bottom: 14px;
}
.submit-body { font-size: 13.5px; color: #8A7A6A; line-height: 2; max-width: 480px; }
.submit-actions { display: flex; flex-direction: column; gap: 12px; flex-shrink: 0; }
.sbtn {
  padding: 14px 28px; font-size: 13px; font-weight: 800;
  text-align: center; white-space: nowrap; letter-spacing: 0.06em;
  font-family: 'Shippori Mincho', serif;
  transition: all 0.2s;
}
.sbtn--primary { background: #D4A02A; color: #2A2420; border: 2px solid #D4A02A; box-shadow: 3px 3px 0 #9E3D26; }
.sbtn--primary:hover { background: #E0AD30; transform: translate(-1px, -1px); box-shadow: 4px 4px 0 #9E3D26; }
.sbtn--ghost { border: 2px solid #5A4A3A; color: #8A7A6A; }
.sbtn--ghost:hover { border-color: #F5EDD8; color: #F5EDD8; }

/* Responsive */
@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .axes-section { padding: 52px 0 60px; }
  .axes-grid { grid-template-columns: 1fr; }
  .ouen-section { padding: 52px 0 60px; }
  .cf-grid { grid-template-columns: 1fr; }
  .articles-section { padding: 52px 0 60px; }
  .article-grid { grid-template-columns: 1fr; }
  .submit-section { padding: 52px 0 64px; }
  .submit-board { padding: 36px 24px; grid-template-columns: 1fr; gap: 24px; }
  .sec-head { gap: 12px; }
  .sec-note { text-align: left; }
  .sec-title { font-size: 21px; }
  .ticker-tag { font-size: 8px; padding: 0 10px; }
}
@media (max-width: 480px) {
  .submit-actions { flex-direction: row; flex-wrap: wrap; }
  .sbtn { padding: 12px 20px; font-size: 12px; }
  .card-name { font-size: 18px; }
}
</style>
