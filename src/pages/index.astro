---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const investigations = sorted.filter(a => a.data.investigation);
const regularArticles = sorted.filter(a => !a.data.investigation).slice(0, 3);
const featuredArticles = investigations.length > 0 ? investigations.slice(0, 3) : regularArticles;

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 9);

const ticks = [
  '🟢 函館の新店情報を毎日追跡中',
  '⚫ 閉店情報もリアルタイムで更新',
  '📐 誰も測っていないことを、測る',
  '📊 データが事実を語る',
  '🔬 函館 × 一次情報 × ユーモア',
  '🏗 工事中のあの場所、何ができる？',
  '🗞 函館の「今」を、勝手に記録する',
  '🧪 CITY EXPERIMENT REPORT',
];

const NEWS_BADGE: Record<string, { bg: string; color: string; label: string }> = {
  '開店':   { bg: '#1a5c2e', color: '#a8f0c0', label: '開店' },
  '閉店':   { bg: '#1a1a1a', color: '#d4d4d4', label: '閉店' },
  '工事中': { bg: '#4a3800', color: '#f5c842', label: '工事中' },
  'イベント': { bg: '#2c1a4a', color: '#c4a0f0', label: 'EVENT' },
  '目撃情報': { bg: '#0d2d52', color: '#80b8e8', label: '目撃' },
  'その他': { bg: '#2a2a2a', color: '#a0a0a0', label: 'NEWS' },
};
---

<BaseLayout
  title="函館を、勝手に測る。"
  description="函館の当たり前を、勝手に測って証明するデータ・ジャーナリズム・メディア。開店・閉店情報も毎日追跡。">
  <Header />

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-grid-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="hero-label">KATTENI HAKODATE</span>
        <span class="hero-sep">—</span>
        <span class="hero-label">CITY EXPERIMENT REPORT</span>
      </div>

      <h1 class="hero-title">
        <span class="hero-line1">函館を、</span>
        <span class="hero-line2">勝手に<em>測る</em>。</span>
      </h1>

      <p class="hero-sub">
        誰も測っていないものを、私たちが測る。<br>
        <span class="hero-quote">「私が言ったんじゃない、数字がそう言っている。」</span>
      </p>

      <div class="hero-actions">
        <a href="/articles" class="hero-btn hero-btn--primary">調査報告を読む →</a>
        <a href="/news" class="hero-btn hero-btn--ghost">ニュースを見る</a>
      </div>
    </div>

    <div class="hero-data-strip" aria-hidden="true">
      <span>HAKODATE</span>
      <span>北海道函館市</span>
      <span>SINCE 2025</span>
      <span>PRIMARY DATA JOURNALISM</span>
      <span>独自調査</span>
      <span>一次情報</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TICKER — 開店・閉店速報
  ═══════════════════════════════════════════ -->
  <div class="ticker-wrap">
    <span class="ticker-tag">速報</span>
    <div class="ticker-track">
      <div class="ticker-run">
        {[...ticks,...ticks].map(t => (
          <span class="t-item">{t}<span class="t-sep">◆</span></span>
        ))}
      </div>
    </div>
  </div>

  <main>

    <!-- ═══════════════════════════════════════════
         調査報告
    ═══════════════════════════════════════════ -->
    <section class="investigations-section">
      <div class="wrap">
        <header class="sec-head">
          <div class="sec-head-left">
            <p class="sec-eye">INVESTIGATION REPORT</p>
            <h2 class="sec-title">調査報告</h2>
          </div>
          <a href="/articles" class="sec-more">すべての調査報告 →</a>
        </header>

        {featuredArticles.length > 0 ? (
          <div class="inv-grid">
            {featuredArticles.map((a, i) => (
              <a href={`/articles/${a.id}`} class={`inv-card ${i === 0 ? 'inv-card--featured' : ''}`}>
                {a.data.experimentNo && (
                  <div class="inv-exp-no">EXP — {a.data.experimentNo}</div>
                )}
                {a.data.finding && (
                  <div class="inv-finding">
                    <span class="inv-finding-num">{a.data.finding}</span>
                    {a.data.findingLabel && (
                      <span class="inv-finding-label">{a.data.findingLabel}</span>
                    )}
                  </div>
                )}
                <h3 class="inv-title">{a.data.title}</h3>
                <p class="inv-desc">{a.data.description}</p>
                <div class="inv-foot">
                  <span class="inv-cat">{a.data.category}</span>
                  <span class="inv-date">{a.data.date}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="inv-empty">
            <div class="inv-empty-inner">
              <p class="inv-empty-label">COMING SOON</p>
              <p class="inv-empty-title">最初の調査報告を準備中。</p>
              <p class="inv-empty-body">
                函館の「当たり前」を測りに行っています。<br>
                データが揃い次第、公開します。
              </p>
              <a href="/about" class="inv-empty-link">このメディアについて →</a>
            </div>
          </div>
        )}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         ニュース — 開店・閉店
    ═══════════════════════════════════════════ -->
    <section class="news-section">
      <div class="wrap">
        <header class="sec-head">
          <div class="sec-head-left">
            <p class="sec-eye">DAILY NEWS</p>
            <h2 class="sec-title">函館の開店・閉店</h2>
          </div>
          <a href="/news" class="sec-more">すべて見る →</a>
        </header>

        <div class="news-list">
          {recentNews.map(n => {
            const badge = NEWS_BADGE[n.data.type] || NEWS_BADGE['その他'];
            return (
              <a href={`/news/${n.id}`} class="news-item">
                <span class="news-badge" style={`background:${badge.bg}; color:${badge.color};`}>
                  {badge.label}
                </span>
                <span class="news-area">{n.data.area}</span>
                <span class="news-title">{n.data.title}</span>
                <span class="news-date">{n.data.date}</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         CONCEPT STRIP
    ═══════════════════════════════════════════ -->
    <section class="concept-strip">
      <div class="wrap">
        <div class="concept-inner">
          <p class="concept-quote">「最高のユーモアは、常に冷徹な事実に基づいている。」</p>
          <p class="concept-body">
            函館に住んでいるから、現地で測れる。<br>
            測ったから、証明できる。<br>
            証明したから、記録として残る。
          </p>
          <a href="/about" class="concept-link">カッテニハコダテとは何か →</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         情報投稿 CTA
    ═══════════════════════════════════════════ -->
    <section class="submit-section">
      <div class="wrap">
        <div class="submit-inner">
          <div class="submit-text">
            <p class="submit-eye">YOUR INTEL</p>
            <h2 class="submit-title">「そういえばあの店が…」<br>その情報が、次の調査になる。</h2>
            <p class="submit-body">
              開店・閉店・工事中・気になる変化——なんでも送ってください。<br>
              現地確認して、データにします。
            </p>
          </div>
          <div class="submit-actions">
            <a href="/submit" class="sbtn sbtn--primary">情報を送る ＋</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>


<style>
/* ═══════════════════════════════════
   HERO
═══════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100svh;
  background: #080e1a;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding: 120px 0 80px;
}
.hero-grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(13,45,82,0.2) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13,45,82,0.2) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}
.hero-inner {
  position: relative;
  max-width: 1200px; margin: 0 auto;
  padding: 0 48px;
  flex: 1;
  display: flex; flex-direction: column; justify-content: center;
}
.hero-eyebrow {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 32px;
}
.hero-label {
  font-size: 10px; letter-spacing: 0.35em; font-weight: 700;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
}
.hero-sep { color: rgba(13,138,135,0.5); font-size: 10px; }

.hero-title {
  display: flex; flex-direction: column;
  margin-bottom: 32px;
}
.hero-line1 {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.04em;
  line-height: 1.2;
}
.hero-line2 {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(56px, 9vw, 120px);
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.01em;
  line-height: 1.0;
}
.hero-line2 em {
  font-style: normal;
  color: #0d8a87;
}

.hero-sub {
  font-size: 14px; color: rgba(255,255,255,0.45);
  line-height: 2; margin-bottom: 40px;
  max-width: 500px;
}
.hero-quote {
  display: block;
  font-family: 'Shippori Mincho', serif;
  font-size: 13px;
  color: rgba(13,138,135,0.7);
  margin-top: 6px;
  letter-spacing: 0.03em;
}

.hero-actions {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
}
.hero-btn {
  display: inline-flex; align-items: center;
  padding: 14px 28px;
  font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
  font-family: 'Shippori Mincho', serif;
  transition: all 0.2s;
}
.hero-btn--primary {
  background: #0d8a87; color: #ffffff;
  border: 2px solid #0d8a87;
}
.hero-btn--primary:hover { background: #0a6e6c; border-color: #0a6e6c; }
.hero-btn--ghost {
  border: 2px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6);
}
.hero-btn--ghost:hover { border-color: rgba(255,255,255,0.5); color: #fff; }

.hero-data-strip {
  position: relative;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 16px 48px;
  display: flex; align-items: center; gap: 32px;
  overflow: hidden;
  margin-top: 60px;
}
.hero-data-strip span {
  font-size: 10px; letter-spacing: 0.25em;
  color: rgba(255,255,255,0.15);
  white-space: nowrap;
  text-transform: uppercase;
  flex-shrink: 0;
}


/* ═══════════════════════════════════
   TICKER
═══════════════════════════════════ */
.ticker-wrap {
  display: flex; align-items: center;
  background: #0d2d52; height: 40px; overflow: hidden;
}
.ticker-tag {
  flex-shrink: 0; background: #0d8a87; color: #fff;
  font-size: 9px; font-weight: 900; letter-spacing: 0.35em;
  padding: 0 16px; height: 100%; display: flex; align-items: center;
  font-family: 'Shippori Mincho', serif;
}
.ticker-track {
  flex: 1; overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
}
.ticker-run { display: flex; animation: tickRoll 40s linear infinite; white-space: nowrap; }
@keyframes tickRoll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.t-item { display: inline-flex; align-items: center; gap: 8px; padding: 0 28px; font-size: 11px; color: rgba(255,255,255,0.45); font-weight: 500; }
.t-sep { font-size: 4px; color: #0d8a87; margin-left: 8px; }


/* ═══════════════════════════════════
   SHARED
═══════════════════════════════════ */
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
.sec-head {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 40px; gap: 16px;
}
.sec-eye {
  font-size: 9px; letter-spacing: 0.4em; font-weight: 700;
  color: #0d8a87; text-transform: uppercase; margin-bottom: 6px;
}
.sec-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 28px; font-weight: 900;
  color: #0d0d0d; letter-spacing: 0.03em;
}
.sec-more {
  font-size: 12px; color: #0d8a87; font-weight: 700;
  border-bottom: 1px solid currentColor; padding-bottom: 2px;
  white-space: nowrap; transition: opacity 0.2s;
  font-family: 'Shippori Mincho', serif; letter-spacing: 0.05em;
}
.sec-more:hover { opacity: 0.65; }


/* ═══════════════════════════════════
   調査報告
═══════════════════════════════════ */
.investigations-section {
  padding: 88px 0 96px;
  background: #f7f8fa;
  border-bottom: 1px solid #e4e8ed;
}
.inv-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: #d0d6de;
  border: 1px solid #d0d6de;
}
.inv-card {
  background: #ffffff;
  padding: 32px 28px;
  text-decoration: none;
  display: flex; flex-direction: column; gap: 12px;
  transition: background 0.2s;
  min-height: 280px;
}
.inv-card:hover { background: #f0f4f8; }
.inv-card--featured {
  grid-column: 1 / -1;
  flex-direction: row;
  align-items: flex-start;
  gap: 48px;
  min-height: 200px;
  background: #080e1a;
}
.inv-card--featured:hover { background: #0d1525; }
.inv-card--featured .inv-exp-no { color: rgba(13,138,135,0.7); }
.inv-card--featured .inv-finding-num { color: #0d8a87; font-size: clamp(40px, 5vw, 72px); }
.inv-card--featured .inv-finding-label { color: rgba(255,255,255,0.4); }
.inv-card--featured .inv-title { color: #ffffff; font-size: 22px; }
.inv-card--featured .inv-desc { color: rgba(255,255,255,0.45); }
.inv-card--featured .inv-cat { color: rgba(255,255,255,0.3); border-color: rgba(255,255,255,0.1); }
.inv-card--featured .inv-date { color: rgba(255,255,255,0.25); }

.inv-exp-no {
  font-size: 9px; letter-spacing: 0.3em; font-weight: 700;
  color: #0d8a87; text-transform: uppercase;
}
.inv-finding {
  display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;
}
.inv-finding-num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(32px, 4vw, 48px); font-weight: 900;
  color: #0d2d52; line-height: 1;
}
.inv-finding-label {
  font-size: 11px; color: #6c757d; letter-spacing: 0.05em;
}
.inv-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 17px; font-weight: 800;
  color: #0d0d0d; line-height: 1.55;
  flex: 1;
}
.inv-desc {
  font-size: 13px; color: #6c757d; line-height: 1.8;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
  overflow: hidden;
}
.inv-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: auto; padding-top: 16px;
  border-top: 1px solid #e4e8ed;
}
.inv-cat {
  font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
  color: #3d4a52; border: 1px solid #d0d6de;
  padding: 2px 8px;
}
.inv-date { font-size: 11px; color: #a0a8b0; }

.inv-empty {
  background: #080e1a;
  border: 1px solid #1a2840;
  padding: 80px 48px;
  text-align: center;
}
.inv-empty-label {
  font-size: 9px; letter-spacing: 0.4em; color: #0d8a87;
  font-weight: 700; text-transform: uppercase; margin-bottom: 16px;
}
.inv-empty-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 28px; font-weight: 800; color: #ffffff;
  margin-bottom: 16px;
}
.inv-empty-body {
  font-size: 14px; color: rgba(255,255,255,0.35);
  line-height: 2; margin-bottom: 32px;
}
.inv-empty-link {
  font-size: 13px; color: #0d8a87; font-weight: 700;
  border-bottom: 1px solid #0d8a87; padding-bottom: 2px;
  font-family: 'Shippori Mincho', serif;
}


/* ═══════════════════════════════════
   NEWS
═══════════════════════════════════ */
.news-section {
  padding: 88px 0 96px;
  background: #ffffff;
  border-bottom: 1px solid #e4e8ed;
}
.news-list {
  display: flex; flex-direction: column;
  border-top: 1px solid #e4e8ed;
}
.news-item {
  display: grid;
  grid-template-columns: 60px 100px 1fr 80px;
  align-items: center; gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid #f0f2f4;
  text-decoration: none;
  transition: background 0.15s;
}
.news-item:hover { background: #f7f8fa; margin: 0 -16px; padding-left: 16px; padding-right: 16px; }
.news-badge {
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 800; letter-spacing: 0.15em;
  padding: 3px 6px; text-align: center;
  white-space: nowrap;
}
.news-area { font-size: 11px; color: #8a9099; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.news-title { font-size: 13.5px; color: #0d0d0d; line-height: 1.5; font-weight: 500; }
.news-date { font-size: 11px; color: #a0a8b0; text-align: right; white-space: nowrap; }


/* ═══════════════════════════════════
   CONCEPT STRIP
═══════════════════════════════════ */
.concept-strip {
  padding: 88px 0;
  background: #0d2d52;
}
.concept-inner {
  max-width: 720px; margin: 0 auto;
  text-align: center;
}
.concept-quote {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(16px, 2.5vw, 22px);
  font-weight: 700; color: rgba(255,255,255,0.9);
  line-height: 1.7; letter-spacing: 0.03em;
  margin-bottom: 28px;
}
.concept-body {
  font-size: 14px; color: rgba(255,255,255,0.45);
  line-height: 2.2; margin-bottom: 36px;
}
.concept-link {
  font-size: 13px; color: #0d8a87; font-weight: 700;
  border-bottom: 1px solid #0d8a87; padding-bottom: 2px;
  font-family: 'Shippori Mincho', serif;
  transition: opacity 0.2s;
}
.concept-link:hover { opacity: 0.7; }


/* ═══════════════════════════════════
   SUBMIT
═══════════════════════════════════ */
.submit-section { padding: 88px 0; background: #f7f8fa; }
.submit-inner {
  display: grid; grid-template-columns: 1fr auto;
  align-items: center; gap: 48px;
  border: 1px solid #d0d6de;
  padding: 48px;
  background: #ffffff;
}
.submit-eye {
  font-size: 9px; letter-spacing: 0.4em; font-weight: 700;
  color: #0d8a87; text-transform: uppercase; margin-bottom: 12px;
}
.submit-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 22px; font-weight: 800; color: #0d0d0d;
  line-height: 1.6; margin-bottom: 12px;
}
.submit-body { font-size: 13px; color: #6c757d; line-height: 2; }
.sbtn {
  display: inline-flex; align-items: center;
  padding: 14px 28px;
  font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
  font-family: 'Shippori Mincho', serif;
  white-space: nowrap; transition: all 0.2s;
}
.sbtn--primary {
  background: #0d8a87; color: #ffffff;
  border: 2px solid #0d8a87;
}
.sbtn--primary:hover { background: #0a6e6c; }


/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media (max-width: 960px) {
  .wrap { padding: 0 24px; }
  .hero-inner { padding: 0 24px; }
  .hero-data-strip { padding: 16px 24px; gap: 20px; }
  .inv-grid { grid-template-columns: 1fr; }
  .inv-card--featured { flex-direction: column; grid-column: 1; gap: 16px; }
  .news-item { grid-template-columns: 56px 1fr; grid-template-rows: auto auto; }
  .news-area { display: none; }
  .news-date { grid-column: 2; font-size: 10px; text-align: left; }
  .submit-inner { grid-template-columns: 1fr; gap: 24px; }
}
@media (max-width: 600px) {
  .hero { padding: 100px 0 60px; }
  .investigations-section, .news-section, .concept-strip, .submit-section { padding: 60px 0; }
  .inv-card { padding: 24px 20px; }
  .inv-empty { padding: 48px 24px; }
