---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="勝手に情報収集" description="函館・道南の開店・閉店・街の変化情報を勝手に集めてお届けします。">
  <Header />

  <main class="news-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="hero-texture" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <span class="hero-stamp">勝手に</span>
        <p class="hero-eye">📋 情報収集</p>
        <h1 class="hero-title">勝手に情報収集</h1>
        <p class="hero-sub">
          函館・道南の「新しいもの」を全部キャッチします。<br>
          開店・閉店・街の変化・工事中の謎スポットまで。
        </p>
      </div>
    </div>

    <!-- Coming Soon -->
    <div class="wrap">
      <div class="coming-board">
        <div class="board-tape t1" aria-hidden="true"></div>
        <div class="board-tape t2" aria-hidden="true"></div>
        <div class="board-tape t3" aria-hidden="true"></div>

        <div class="coming-inner">
          <p class="coming-num">COMING SOON</p>
          <p class="coming-icon">🏗</p>
          <h2 class="coming-title">工事中です</h2>
          <p class="coming-sub">
            函館市内の開店・閉店・街の変化情報を毎日集めるコーナーを準備中！<br>
            <br>
            X（旧Twitter）や読者からの投稿をもとに、<br>
            函館の「今」をリアルタイムでお届けします。
          </p>

          <div class="sources">
            <p class="sources-title">情報収集元（予定）</p>
            <div class="sources-list">
              <div class="source-item">
                <span class="source-icon">𝕏</span>
                <div>
                  <p class="source-name">#函館 / #函館グルメ</p>
                  <p class="source-desc">X（Twitter）の函館タグをリアルタイム監視</p>
                </div>
              </div>
              <div class="source-item">
                <span class="source-icon">👥</span>
                <div>
                  <p class="source-name">Facebook 函館グループ</p>
                  <p class="source-desc">地域コミュニティからの情報収集</p>
                </div>
              </div>
              <div class="source-item">
                <span class="source-icon">📩</span>
                <div>
                  <p class="source-name">読者投稿</p>
                  <p class="source-desc">「見た！」「気になる！」情報をお寄せください</p>
                </div>
              </div>
            </div>
          </div>

          <div class="coming-cta-wrap">
            <p class="cta-label">情報提供はこちら</p>
            <a href="/submit" class="coming-cta">情報を投稿する ＋</a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
.news-page { background: #F5EDD8; min-height: 100vh; }
.wrap { max-width: 900px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: #9E3D26;
  padding: 96px 0 64px;
}
.hero-texture {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 28px, rgba(0,0,0,0.07) 28px, rgba(0,0,0,0.07) 30px),
    repeating-linear-gradient(90deg, transparent, transparent 56px, rgba(0,0,0,0.05) 56px, rgba(0,0,0,0.05) 58px);
  background-size: 58px 30px;
}
.page-hero-inner { position: relative; z-index: 1; }
.hero-stamp {
  display: inline-block; background: #D4A02A; color: #2A2420;
  font-size: 10px; font-weight: 900; letter-spacing: 0.3em;
  padding: 4px 16px; transform: rotate(-1.5deg);
  font-family: 'Shippori Mincho', serif;
  border: 2px solid #2A2420; margin-bottom: 16px;
}
.hero-eye { font-size: 11px; letter-spacing: 0.3em; color: rgba(245,237,216,0.6); font-weight: 700; margin-bottom: 10px; }
.hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(28px, 5vw, 48px); font-weight: 900;
  color: #F5EDD8; letter-spacing: 0.04em; margin-bottom: 16px;
}
.hero-sub { font-size: 14px; color: rgba(245,237,216,0.75); line-height: 2; }

/* Coming board */
.coming-board {
  position: relative;
  background: #FBF7EF;
  border: 2px solid #2A2420;
  box-shadow: 6px 6px 0 #9E3D26;
  margin: 56px 0 80px;
  padding: 56px 48px;
}
.board-tape {
  position: absolute;
  height: 20px;
  background: rgba(212,160,42,0.7);
  border: 1px solid rgba(42,36,32,0.2);
}
.t1 { width: 56px; top: -10px; left: 28px; transform: rotate(-1.5deg); }
.t2 { width: 48px; top: -10px; right: 48px; transform: rotate(1.5deg); }
.t3 { width: 40px; bottom: -10px; right: 120px; transform: rotate(-1deg); }

.coming-inner { text-align: center; }
.coming-num {
  font-size: 10px; letter-spacing: 0.4em;
  color: #8A7A6A; font-weight: 700;
  text-transform: uppercase; margin-bottom: 16px;
}
.coming-icon { font-size: 56px; margin-bottom: 12px; }
.coming-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 32px; font-weight: 900;
  color: #2A2420; margin-bottom: 20px;
  letter-spacing: 0.04em;
}
.coming-sub {
  font-size: 14px; color: #5A4A3A;
  line-height: 2; margin-bottom: 40px;
}

/* Sources */
.sources {
  background: #EDE3CC;
  border: 1px solid #8A7A6A;
  padding: 24px 28px;
  text-align: left;
  margin-bottom: 36px;
}
.sources-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 11px; font-weight: 800;
  color: #9E3D26; letter-spacing: 0.2em;
  text-transform: uppercase; margin-bottom: 16px;
}
.sources-list { display: flex; flex-direction: column; gap: 16px; }
.source-item { display: flex; align-items: flex-start; gap: 16px; }
.source-icon {
  width: 36px; height: 36px; flex-shrink: 0;
  background: #2A2420; color: #F5EDD8;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700;
}
.source-name { font-size: 14px; font-weight: 700; color: #2A2420; margin-bottom: 2px; font-family: 'Shippori Mincho', serif; }
.source-desc { font-size: 12px; color: #8A7A6A; }

/* CTA */
.cta-label { font-size: 11px; letter-spacing: 0.2em; color: #8A7A6A; margin-bottom: 12px; }
.coming-cta {
  display: inline-block; padding: 14px 32px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420;
  box-shadow: 3px 3px 0 #2A2420;
  font-size: 14px; font-weight: 800;
  font-family: 'Shippori Mincho', serif;
  letter-spacing: 0.06em;
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
}
.coming-cta:hover { background: #B84A2E; transform: translate(-1px, -1px); box-shadow: 4px 4px 0 #2A2420; }

/* Responsive */
@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 88px 0 48px; }
  .coming-board { padding: 36px 20px; margin: 36px 0 56px; }
  .coming-title { font-size: 24px; }
}
</style>
