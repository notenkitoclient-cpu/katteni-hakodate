---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection, render } from 'astro:content';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const TYPE_CONFIG: Record<string, { label: string; color: string; bg: string }> = {
  '開店':   { label: '開店',   color: '#F5EDD8', bg: '#2A7A3A' },
  '閉店':   { label: '閉店',   color: '#F5EDD8', bg: '#2A2420' },
  '工事中': { label: '工事中', color: '#2A2420', bg: '#D4A02A' },
  'イベント': { label: 'EVENT', color: '#F5EDD8', bg: '#9E3D26' },
  '目撃情報': { label: '目撃',  color: '#F5EDD8', bg: '#3D6B9E' },
  'その他':  { label: 'INFO',  color: '#2A2420', bg: '#C8BEA8' },
};

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}/${d.getDate()}`;
}
---

<BaseLayout title="勝手に情報収集" description="函館・道南の開店・閉店・街の変化情報を勝手に集めてお届けします。">
  <Header />

  <main class="news-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="hero-texture" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <span class="hero-stamp">勝手に</span>
        <p class="hero-eye">📋 情報収集</p>
        <h1 class="hero-title">勝手に情報収集</h1>
        <p class="hero-sub">
          函館・道南の「新しいもの」を全部キャッチします。<br>
          開店・閉店・街の変化・工事中の謎スポットまで。
        </p>
      </div>
    </div>

    <div class="wrap">

      <!-- フィルターバー -->
      <div class="filter-bar">
        <div class="filter-count">
          <span class="count-num" id="count-num">{sorted.length}</span>
          <span class="count-label">件</span>
        </div>
        <div class="filter-btns">
          <button class="filter-btn active" data-type="all">すべて</button>
          {Object.entries(TYPE_CONFIG).map(([key, cfg]) => (
            <button
              class="filter-btn"
              data-type={key}
              style={`--badge-bg:${cfg.bg}; --badge-color:${cfg.color}`}
            >{cfg.label}</button>
          ))}
        </div>
      </div>

      <!-- ニュースリスト -->
      {sorted.length === 0 ? (
        <div class="empty-state">
          <p class="empty-icon">📭</p>
          <p class="empty-text">まだ情報がありません。一番乗りで教えてください！</p>
          <a href="/submit" class="empty-cta">情報を投稿する ＋</a>
        </div>
      ) : (
        <div class="news-list">
          {sorted.map(async (item) => {
            const { Content } = await render(item);
            const cfg = TYPE_CONFIG[item.data.type] ?? TYPE_CONFIG['その他'];
            return (
              <article class="news-card" data-type={item.data.type} onclick={`location.href='/news/${item.id}'`} style="cursor:pointer;">
                <div class="card-left">
                  <span class="type-badge" style={`background:${cfg.bg}; color:${cfg.color}`}>
                    {cfg.label}
                  </span>
                  <span class="card-date">{formatDate(item.data.date)}</span>
                </div>
                <div class="card-body">
                  <div class="card-meta">
                    <span class="card-area">📍 {item.data.area}</span>
                    <span class="card-reporter">by {item.data.reporter}</span>
                  </div>
                  <h2 class="card-title"><a href={`/news/${item.id}`}>{item.data.title}</a></h2>
                  <div class="card-content">
                    <Content />
                  </div>
                  {item.data.source && (
                    <a href={item.data.source} target="_blank" rel="noopener" class="card-source">
                      情報元 ↗
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )}

      <!-- 投稿CTA -->
      <div class="cta-board">
        <div class="board-tape t1" aria-hidden="true"></div>
        <div class="board-tape t2" aria-hidden="true"></div>
        <div class="cta-inner">
          <div class="cta-text">
            <p class="cta-title">「見た！」情報、募集中</p>
            <p class="cta-desc">
              開店・閉店・工事中の謎スポット・気になる出来事など、<br>
              あなたが見た函館の変化を教えてください。
            </p>
          </div>
          <a href="/submit" class="cta-btn">情報を投稿する ＋</a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
.news-page { background: #F5EDD8; min-height: 100vh; }
.wrap { max-width: 800px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: #9E3D26; padding: 96px 0 64px;
}
.hero-texture {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 28px, rgba(0,0,0,0.07) 28px, rgba(0,0,0,0.07) 30px),
    repeating-linear-gradient(90deg, transparent, transparent 56px, rgba(0,0,0,0.05) 56px, rgba(0,0,0,0.05) 58px);
  background-size: 58px 30px;
}
.page-hero-inner { position: relative; z-index: 1; }
.hero-stamp {
  display: inline-block; background: #D4A02A; color: #2A2420;
  font-size: 10px; font-weight: 900; letter-spacing: 0.3em;
  padding: 4px 16px; transform: rotate(-1.5deg);
  font-family: 'Shippori Mincho', serif;
  border: 2px solid #2A2420; margin-bottom: 16px;
}
.hero-eye { font-size: 11px; letter-spacing: 0.3em; color: rgba(245,237,216,0.6); font-weight: 700; margin-bottom: 10px; }
.hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(28px, 5vw, 48px); font-weight: 900;
  color: #F5EDD8; letter-spacing: 0.04em; margin-bottom: 16px;
}
.hero-sub { font-size: 14px; color: rgba(245,237,216,0.75); line-height: 2; }

/* フィルターバー */
.filter-bar {
  display: flex; align-items: center; gap: 16px;
  padding: 20px 0 16px;
  border-bottom: 2px solid #2A2420;
  margin-bottom: 24px;
  flex-wrap: wrap;
}
.filter-count { display: flex; align-items: baseline; gap: 4px; flex-shrink: 0; }
.count-num {
  font-family: 'Shippori Mincho', serif;
  font-size: 28px; font-weight: 900; color: #9E3D26;
}
.count-label { font-size: 12px; color: #8A7A6A; }
.filter-btns { display: flex; gap: 6px; flex-wrap: wrap; }
.filter-btn {
  font-size: 11px; font-weight: 800; letter-spacing: 0.06em;
  padding: 5px 12px; cursor: pointer;
  border: 2px solid #2A2420;
  background: transparent; color: #2A2420;
  font-family: 'Shippori Mincho', serif;
  transition: background 0.15s, color 0.15s;
}
.filter-btn:hover { background: #EDE3CC; }
.filter-btn.active {
  background: var(--badge-bg, #2A2420);
  color: var(--badge-color, #F5EDD8);
}
.filter-btn[data-type="all"].active { background: #2A2420; color: #F5EDD8; }
.news-card.hidden { display: none; }

/* ニュースリスト */
.news-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 56px; }

.news-card {
  display: flex; gap: 20px; align-items: flex-start;
  padding: 20px 0;
  border-bottom: 1px solid rgba(42,36,32,0.15);
}
.news-card:first-child { border-top: none; }

.card-left {
  display: flex; flex-direction: column; align-items: center;
  gap: 6px; flex-shrink: 0; width: 52px;
  padding-top: 3px;
}
.type-badge {
  font-size: 9px; font-weight: 900; letter-spacing: 0.06em;
  padding: 4px 6px; text-align: center;
  width: 100%;
  font-family: 'Shippori Mincho', serif;
}
.card-date {
  font-size: 11px; color: #8A7A6A; font-weight: 700;
  letter-spacing: 0.04em; white-space: nowrap;
}

.card-body { flex: 1; min-width: 0; }
.card-meta {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 6px;
}
.card-area { font-size: 11px; color: #9E3D26; font-weight: 700; letter-spacing: 0.04em; }
.card-reporter { font-size: 11px; color: #8A7A6A; }
.card-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 16px; font-weight: 800;
  color: #2A2420; line-height: 1.5;
  margin-bottom: 8px;
}
.card-title a { color: inherit; }
.card-title a:hover { color: #9E3D26; }
.card-content {
  font-size: 13px; color: #5A4A3A; line-height: 1.8;
}
.card-content p { margin: 0; }
.card-source {
  display: inline-block; margin-top: 8px;
  font-size: 11px; color: #9E3D26; font-weight: 700;
  border-bottom: 1px solid currentColor;
}

/* 空状態 */
.empty-state {
  text-align: center; padding: 80px 0;
}
.empty-icon { font-size: 48px; margin-bottom: 16px; }
.empty-text { font-size: 14px; color: #5A4A3A; margin-bottom: 24px; }
.empty-cta {
  display: inline-block; padding: 12px 28px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420; font-weight: 800;
  font-family: 'Shippori Mincho', serif;
}

/* 投稿CTA */
.cta-board {
  position: relative;
  background: #FBF7EF;
  border: 2px solid #2A2420;
  box-shadow: 5px 5px 0 #9E3D26;
  padding: 32px 36px;
  margin-bottom: 80px;
}
.board-tape {
  position: absolute; height: 18px;
  background: rgba(212,160,42,0.75);
  border: 1px solid rgba(42,36,32,0.25);
}
.t1 { width: 52px; top: -9px; left: 28px; transform: rotate(-1.5deg); }
.t2 { width: 44px; top: -9px; right: 52px; transform: rotate(1.5deg); }

.cta-inner { display: flex; align-items: center; gap: 32px; }
.cta-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 18px; font-weight: 900; color: #2A2420; margin-bottom: 8px;
}
.cta-desc { font-size: 13px; color: #5A4A3A; line-height: 1.8; }
.cta-btn {
  flex-shrink: 0;
  display: inline-block; padding: 14px 24px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420;
  box-shadow: 3px 3px 0 #2A2420;
  font-size: 14px; font-weight: 900;
  font-family: 'Shippori Mincho', serif;
  letter-spacing: 0.06em; white-space: nowrap;
  transition: transform 0.15s, box-shadow 0.15s;
}
.cta-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #2A2420; }

@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 88px 0 48px; }
  .cta-inner { flex-direction: column; align-items: flex-start; gap: 20px; }
  .filter-bar { gap: 12px; }
}
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.news-card');
  const countEl = document.getElementById('count-num');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const type = btn.dataset.type;
      let visible = 0;
      cards.forEach(card => {
        const match = type === 'all' || card.dataset.type === type;
        card.classList.toggle('hidden', !match);
        if (match) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
    });
  });
</script>
