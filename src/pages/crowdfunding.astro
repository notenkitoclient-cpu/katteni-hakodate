---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('crowdfunding');
const sorted = all.sort((a, b) => new Date(a.data.endDate).getTime() - new Date(b.data.endDate).getTime());

function daysLeft(dateStr: string) {
  const end = new Date(dateStr);
  const now = new Date();
  return Math.max(0, Math.ceil((end.getTime() - now.getTime()) / 86400000));
}
function pct(current: number, goal: number) {
  if (!goal) return null;
  return Math.min(100, Math.round((current / goal) * 100));
}
function fmtYen(n: number) {
  return n.toLocaleString('ja-JP') + '円';
}
---

<BaseLayout title="勝手に応援団" description="道南エリアのクラウドファンディング・地域プロジェクトを勝手に紹介・応援します！">
  <Header />

  <main class="cf-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="page-hero-bg" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <div class="stamp-label">勝手に</div>
        <p class="page-eye">💰 Support Projects</p>
        <h1 class="page-title">勝手に応援団</h1>
        <p class="page-sub">
          道南エリア（函館・北斗・七飯ほか）の<br>
          クラウドファンディング・地域プロジェクトを勝手に発掘して応援します。
        </p>
        <div class="page-tags">
          <span class="ptag">函館</span>
          <span class="ptag">北斗市</span>
          <span class="ptag">七飯町</span>
          <span class="ptag">道南エリア</span>
        </div>
      </div>
    </div>

    <!-- List -->
    <div class="cf-list wrap">

      {sorted.length === 0 ? (
        <div class="empty">
          <p class="empty-icon">💰</p>
          <p class="empty-title">現在紹介中のプロジェクトはありません</p>
          <p class="empty-sub">道南のクラファン情報をご存知の方はぜひ教えてください！</p>
          <a href="/submit" class="empty-btn">情報を投稿する →</a>
        </div>
      ) : sorted.map(cf => {
        const p = pct(cf.data.currentAmount, cf.data.goalAmount);
        const days = daysLeft(cf.data.endDate);
        const ended = days === 0;
        const isPurchaseType = !cf.data.goalAmount;
        return (
          <article class={`cf-card ${ended ? 'cf-card--ended' : ''}`}>
            <div class="cf-card-inner">

              <!-- Left: Info -->
              <div class="cf-info">
                <div class="cf-meta">
                  <span class="cf-area">{cf.data.area}</span>
                  <span class="cf-cat">{cf.data.category}</span>
                  {isPurchaseType && <span class="cf-purchase">応援購入型</span>}
                  {!ended && days <= 7 && <span class="cf-urgent">🔥 残り{days}日</span>}
                  {ended && <span class="cf-ended">終了</span>}
                </div>
                <h2 class="cf-title">{cf.data.title}</h2>
                <p class="cf-summary">{cf.data.summary}</p>
                <p class="cf-owner">主催：{cf.data.owner}</p>
              </div>

              <!-- Right: Progress -->
              <div class="cf-progress">
                {p !== null ? (
                  <>
                    <div class="cf-pct-num">{p}<span>%</span></div>
                    <div class="cf-bar-wrap">
                      <div class="cf-bar">
                        <div class="cf-fill" style={`--pct: ${p}%`}></div>
                      </div>
                    </div>
                    <div class="cf-amounts">
                      <p class="cf-current">{fmtYen(cf.data.currentAmount)}</p>
                      <p class="cf-goal">目標 {fmtYen(cf.data.goalAmount)}</p>
                    </div>
                  </>
                ) : (
                  <div class="cf-purchase-info">
                    <p class="cf-purchase-icon">🎫</p>
                    <p class="cf-purchase-label">応援購入型</p>
                    <p class="cf-current">{fmtYen(cf.data.currentAmount)} 集まっています</p>
                  </div>
                )}
                <div class="cf-sub-stats">
                  <div class="cf-sub-stat">
                    <b>{cf.data.supporterCount}</b>
                    <span>人が支援</span>
                  </div>
                  <div class="cf-sub-stat">
                    <b>{ended ? '終了' : `${days}日`}</b>
                    <span>{ended ? '' : '残り'}</span>
                  </div>
                </div>
                {!ended && (
                  <a href={cf.data.url} target="_blank" rel="noopener" class="cf-link-btn">
                    詳細を見て応援する ↗
                  </a>
                )}
              </div>

            </div>
          </article>
        );
      })}
    </div>

    <!-- Submit CTA -->
    <div class="submit-band wrap">
      <div class="submit-inner">
        <div>
          <p class="submit-title">道南のクラファン情報を教えてください！</p>
          <p class="submit-sub">「こんなプロジェクトがある」という情報、お待ちしています。勝手に紹介させてもらいます。</p>
        </div>
        <a href="/submit" class="submit-btn">情報を投稿する →</a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
.cf-page { background: #faf7f0; min-height: 100vh; }
.wrap { max-width: 1100px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #c04a28 0%, #e8734a 50%, #f0a060 100%);
  padding: 100px 0 72px;
}
.page-hero-bg {
  position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
  background-size: 24px 24px;
}
.page-hero-inner { position: relative; z-index: 1; }
.stamp-label {
  display: inline-block; background: rgba(255,255,255,0.22); color: white;
  font-size: 10px; font-weight: 900; letter-spacing: 0.25em;
  padding: 4px 14px; border-radius: 2px; transform: rotate(-1deg);
  margin-bottom: 16px;
}
.page-eye { font-size: 11px; letter-spacing: 0.3em; color: rgba(255,255,255,0.7); font-weight: 700; margin-bottom: 10px; }
.page-title { font-family: 'Shippori Mincho', serif; font-size: clamp(32px, 5vw, 52px); font-weight: 900; color: white; letter-spacing: 0.04em; margin-bottom: 16px; }
.page-sub { font-size: 15px; color: rgba(255,255,255,0.82); line-height: 1.9; margin-bottom: 24px; }
.page-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.ptag { background: rgba(255,255,255,0.18); color: white; font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 14px; letter-spacing: 0.06em; }

/* List */
.cf-list { padding: 56px 0 80px; display: flex; flex-direction: column; gap: 20px; }

/* Card */
.cf-card { background: white; border-radius: 16px; border: 1.5px solid #e8eef4; overflow: hidden; transition: box-shadow 0.25s, transform 0.25s; }
.cf-card:hover { transform: translateY(-3px); box-shadow: 0 16px 48px rgba(13,45,82,0.10); }
.cf-card--ended { opacity: 0.65; }
.cf-card-inner { display: grid; grid-template-columns: 1fr 280px; }

/* Info */
.cf-info { padding: 32px 32px 32px 36px; border-right: 1px solid #edf2f6; }
.cf-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.cf-area { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; background: #fff3e0; color: #e8734a; }
.cf-cat { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 4px; background: #e4f5f4; color: #0d8a87; }
.cf-urgent { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; background: #fde; color: #c0304a; }
.cf-ended { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; background: #f0f0f0; color: #888; }
.cf-purchase { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; background: #fff0e8; color: #e8734a; }
.cf-purchase-info { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 0; }
.cf-purchase-icon { font-size: 32px; line-height: 1; }
.cf-purchase-label { font-size: 11px; font-weight: 700; color: #e8734a; letter-spacing: 0.05em; }
.cf-title { font-family: 'Shippori Mincho', serif; font-size: 18px; font-weight: 800; color: #0d2d52; line-height: 1.65; margin-bottom: 12px; }
.cf-summary { font-size: 13.5px; color: #5a7080; line-height: 1.8; margin-bottom: 16px; }
.cf-owner { font-size: 12px; color: #9ab8c8; }

/* Progress */
.cf-progress { padding: 28px 28px 28px 24px; display: flex; flex-direction: column; gap: 12px; background: #fdfbf8; }
.cf-pct-num { font-family: 'Shippori Mincho', serif; font-size: 44px; font-weight: 900; color: #e8734a; line-height: 1; }
.cf-pct-num span { font-size: 20px; }
.cf-bar-wrap {}
.cf-bar { height: 10px; background: #edf2f6; border-radius: 5px; overflow: hidden; }
.cf-fill { height: 100%; background: linear-gradient(90deg,#e8734a,#f0a070); border-radius: 5px; width: 0; animation: fillBar 1.2s 0.3s ease-out forwards; }
@keyframes fillBar { to { width: var(--pct); } }
.cf-amounts {}
.cf-current { font-size: 20px; font-weight: 800; color: #0d2d52; }
.cf-goal { font-size: 11px; color: #9ab8c8; margin-top: 2px; }
.cf-sub-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.cf-sub-stat { background: #f5f8fa; border-radius: 8px; padding: 10px 12px; text-align: center; }
.cf-sub-stat b { display: block; font-size: 18px; font-weight: 800; color: #0d2d52; }
.cf-sub-stat span { font-size: 10px; color: #9ab8c8; letter-spacing: 0.05em; }
.cf-link-btn { display: block; text-align: center; padding: 12px; background: #e8734a; color: white; border-radius: 8px; font-size: 13px; font-weight: 700; letter-spacing: 0.04em; transition: background 0.2s, transform 0.2s; margin-top: auto; }
.cf-link-btn:hover { background: #f0845a; transform: translateY(-1px); }

/* Empty */
.empty { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 48px; margin-bottom: 16px; }
.empty-title { font-family: 'Shippori Mincho', serif; font-size: 20px; font-weight: 700; color: #0d2d52; margin-bottom: 8px; }
.empty-sub { font-size: 14px; color: #7a9aaa; margin-bottom: 28px; }
.empty-btn { display: inline-block; padding: 12px 28px; background: #e8734a; color: white; border-radius: 6px; font-weight: 700; font-size: 14px; }

/* Submit band */
.submit-band { padding-bottom: 80px; }
.submit-inner { background: #0d2d52; border-radius: 14px; padding: 36px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
.submit-title { font-family: 'Shippori Mincho', serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 6px; }
.submit-sub { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.7; }
.submit-btn { flex-shrink: 0; padding: 13px 28px; background: #e8734a; color: white; border-radius: 6px; font-size: 13px; font-weight: 700; white-space: nowrap; transition: background 0.2s; }
.submit-btn:hover { background: #f0845a; }

/* Responsive */
@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 88px 0 52px; }
  .cf-card-inner { grid-template-columns: 1fr; }
  .cf-info { border-right: none; border-bottom: 1px solid #edf2f6; padding: 24px 20px; }
  .cf-progress { padding: 20px; }
  .submit-inner { padding: 24px 20px; flex-direction: column; align-items: flex-start; }
}
</style>
