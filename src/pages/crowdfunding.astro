---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('crowdfunding');
const sorted = all.sort((a, b) => new Date(a.data.endDate).getTime() - new Date(b.data.endDate).getTime());

function daysLeft(dateStr: string) {
  const end = new Date(dateStr);
  const now = new Date();
  return Math.max(0, Math.ceil((end.getTime() - now.getTime()) / 86400000));
}
function pct(current: number, goal: number) {
  if (!goal) return null;
  return Math.min(100, Math.round((current / goal) * 100));
}
function fmtYen(n: number) {
  return n.toLocaleString('ja-JP') + '円';
}
---

<BaseLayout title="勝手に応援" description="道南エリアのクラウドファンディング・地域プロジェクトを勝手に発掘して応援します！">
  <Header />

  <main class="ouen-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="hero-texture" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <span class="hero-stamp">勝手に</span>
        <p class="hero-eye">💰 応援</p>
        <h1 class="hero-title">勝手に応援</h1>
        <p class="hero-sub">
          道南エリア（函館・北斗・七飯ほか）で頑張ってるのに<br>
          目につかないプロジェクトを勝手に発掘して全力で応援します。
        </p>
        <div class="hero-tags">
          <span class="htag">函館</span>
          <span class="htag">北斗市</span>
          <span class="htag">七飯町</span>
          <span class="htag">道南エリア</span>
        </div>
      </div>
    </div>

    <!-- List -->
    <div class="ouen-list wrap">

      {sorted.length === 0 ? (
        <div class="empty">
          <p class="empty-icon">💰</p>
          <p class="empty-title">現在応援中のプロジェクトはありません</p>
          <p class="empty-sub">道南のプロジェクト情報をご存知の方はぜひ教えてください！</p>
          <a href="/submit" class="empty-btn">情報を投稿する →</a>
        </div>
      ) : sorted.map(cf => {
        const p = pct(cf.data.currentAmount, cf.data.goalAmount);
        const days = daysLeft(cf.data.endDate);
        const ended = days === 0;
        const isPurchaseType = !cf.data.goalAmount;
        return (
          <article class={`cf-card ${ended ? 'cf-card--ended' : ''}`}>
            <div class="cf-card-inner">

              <!-- Left: Info -->
              <div class="cf-info">
                <div class="cf-meta">
                  <span class="cf-area">{cf.data.area}</span>
                  <span class="cf-cat">{cf.data.category}</span>
                  {isPurchaseType && <span class="cf-purchase">応援購入型</span>}
                  {!ended && days <= 7 && <span class="cf-urgent">🔥 残り{days}日</span>}
                  {ended && <span class="cf-ended">終了</span>}
                </div>
                <h2 class="cf-title">{cf.data.title}</h2>
                <p class="cf-summary">{cf.data.summary}</p>
                <p class="cf-owner">主催：{cf.data.owner}</p>
              </div>

              <!-- Right: Progress -->
              <div class="cf-progress">
                {p !== null ? (
                  <>
                    <div class="cf-pct-num">{p}<span>%</span></div>
                    <div class="cf-bar-wrap">
                      <div class="cf-bar">
                        <div class="cf-fill" style={`--pct: ${p}%`}></div>
                      </div>
                    </div>
                    <div class="cf-amounts">
                      <p class="cf-current">{fmtYen(cf.data.currentAmount)}</p>
                      <p class="cf-goal">目標 {fmtYen(cf.data.goalAmount)}</p>
                    </div>
                  </>
                ) : (
                  <div class="cf-purchase-info">
                    <p class="cf-purchase-icon">🎫</p>
                    <p class="cf-purchase-label">応援購入型</p>
                    <p class="cf-current">{fmtYen(cf.data.currentAmount)} 集まっています</p>
                  </div>
                )}
                <div class="cf-sub-stats">
                  <div class="cf-sub-stat">
                    <b>{cf.data.supporterCount}</b>
                    <span>人が支援</span>
                  </div>
                  <div class="cf-sub-stat">
                    <b>{ended ? '終了' : `${days}日`}</b>
                    <span>{ended ? '' : '残り'}</span>
                  </div>
                </div>
                {!ended && (
                  <a href={cf.data.url} target="_blank" rel="noopener" class="cf-link-btn">
                    詳細を見て応援する ↗
                  </a>
                )}
              </div>

            </div>
          </article>
        );
      })}
    </div>

    <!-- Submit CTA -->
    <div class="submit-band wrap">
      <div class="submit-inner">
        <div>
          <p class="submit-title">応援してほしいプロジェクトを教えてください！</p>
          <p class="submit-sub">「こんなプロジェクトがある」「うちのお店を紹介してほしい」大歓迎です。勝手に応援します。</p>
        </div>
        <a href="/submit" class="submit-btn">情報を投稿する →</a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
.ouen-page { background: #F5EDD8; min-height: 100vh; }
.wrap { max-width: 1100px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: #9E3D26;
  padding: 96px 0 64px;
}
.hero-texture {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 28px, rgba(0,0,0,0.07) 28px, rgba(0,0,0,0.07) 30px),
    repeating-linear-gradient(90deg, transparent, transparent 56px, rgba(0,0,0,0.05) 56px, rgba(0,0,0,0.05) 58px);
  background-size: 58px 30px;
}
.page-hero-inner { position: relative; z-index: 1; }
.hero-stamp {
  display: inline-block; background: #D4A02A; color: #2A2420;
  font-size: 10px; font-weight: 900; letter-spacing: 0.3em;
  padding: 4px 16px; transform: rotate(-1.5deg);
  font-family: 'Shippori Mincho', serif;
  border: 2px solid #2A2420; margin-bottom: 16px;
}
.hero-eye { font-size: 11px; letter-spacing: 0.3em; color: rgba(245,237,216,0.6); font-weight: 700; margin-bottom: 10px; }
.hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(28px, 5vw, 48px); font-weight: 900;
  color: #F5EDD8; letter-spacing: 0.04em; margin-bottom: 16px;
}
.hero-sub { font-size: 14px; color: rgba(245,237,216,0.75); line-height: 2; margin-bottom: 20px; }
.hero-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.htag {
  background: rgba(245,237,216,0.15); color: #F5EDD8;
  font-size: 11px; font-weight: 600; padding: 4px 12px;
  border: 1px solid rgba(245,237,216,0.3); letter-spacing: 0.06em;
}

/* List */
.ouen-list { padding: 56px 0 80px; display: flex; flex-direction: column; gap: 16px; }

/* Card */
.cf-card {
  background: #FBF7EF;
  border: 2px solid #2A2420;
  box-shadow: 4px 4px 0 #9E3D26;
  overflow: hidden;
  transition: transform 0.22s, box-shadow 0.22s;
}
.cf-card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #9E3D26; }
.cf-card--ended { opacity: 0.65; }
.cf-card-inner { display: grid; grid-template-columns: 1fr 260px; }

/* Info */
.cf-info { padding: 28px 28px 28px 32px; border-right: 2px solid #EDE3CC; }
.cf-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
.cf-area {
  font-size: 10px; font-weight: 800; padding: 2px 8px;
  background: #F7E8E2; color: #9E3D26; border: 1px solid #9E3D26;
  font-family: 'Shippori Mincho', serif;
}
.cf-cat { font-size: 10px; font-weight: 600; padding: 2px 8px; background: #EDE3CC; color: #5A4A3A; border: 1px solid #8A7A6A; }
.cf-purchase { font-size: 10px; font-weight: 700; padding: 2px 8px; background: #FBF3DB; color: #D4A02A; border: 1px solid #D4A02A; }
.cf-urgent { font-size: 10px; font-weight: 700; padding: 2px 8px; background: #2A2420; color: #D4A02A; }
.cf-ended { font-size: 10px; font-weight: 700; padding: 2px 8px; background: #EDE3CC; color: #8A7A6A; border: 1px solid #8A7A6A; }
.cf-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 17px; font-weight: 800; color: #2A2420; line-height: 1.65; margin-bottom: 10px;
}
.cf-summary { font-size: 13px; color: #5A4A3A; line-height: 1.85; margin-bottom: 14px; }
.cf-owner { font-size: 11px; color: #8A7A6A; }

/* Progress */
.cf-progress { padding: 24px 24px 24px 20px; display: flex; flex-direction: column; gap: 10px; background: #F7EDE5; }
.cf-pct-num {
  font-family: 'Shippori Mincho', serif;
  font-size: 42px; font-weight: 900; color: #9E3D26; line-height: 1;
}
.cf-pct-num span { font-size: 18px; }
.cf-bar { height: 10px; background: #EDE3CC; border: 1px solid #8A7A6A; }
.cf-fill { height: 100%; background: #9E3D26; width: 0; animation: fillBar 1.2s 0.3s ease-out forwards; }
@keyframes fillBar { to { width: var(--pct); } }
.cf-current { font-size: 18px; font-weight: 800; color: #2A2420; font-family: 'Shippori Mincho', serif; }
.cf-goal { font-size: 11px; color: #8A7A6A; margin-top: 2px; }
.cf-purchase-info { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 0; }
.cf-purchase-icon { font-size: 32px; line-height: 1; }
.cf-purchase-label { font-size: 11px; font-weight: 700; color: #D4A02A; letter-spacing: 0.05em; font-family: 'Shippori Mincho', serif; }
.cf-sub-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.cf-sub-stat {
  background: #FBF7EF; border: 1px solid #EDE3CC;
  padding: 10px 12px; text-align: center;
}
.cf-sub-stat b { display: block; font-size: 16px; font-weight: 900; color: #2A2420; font-family: 'Shippori Mincho', serif; }
.cf-sub-stat span { font-size: 10px; color: #8A7A6A; letter-spacing: 0.05em; }
.cf-link-btn {
  display: block; text-align: center; padding: 12px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420;
  font-size: 12px; font-weight: 800;
  letter-spacing: 0.06em;
  font-family: 'Shippori Mincho', serif;
  transition: background 0.2s;
  margin-top: auto;
}
.cf-link-btn:hover { background: #B84A2E; }

/* Empty */
.empty { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 48px; margin-bottom: 16px; }
.empty-title { font-family: 'Shippori Mincho', serif; font-size: 20px; font-weight: 700; color: #2A2420; margin-bottom: 8px; }
.empty-sub { font-size: 14px; color: #8A7A6A; margin-bottom: 28px; }
.empty-btn {
  display: inline-block; padding: 12px 28px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420;
  font-weight: 800; font-size: 13px;
  font-family: 'Shippori Mincho', serif;
}

/* Submit band */
.submit-band { padding-bottom: 80px; }
.submit-inner {
  background: #2A2420;
  border: 2px solid #2A2420;
  box-shadow: 4px 4px 0 #9E3D26;
  padding: 32px 40px; display: flex;
  align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
}
.submit-title { font-family: 'Shippori Mincho', serif; font-size: 17px; font-weight: 800; color: #F5EDD8; margin-bottom: 6px; }
.submit-sub { font-size: 13px; color: #8A7A6A; line-height: 1.7; }
.submit-btn {
  flex-shrink: 0; padding: 12px 24px;
  background: #D4A02A; color: #2A2420;
  border: 2px solid #D4A02A;
  font-size: 13px; font-weight: 800;
  font-family: 'Shippori Mincho', serif;
  white-space: nowrap; transition: background 0.2s;
}
.submit-btn:hover { background: #E0AD30; }

/* Responsive */
@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 88px 0 48px; }
  .cf-card-inner { grid-template-columns: 1fr; }
  .cf-info { border-right: none; border-bottom: 2px solid #EDE3CC; padding: 20px 16px; }
  .cf-progress { padding: 16px; }
  .submit-inner { padding: 24px 20px; flex-direction: column; align-items: flex-start; }
}
</style>
