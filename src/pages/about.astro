---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="このメディアについて"
  description="函館の当たり前を、勝手に測って証明するデータ・ジャーナリズム・メディア「カッテニハコダテ」のコンセプト。">
  <Header />

  <!-- HERO -->
  <section class="concept-hero">
    <div class="concept-hero-grid" aria-hidden="true"></div>
    <div class="ch-inner">
      <p class="ch-label">KATTENI HAKODATE — CITY EXPERIMENT REPORT</p>
      <h1 class="ch-title">
        私たちは、<br>
        <em>函館を測る</em>ために<br>
        存在します。
      </h1>
      <p class="ch-sub">データ・ジャーナリズム × ローカル × ユーモア</p>
    </div>
  </section>

  <main class="about-main">

    <!-- 01 WHAT -->
    <section class="about-section">
      <div class="wrap">
        <div class="two-col">
          <div class="col-label">
            <p class="col-num">01</p>
            <p class="col-eye">WHAT WE DO</p>
          </div>
          <div class="col-body">
            <h2 class="col-title">誰も測っていないものを、<br>私たちが測る。</h2>
            <p class="col-text">
              函館には、「当たり前」がたくさんあります。坂が多い、霧が出る、
              ラッキーピエロが混んでいる、市電がゆっくり走る。
            </p>
            <p class="col-text">
              でも、その「当たり前」を実際に測った人は、ほとんどいません。
            </p>
            <p class="col-text">
              カッテニハコダテは、その「当たり前」を現地で計量・計測・記録し、
              データとして提示するメディアです。グルメ情報でも観光ガイドでもありません。
              <strong>函館という都市を、勝手に調査する実験報告書です。</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- 02 STANCE -->
    <section class="about-section">
      <div class="wrap">
        <div class="two-col">
          <div class="col-label">
            <p class="col-num">02</p>
            <p class="col-eye">OUR STANCE</p>
          </div>
          <div class="col-body">
            <h2 class="col-title">「私が言ったんじゃない、<br>数字がそう言っている。」</h2>
            <p class="col-text">
              私たちが信じるのは感想ではなく、数値です。
              「おいしい」ではなく「127グラムだった」。
              「坂がきつい」ではなく「勾配8.7度だった」。
            </p>
            <p class="col-text">
              データを盾に持つことで、「函館はこういう街だ」を
              感情論ではなく事実として示せる。それがこのメディアの存在理由です。
            </p>

            <div class="stance-block">
              <div class="stance-item">
                <span class="stance-num">1</span>
                <div>
                  <p class="stance-label">調査（Investigate）</p>
                  <p class="stance-desc">誰も測っていない函館の「当たり前」を発見する</p>
                </div>
              </div>
              <div class="stance-item">
                <span class="stance-num">2</span>
                <div>
                  <p class="stance-label">計測（Measure）</p>
                  <p class="stance-desc">実際に現地へ行き、一次データを取得する</p>
                </div>
              </div>
              <div class="stance-item">
                <span class="stance-num">3</span>
                <div>
                  <p class="stance-label">証明（Prove）</p>
                  <p class="stance-desc">ユーモアで包みながら、数字で事実を語る</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- 03 WHY HAKODATE -->
    <section class="about-section">
      <div class="wrap">
        <div class="two-col">
          <div class="col-label">
            <p class="col-num">03</p>
            <p class="col-eye">WHY HAKODATE</p>
          </div>
          <div class="col-body">
            <h2 class="col-title">函館在住だから、<br>現地で測れる。</h2>
            <p class="col-text">
              The Puddingのようなデータ・ジャーナリズムの多くは、
              遠くからデータを集めて分析します。カッテニハコダテの強みはそこではありません。
            </p>
            <p class="col-text">
              <strong>函館に住んでいるから、実際に行って測れる。</strong>
              ラッキーピエロの全店舗を回ってチキンバーガーの重さを量れる。
              八幡坂の勾配をスマートフォンで計測できる。
              市電に乗って振動周波数を記録できる。
            </p>
            <p class="col-text">
              東京のメディアには絶対に作れない、一次情報の地産地消。
              それがカッテニハコダテです。
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- 04 DAILY NEWS -->
    <section class="about-section">
      <div class="wrap">
        <div class="two-col">
          <div class="col-label">
            <p class="col-num">04</p>
            <p class="col-eye">DAILY NEWS</p>
          </div>
          <div class="col-body">
            <h2 class="col-title">開店・閉店は、<br>毎日追う。</h2>
            <p class="col-text">
              調査報告（実験記事）は月数本ですが、函館の街の変化は毎日追っています。
            </p>
            <p class="col-text">
              新しいお店が開いた、馴染みのあの店が閉まった、工事が始まった——
              そういった日々の変化を記録することも、このメディアの大切な使命です。
            </p>
            <p class="col-text">
              情報をお持ちの方はぜひ送ってください。現地確認した上でニュースに追加します。
            </p>
            <a href="/submit" class="col-cta">情報を送る →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- QUOTE -->
    <section class="quote-section">
      <div class="wrap">
        <blockquote class="big-quote">
          「最高のユーモアは、<br>常に冷徹な事実に基づいている。」
        </blockquote>
        <p class="quote-caption">カッテニハコダテ 運営方針より</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta-section">
      <div class="wrap">
        <div class="about-cta-inner">
          <h2 class="about-cta-title">読む、送る、関わる。</h2>
          <div class="about-cta-btns">
            <a href="/articles" class="cta-btn cta-btn--primary">調査報告を読む →</a>
            <a href="/news" class="cta-btn cta-btn--secondary">ニュースを見る</a>
            <a href="/submit" class="cta-btn cta-btn--ghost">情報を送る ＋</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
.concept-hero {
  position: relative;
  background: #080e1a;
  padding: 140px 0 100px;
  overflow: hidden;
}
.concept-hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(13,45,82,0.18) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13,45,82,0.18) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}
.ch-inner {
  position: relative;
  max-width: 1200px; margin: 0 auto; padding: 0 48px;
}
.ch-label {
  font-size: 9px; letter-spacing: 0.4em; font-weight: 700;
  color: rgba(255,255,255,0.25); text-transform: uppercase;
  margin-bottom: 28px;
}
.ch-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(32px, 5.5vw, 64px); font-weight: 800;
  color: #ffffff; line-height: 1.35; letter-spacing: 0.02em;
  margin-bottom: 24px;
}
.ch-title em { font-style: normal; color: #0d8a87; }
.ch-sub {
  font-size: 13px; color: rgba(255,255,255,0.3);
  letter-spacing: 0.15em;
}

.about-main { background: #ffffff; }
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
.about-section { padding: 80px 0; }

.two-col {
  display: grid; grid-template-columns: 200px 1fr;
  gap: 64px; align-items: start;
}
.col-label { padding-top: 4px; }
.col-num {
  font-family: 'Shippori Mincho', serif;
  font-size: 48px; font-weight: 900;
  color: #e8edf2; line-height: 1; margin-bottom: 8px;
}
.col-eye {
  font-size: 9px; letter-spacing: 0.35em; font-weight: 700;
  color: #0d8a87; text-transform: uppercase;
}
.col-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(22px, 3vw, 30px); font-weight: 800;
  color: #0d0d0d; line-height: 1.45; margin-bottom: 24px;
}
.col-text {
  font-size: 15px; color: #3d4a52; line-height: 2; margin-bottom: 20px;
}
.col-text strong { color: #0d2d52; }
.col-cta {
  display: inline-flex; align-items: center;
  padding: 12px 24px; margin-top: 8px;
  background: #0d8a87; color: #fff;
  font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
  font-family: 'Shippori Mincho', serif; transition: background 0.2s;
}
.col-cta:hover { background: #0a6e6c; }

.stance-block {
  margin-top: 32px;
  border: 1px solid #e4e8ed;
}
.stance-item {
  display: flex; align-items: flex-start; gap: 20px;
  padding: 20px 24px; border-bottom: 1px solid #e4e8ed;
}
.stance-item:last-child { border-bottom: none; }
.stance-num {
  width: 28px; height: 28px; flex-shrink: 0;
  background: #0d2d52; color: #fff;
  font-size: 11px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Shippori Mincho', serif;
}
.stance-label {
  font-size: 13px; font-weight: 700; color: #0d2d52;
  margin-bottom: 4px; font-family: 'Shippori Mincho', serif;
}
.stance-desc { font-size: 12px; color: #6c757d; line-height: 1.7; }

.divider { border: none; border-top: 1px solid #e8edf2; margin: 0; }

.quote-section { padding: 96px 0; background: #0d2d52; }
.big-quote {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(20px, 3vw, 32px);
  font-weight: 800; color: #fff;
  line-height: 1.65; text-align: center;
  max-width: 640px; margin: 0 auto 20px;
}
.quote-caption {
  text-align: center; font-size: 11px;
  color: rgba(255,255,255,0.3); letter-spacing: 0.15em;
}

.about-cta-section {
  padding: 88px 0; background: #f7f8fa;
  border-top: 1px solid #e4e8ed;
}
.about-cta-inner { text-align: center; }
.about-cta-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 28px; font-weight: 800; color: #0d0d0d;
  margin-bottom: 36px;
}
.about-cta-btns {
  display: flex; align-items: center; justify-content: center;
  gap: 12px; flex-wrap: wrap;
}
.cta-btn {
  display: inline-flex; align-items: center;
  padding: 14px 28px;
  font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
  font-family: 'Shippori Mincho', serif; transition: all 0.2s;
}
.cta-btn--primary { background: #0d8a87; color: #fff; border: 2px solid #0d8a87; }
.cta-btn--primary:hover { background: #0a6e6c; }
.cta-btn--secondary { border: 2px solid #0d2d52; color: #0d2d52; }
.cta-btn--secondary:hover { background: #0d2d52; color: #fff; }
.cta-btn--ghost { border: 2px solid #d0d6de; color: #6c757d; }
.cta-btn--ghost:hover { border-color: #0d8a87; color: #0d8a87; }

@media (max-width: 900px) {
  .wrap { padding: 0 24px; }
  .ch-inner { padding: 0 24px; }
  .two-col { grid-template-columns: 1fr; gap: 24px; }
  .col-num { font-size: 32px; }
  .about-section { padding: 56px 0; }
  .quote-section { padding: 64px 0; }
  .about-cta-section { padding: 64px 0; }
}
@media (max-width: 600px) {
  .concept-hero { padding: 100px 0 64px; }
  .about-cta-btns { flex-direction: column; align-items: stretch; }
  .cta-btn { justify-content: center; }
}
</style>
