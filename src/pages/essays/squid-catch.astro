---
import Navigation from '../../components/Navigation.tsx';
import SquidScrolly from '../../components/visuals/squid/SquidScrolly.tsx';
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>函館のイカが消えていく | カッテニハコダテ</title>
  <meta name="description" content="スルメイカの漁獲量はピークから93%減。「イカの街・函館」は、あとどれくらい続くのか。データで読み解く。" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RFE6QTKL22"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RFE6QTKL22');
  </script>
</head>
<body style="background:#040e1e; color:white; margin:0;">

  <Navigation client:load />

  <!-- カバー -->
  <div style="height:100svh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 2rem 6rem;position:relative;overflow:hidden;background:linear-gradient(160deg,#0a2a4a,#040810);">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 60%,rgba(0,120,200,0.15),transparent 60%);"></div>
    <div style="position:relative;z-index:1;max-width:700px;">
      <p style="font-family:Inter,sans-serif;font-size:10px;letter-spacing:.3em;opacity:.4;text-transform:uppercase;margin-bottom:1.5rem;">
        Data Essay / 漁業
      </p>
      <h1 style="font-family:'Shippori Mincho',serif;font-size:clamp(2.5rem,8vw,6rem);line-height:1.1;letter-spacing:.04em;margin-bottom:1.5rem;font-feature-settings:'palt'">
        函館のイカが、<br />消えていく。
      </h1>
      <p style="font-family:Inter,sans-serif;font-size:.9rem;opacity:.5;line-height:1.8;max-width:480px;">
        スルメイカの漁獲量はピークから93%減。<br />
        「イカの街・函館」は、あとどれくらい続くのか。
      </p>
      <div style="margin-top:2rem;display:flex;gap:2rem;font-family:Inter,sans-serif;font-size:10px;opacity:.3;letter-spacing:.1em;">
        <span>2026年4月</span><span>·</span>
        <span>読了 6分</span><span>·</span>
        <span>出典: 函館市漁業統計（架空データ）</span>
      </div>
    </div>
    <div style="position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);text-align:center;">
      <p style="font-family:Inter,sans-serif;font-size:9px;letter-spacing:.2em;opacity:.3;text-transform:uppercase;margin-bottom:.5rem;">Scroll</p>
      <div style="width:1px;height:40px;background:rgba(255,255,255,.2);margin:0 auto;"></div>
    </div>
  </div>

  <SquidScrolly client:load />

  <!-- エッセイ末尾 -->
  <div style="background:#040e1e;padding:5rem 2rem 8rem;max-width:680px;margin:0 auto;">
    <p style="font-family:'Shippori Mincho',serif;font-size:1.6rem;line-height:1.8;letter-spacing:.04em;margin-bottom:2rem;font-feature-settings:'palt';opacity:.9;">
      「イカの街」というアイデンティティが消える前に、<br />私たちは何を残せるだろうか。
    </p>
    <p style="font-family:Inter,sans-serif;font-size:.8rem;line-height:1.9;opacity:.5;">
      データは冷徹に、しかし正直に現実を示す。函館のイカ漁の未来は、
      海の温暖化という地球規模の問題と不可分に結びついている。
      一地方の漁業問題ではなく、気候変動が地域アイデンティティを奪う最前線の出来事として向き合う必要がある。
    </p>
    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,.1);">
      <a href="/essays" style="font-family:Inter,sans-serif;font-size:10px;letter-spacing:.2em;opacity:.4;text-transform:uppercase;text-decoration:none;color:inherit;">← 一覧に戻る</a>
    </div>
  </div>

</body>
</html>
