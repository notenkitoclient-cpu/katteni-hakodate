---
import { getCollection, render } from 'astro:content';
import Navigation from '../../components/Navigation.tsx';
import '../../styles/global.css';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

const coverBg = essay.data.coverBg ?? 'linear-gradient(135deg,#111 0%,#1a1a2e 100%)';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{essay.data.title} | カッテニハコダテ</title>
  {essay.data.subtitle && <meta name="description" content={essay.data.subtitle} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet" />
  <style>
    body { margin: 0; background: #111; color: white; }
    /* MDX内のpタグデフォルトスタイルをリセット */
    .essay-content p { margin: 0; }
  </style>
</head>
<body>

  <Navigation client:load />

  <!-- カバー -->
  <div style={`background:${coverBg}; min-height:100vh; display:flex; align-items:flex-end; padding:0 2.5rem 5rem;`}>
    <div style="max-width:800px; margin:0 auto; width:100%; padding-top:8rem;">
      <p style="font-family:Inter,sans-serif; font-size:10px; letter-spacing:.3em; opacity:.4; text-transform:uppercase; margin-bottom:1.5rem; color:white;">
        {essay.data.date.replace(/-/g,'.')} · {essay.data.minutes}分
      </p>
      <h1 style="font-family:'Shippori Mincho',serif; font-size:clamp(2.5rem,8vw,6rem); line-height:1.1; letter-spacing:.06em; margin-bottom:1.5rem; font-feature-settings:'palt'; color:white;">
        {essay.data.title}
      </h1>
      {essay.data.subtitle && (
        <p style="font-family:Inter,sans-serif; font-size:1rem; opacity:.5; letter-spacing:.04em; color:white; margin:0;">
          {essay.data.subtitle}
        </p>
      )}
    </div>
  </div>

  <!-- MDXコンテンツ -->
  <div class="essay-content">
    <Content />
  </div>

</body>
</html>
