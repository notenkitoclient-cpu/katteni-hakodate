---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sources = [
  { name: 'はこしん デジタル', url: 'https://digital.hakoshin.jp/', desc: '函館新聞社が運営する函館・道南の地域情報サイト' },
  { name: '青いポスト (aopos)',  url: 'https://aopos.jp/',            desc: '函館エリアのローカル情報・イベントまとめ' },
  { name: 'はこだてイベント情報', url: 'https://hakodate-event.com/', desc: '函館市内のイベント情報に特化したポータル' },
];
---

<BaseLayout title="勝手にイベント情報団" description="道南エリアのイベント情報を勝手にまとめます！近日公開予定。">
  <Header />

  <main class="ev-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="page-hero-bg" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <div class="stamp-label">勝手に</div>
        <p class="page-eye">🎉 Events</p>
        <h1 class="page-title">イベント情報団</h1>
        <p class="page-sub">
          函館・北斗・七飯ほか道南エリアのイベント情報を<br>
          勝手にまとめて、勝手にお届けします。
        </p>
        <div class="page-tags">
          <span class="ptag">函館</span>
          <span class="ptag">北斗市</span>
          <span class="ptag">七飯町</span>
          <span class="ptag">道南エリア</span>
        </div>
      </div>
    </div>

    <!-- Coming soon -->
    <div class="coming-wrap wrap">

      <div class="coming-card">
        <div class="coming-icon">🚧</div>
        <h2 class="coming-title">近日公開予定！</h2>
        <p class="coming-desc">
          現在、道南エリアのイベント情報を自動収集する仕組みを構築中です。<br>
          下記のサイトを参考に情報を集めています。<br>
          もうしばらくお待ちください！
        </p>
      </div>

      <!-- Sources -->
      <div class="sources">
        <h3 class="sources-head">📡 参考にしている情報源</h3>
        <div class="source-list">
          {sources.map(s => (
            <a href={s.url} target="_blank" rel="noopener" class="source-card">
              <div class="source-icon">🔗</div>
              <div class="source-body">
                <p class="source-name">{s.name}</p>
                <p class="source-desc">{s.desc}</p>
              </div>
              <span class="source-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="ev-cta">
        <div class="ev-cta-inner">
          <div>
            <p class="ev-cta-title">イベント情報を教えてください！</p>
            <p class="ev-cta-desc">「こんなイベントがある」「このページを見て」という情報、大歓迎です。勝手に紹介します。</p>
          </div>
          <a href="/submit" class="ev-cta-btn">情報を投稿する →</a>
        </div>
      </div>

    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
.ev-page { background: #faf7f0; min-height: 100vh; }
.wrap { max-width: 900px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #0d2040 0%, #0d2d52 50%, #0d4a72 100%);
  padding: 100px 0 72px;
}
.page-hero-bg {
  position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
  background-size: 24px 24px;
}
.page-hero-inner { position: relative; z-index: 1; }
.stamp-label { display: inline-block; background: rgba(255,255,255,0.15); color: white; font-size: 10px; font-weight: 900; letter-spacing: 0.25em; padding: 4px 14px; border-radius: 2px; transform: rotate(-1deg); margin-bottom: 16px; }
.page-eye { font-size: 11px; letter-spacing: 0.3em; color: rgba(255,255,255,0.6); font-weight: 700; margin-bottom: 10px; }
.page-title { font-family: 'Shippori Mincho', serif; font-size: clamp(32px, 5vw, 52px); font-weight: 900; color: white; letter-spacing: 0.04em; margin-bottom: 16px; }
.page-sub { font-size: 15px; color: rgba(255,255,255,0.78); line-height: 1.9; margin-bottom: 24px; }
.page-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.ptag { background: rgba(255,255,255,0.12); color: white; font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 14px; letter-spacing: 0.06em; }

/* Coming soon */
.coming-wrap { padding: 64px 0 80px; display: flex; flex-direction: column; gap: 40px; }
.coming-card { background: white; border-radius: 20px; border: 1.5px solid #e8eef4; padding: 56px 48px; text-align: center; }
.coming-icon { font-size: 56px; margin-bottom: 20px; }
.coming-title { font-family: 'Shippori Mincho', serif; font-size: 26px; font-weight: 800; color: #0d2d52; margin-bottom: 16px; }
.coming-desc { font-size: 14px; color: #5a7080; line-height: 2; }

/* Sources */
.sources {}
.sources-head { font-size: 13px; font-weight: 700; color: #0d8a87; letter-spacing: 0.12em; margin-bottom: 16px; }
.source-list { display: flex; flex-direction: column; gap: 10px; }
.source-card { display: flex; align-items: center; gap: 16px; background: white; border-radius: 12px; border: 1.5px solid #e8eef4; padding: 18px 20px; text-decoration: none; transition: border-color 0.2s, transform 0.2s; }
.source-card:hover { border-color: #0d8a87; transform: translateX(4px); }
.source-icon { font-size: 20px; flex-shrink: 0; }
.source-body { flex: 1; }
.source-name { font-size: 14px; font-weight: 700; color: #0d2d52; margin-bottom: 3px; }
.source-desc { font-size: 12px; color: #7a9aaa; }
.source-arrow { font-size: 16px; color: #9ab8c8; flex-shrink: 0; }

/* CTA */
.ev-cta {}
.ev-cta-inner { background: #0d2d52; border-radius: 14px; padding: 36px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
.ev-cta-title { font-family: 'Shippori Mincho', serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 6px; }
.ev-cta-desc { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.7; }
.ev-cta-btn { flex-shrink: 0; padding: 13px 28px; background: #e8734a; color: white; border-radius: 6px; font-size: 13px; font-weight: 700; white-space: nowrap; transition: background 0.2s; }
.ev-cta-btn:hover { background: #f0845a; }

@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 88px 0 52px; }
  .coming-card { padding: 36px 24px; }
  .ev-cta-inner { flex-direction: column; align-items: flex-start; padding: 24px 20px; }
}
</style>
