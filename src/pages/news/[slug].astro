---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('news');
  return all.map(item => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const TYPE_CONFIG: Record<string, { label: string; color: string; bg: string }> = {
  '開店':     { label: '開店',   color: '#F5EDD8', bg: '#2A7A3A' },
  '閉店':     { label: '閉店',   color: '#F5EDD8', bg: '#2A2420' },
  '工事中':   { label: '工事中', color: '#2A2420', bg: '#D4A02A' },
  'イベント': { label: 'EVENT',  color: '#F5EDD8', bg: '#9E3D26' },
  '目撃情報': { label: '目撃',   color: '#F5EDD8', bg: '#3D6B9E' },
  'その他':   { label: 'INFO',   color: '#2A2420', bg: '#C8BEA8' },
};
const cfg = TYPE_CONFIG[item.data.type] ?? TYPE_CONFIG['その他'];

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
---

<BaseLayout title={item.data.title} description={`${item.data.area}の${item.data.type}情報。${item.data.title}`}>
  <Header />

  <main class="news-detail-page">

    <!-- Hero -->
    <div class="page-hero">
      <div class="hero-texture" aria-hidden="true"></div>
      <div class="page-hero-inner wrap">
        <nav class="breadcrumb">
          <a href="/">ホーム</a>
          <span>›</span>
          <a href="/news">情報収集</a>
          <span>›</span>
          <span>{item.data.title}</span>
        </nav>
        <div class="hero-meta">
          <span class="type-badge" style={`background:${cfg.bg}; color:${cfg.color}`}>{cfg.label}</span>
          <span class="hero-area">📍 {item.data.area}</span>
        </div>
        <h1 class="hero-title">{item.data.title}</h1>
        <div class="hero-sub-meta">
          <span class="hero-date">{formatDate(item.data.date)}</span>
          <span class="hero-reporter">by {item.data.reporter}</span>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="wrap">
      <div class="content-board">
        <div class="board-tape t1" aria-hidden="true"></div>
        <div class="board-tape t2" aria-hidden="true"></div>

        <div class="content-body">
          <Content />
        </div>

        {item.data.source && (
          <div class="source-box">
            <span class="source-label">情報元</span>
            <a href={item.data.source} target="_blank" rel="noopener" class="source-link">
              {item.data.source} ↗
            </a>
          </div>
        )}
      </div>

      <!-- 情報提供CTA -->
      <div class="cta-board">
        <div class="board-tape t3" aria-hidden="true"></div>
        <p class="cta-title">続報・追加情報をお持ちですか？</p>
        <p class="cta-desc">「その後こうなった」「詳細を知っている」などの情報、ぜひ教えてください。</p>
        <a href="/submit" class="cta-btn">情報を投稿する ＋</a>
      </div>

      <!-- 戻るリンク -->
      <div class="back-wrap">
        <a href="/news" class="back-link">← 情報収集一覧に戻る</a>
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
.news-detail-page { background: #F5EDD8; min-height: 100vh; }
.wrap { max-width: 720px; margin: 0 auto; padding: 0 40px; }

/* Hero */
.page-hero {
  position: relative; overflow: hidden;
  background: #9E3D26; padding: 80px 0 56px;
}
.hero-texture {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 28px, rgba(0,0,0,0.07) 28px, rgba(0,0,0,0.07) 30px),
    repeating-linear-gradient(90deg, transparent, transparent 56px, rgba(0,0,0,0.05) 56px, rgba(0,0,0,0.05) 58px);
  background-size: 58px 30px;
}
.page-hero-inner { position: relative; z-index: 1; }

.breadcrumb {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; color: rgba(245,237,216,0.5);
  margin-bottom: 20px; flex-wrap: wrap;
}
.breadcrumb a { color: rgba(245,237,216,0.6); }
.breadcrumb a:hover { color: #F5EDD8; }
.breadcrumb span:last-child { color: rgba(245,237,216,0.4); }

.hero-meta {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 16px;
}
.type-badge {
  font-size: 10px; font-weight: 900; letter-spacing: 0.1em;
  padding: 5px 12px; font-family: 'Shippori Mincho', serif;
}
.hero-area { font-size: 12px; color: rgba(245,237,216,0.75); font-weight: 700; }

.hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(20px, 4vw, 32px); font-weight: 900;
  color: #F5EDD8; line-height: 1.5;
  letter-spacing: 0.03em; margin-bottom: 16px;
}
.hero-sub-meta {
  display: flex; align-items: center; gap: 16px;
  font-size: 12px; color: rgba(245,237,216,0.55);
}

/* Content board */
.content-board {
  position: relative;
  background: #FBF7EF;
  border: 2px solid #2A2420;
  box-shadow: 5px 5px 0 #9E3D26;
  padding: 40px 40px 36px;
  margin: 48px 0 24px;
}
.board-tape {
  position: absolute; height: 18px;
  background: rgba(212,160,42,0.75);
  border: 1px solid rgba(42,36,32,0.25);
}
.t1 { width: 52px; top: -9px; left: 28px; transform: rotate(-1.5deg); }
.t2 { width: 44px; top: -9px; right: 52px; transform: rotate(1.5deg); }
.t3 { width: 48px; top: -9px; left: 40px; transform: rotate(-1deg); }

.content-body {
  font-size: 15px; color: #2A2420; line-height: 2;
}
.content-body p { margin: 0 0 1em; }

.source-box {
  display: flex; align-items: center; gap: 12px;
  margin-top: 28px; padding-top: 20px;
  border-top: 1px dashed rgba(42,36,32,0.2);
}
.source-label {
  font-size: 10px; font-weight: 800; letter-spacing: 0.1em;
  color: #8A7A6A; white-space: nowrap;
}
.source-link {
  font-size: 12px; color: #9E3D26;
  word-break: break-all;
  border-bottom: 1px solid currentColor;
}

/* CTA */
.cta-board {
  position: relative;
  background: #EDE3CC;
  border: 2px solid #2A2420;
  padding: 28px 32px;
  margin-bottom: 24px;
  text-align: center;
}
.cta-title {
  font-family: 'Shippori Mincho', serif;
  font-size: 16px; font-weight: 900; color: #2A2420; margin-bottom: 8px;
}
.cta-desc { font-size: 13px; color: #5A4A3A; line-height: 1.8; margin-bottom: 20px; }
.cta-btn {
  display: inline-block; padding: 12px 28px;
  background: #9E3D26; color: #F5EDD8;
  border: 2px solid #2A2420;
  box-shadow: 3px 3px 0 #2A2420;
  font-size: 14px; font-weight: 900;
  font-family: 'Shippori Mincho', serif;
  letter-spacing: 0.06em;
  transition: transform 0.15s, box-shadow 0.15s;
}
.cta-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #2A2420; }

/* 戻る */
.back-wrap { padding: 8px 0 72px; }
.back-link {
  font-size: 13px; color: #9E3D26; font-weight: 700;
  border-bottom: 1px solid currentColor;
}
.back-link:hover { color: #2A2420; }

@media (max-width: 768px) {
  .wrap { padding: 0 16px; }
  .page-hero { padding: 72px 0 40px; }
  .content-board { padding: 28px 20px; }
}
</style>
